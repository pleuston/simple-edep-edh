                Iulia Epipodia fecit sibi <lb n="2"/>et co<expan><ex>n</ex><abbr>iugi</abbr></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> Aemili Feli<lb break="no" n="3"/>cissimi et filibus <note>sic</note> su<lb break="no" n="4"/>is <expan><abbr>M</abbr><ex>arco</ex></expan> Iulio Silbano <note>sic</note> <lb n="5"/>libertis libertabu<lb break="no" n="6"/>sque posteri<expan><ex>s</ex><abbr>que</abbr></expan> eo<lb break="no" n="7"/>run <note>sic</note> in <expan><abbr>fr</abbr><ex>onte</ex></expan> <expan><abbr>p</abbr><ex>edes</ex></expan> XXV <expan><abbr>S</abbr><ex>emis</ex></expan> <lb n="8"/>in <expan><abbr>ag</abbr><ex>ro</ex></expan> <expan><abbr>p</abbr><ex>edes</ex></expan> XXX
            </ab></div>
