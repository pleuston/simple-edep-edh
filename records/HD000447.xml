            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Fl</abbr><ex>avi</ex></expan> Arpagii <expan><abbr>v</abbr><ex>iri</ex></expan> <expan><abbr>c</abbr><ex>larissimi</ex></expan> <lb n="2"/><expan><abbr>Fl</abbr><ex>avio</ex></expan> Arpagio <expan><abbr>fl</abbr><ex>amini</ex></expan> p<expan><ex>er</ex><abbr>p</abbr><ex>etuo</ex></expan> huiusce <lb n="3"/>civitatis ex agente in <lb n="4"/>rebus <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>c</abbr><ex>larissimo</ex></expan> ex <expan><abbr>adiut</abbr><ex>ore</ex></expan> <expan><abbr>inl</abbr><ex>ustris</ex></expan> <lb n="5"/>viri <expan><abbr>mag</abbr><ex>istri</ex></expan> <expan><abbr>officior</abbr><ex>um</ex></expan> <expan><abbr>v</abbr><ex>iro</ex></expan> <lb n="6"/><expan><abbr>spectab</abbr><ex>ili</ex></expan> <expan><abbr>trib</abbr><ex>uno</ex></expan> et <expan><abbr>not</abbr><ex>ario</ex></expan> <lb n="7"/>ob insignia eius erga <lb n="8"/>rem <expan><abbr>p</abbr><ex>ublicam</ex></expan> merita et praecipue <lb n="9"/>ob <expan><abbr>pat</abbr><ex>ronatus</ex></expan> <expan><abbr>benef</abbr><ex>icia</ex></expan> statuam ad <lb n="10"/>aeternitatem meri<lb break="no" n="11"/>torum eius <expan><abbr>Miss</abbr><ex>uenses</ex></expan> cives <lb n="12"/>conlocaverunt
            </ab></div>
