            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Ordo <expan><abbr>sanctissim</abbr><ex>us</ex></expan> <lb n="2"/><expan><abbr>Q</abbr><ex>uinto</ex></expan> Avilio <expan><abbr>Q</abbr><ex>uinti</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> Sennio <lb n="3"/>Palatina Comini<lb break="no" n="4"/>ano in honorem pa<lb break="no" n="5"/>tris eius <expan><abbr>Q</abbr><ex>uinti</ex></expan> Avili Hyacin<lb break="no" n="6"/>thi quod is praeter libera<lb break="no" n="7"/>litates spectaculorum quae <lb n="8"/>sponte ededit <note>sic</note> vel postulata <lb n="9"/>non negavit velis novis sum<lb break="no" n="10"/>ptu suo in theatro positis cum <lb n="11"/>suis armamentis saepe pecunia <lb n="12"/>mutua quae a magistratibus <lb n="13"/>petebatur data actum publicum <lb n="14"/>iuverit
            </ab></div>
