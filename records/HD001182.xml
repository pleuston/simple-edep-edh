                <expan><abbr>Pridi</abbr><ex>e</ex></expan> <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Mart</abbr><ex>ias</ex></expan> <lb n="2"/>&amp;lt;Mar&amp;gt;<expan><abbr>tinianus</abbr><ex cert="low"/></expan> <lb n="3"/><expan><abbr>h</abbr><ex>ic</ex></expan> situs
