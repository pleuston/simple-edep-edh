                <expan><abbr>P</abbr><ex>ublio</ex></expan> Petronio <lb n="2"/>Trophimo Pet<lb break="no" n="3"/>ronia Chreste ma<lb break="no" n="4"/>t<expan><ex>e</ex><abbr>r</abbr></expan> posuit <expan><abbr>P</abbr><ex>ublius</ex></expan> Petronius <lb n="5"/>Tiasus posu<expan><ex>i</ex><abbr>t</abbr></expan> <expan><abbr>an</abbr><ex>norum</ex></expan> XX <lb n="6"/><expan><abbr>h</abbr><ex>ic</ex></expan> <expan><abbr>i</abbr><ex>acet</ex></expan> <expan><abbr>s</abbr><ex>epultus</ex></expan>
