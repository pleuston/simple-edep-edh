                Diis <expan><abbr>Mani</abbr><ex>bus</ex></expan> <lb n="2"/><expan><abbr>T</abbr><ex>ito</ex></expan> Fufio <expan><abbr>Carp</abbr><ex>o</ex></expan> <lb n="3"/>fecit <lb n="4"/>Fufia Rodope <lb n="5"/>co<expan><ex>n</ex><abbr>iugi</abbr></expan> suo <lb n="6"/>et Verna filius <lb n="7"/><expan><abbr>d</abbr><ex>ono</ex></expan> <expan><abbr>d</abbr><ex>ederunt</ex></expan>
