                <expan><ex>H</ex><abbr>ic</abbr></expan> iacet Gaudi<lb break="no" n="2"/>osa infantula <lb n="3"/>qui <note>sic</note> bissit <note>sic</note> annoru<lb break="no" n="4"/>m plus <expan><abbr>minu</abbr><ex>s</ex></expan> tre<lb break="no" n="5"/>s requiebit <note>sic</note> in <lb n="6"/>pacem <note>sic</note>
