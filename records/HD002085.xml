                <expan><abbr>Ti</abbr><ex>berius</ex></expan> Claudius <lb n="2"/><expan><abbr>Cl</abbr><ex>audi</ex></expan> Crispi <expan><abbr>f</abbr><ex>ilius</ex></expan> <expan><abbr>Quir</abbr><ex>ina</ex></expan> <lb n="3"/>Germanus <expan><abbr>vix</abbr><ex>it</ex></expan> <lb n="4"/><expan><abbr>n<am>n</am></abbr><ex>os</ex></expan> LXV <lb n="5"/><expan><abbr>h</abbr><ex>ic</ex></expan> <expan><abbr>s</abbr><ex>itus</ex></expan> <expan><abbr>e</abbr><ex>st</ex></expan> <lb n="6"/><expan><abbr>Cl</abbr><ex>audia</ex></expan> Tuta uxor <lb n="7"/>et <expan><abbr>Cl</abbr><ex>audius</ex></expan> Crispus et <lb n="8"/><expan><abbr>Cl</abbr><ex>audia</ex></expan> Vera <expan><abbr>fili</abbr><ex>i</ex></expan> <lb n="9"/><expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uraverunt</ex></expan>
