                <supplied reason="lost">I</supplied>n <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> Marti <lb n="2"/>et Ancamnae <lb n="3"/><expan><abbr>C</abbr><ex>aius</ex></expan> Serotinius <lb n="4"/>Iustus ex voto <lb n="5"/>posuit
