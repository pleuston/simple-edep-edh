                <gap reason="lost" quantity="1" unit="line"/>tis Marcelli <expan><abbr>v</abbr><ex>iri</ex></expan> <expan><abbr>s</abbr><ex>pectabilis</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="0"/> D<gap reason="lost" quantity="1" unit="line"/>
