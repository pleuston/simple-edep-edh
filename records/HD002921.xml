            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>erator</ex></expan> <expan><abbr>Caes</abbr><ex>ar</ex></expan> <expan><abbr>L</abbr><ex>ucius</ex></expan> <expan><abbr>Sept</abbr><ex>imius</ex></expan> Severus Pius <lb n="2"/><expan><abbr>Pert</abbr><ex>inax</ex></expan> <expan><abbr>Aug</abbr><ex>ustus</ex></expan> <expan><abbr>Arab</abbr><ex>icus</ex></expan> <expan><abbr>Adiab</abbr><ex>enicus</ex></expan> <expan><abbr>Part</abbr><ex>hicus</ex></expan> <expan><abbr>max</abbr><ex>imus</ex></expan> <lb n="3"/><expan><abbr>pont</abbr><ex>ifex</ex></expan> <expan><abbr>max</abbr><ex>imus</ex></expan> <expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> et <expan><abbr>Imp</abbr><ex>erator</ex></expan> <expan><abbr>Caes</abbr><ex>ar</ex></expan> <expan><abbr>M</abbr><ex>arcus</ex></expan> Aure<lb break="no" n="4"/>lius Antoninus Pius <expan><abbr>Aug</abbr><ex>ustus</ex></expan> <expan><abbr>Arab</abbr><ex>icus</ex></expan> <lb n="5"/><expan><abbr>Adiab</abbr><ex>enicus</ex></expan> <expan><abbr>Part</abbr><ex>hicus</ex></expan> <expan><abbr>max</abbr><ex>imus</ex></expan> <expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <del rend="erasure">et <expan><abbr>P</abbr><ex>ublius</ex></expan> <expan><abbr>Sept</abbr><ex>imius</ex></expan> Geta</del> <lb n="6"/><del rend="erasure">[<gap reason="lost" extent="unknown" unit="character"/></del>] castellanis Thude<lb break="no" n="7"/>densibus fines et immunitatem <lb n="8"/>a rege Iuba per <expan><abbr>confirmatione</abbr><ex cert="low"/></expan> <lb n="9"/>divi <expan><abbr>Aug</abbr><ex>usti</ex></expan> concessos post <lb n="10"/><supplied reason="lost">m</supplied>ultis maximisque saecu<lb break="no" n="11"/>lis felicissimis temporibus <lb n="12"/>suis divino iudicio restituerunt <lb n="13"/>Thude<expan><ex>de</ex><abbr>nses</abbr></expan> determinatione s<expan><ex>a</ex><abbr>e</abbr></expan><lb break="no" n="14"/>culi terminos posuerunt <lb n="15"/>et