                <expan><abbr><supplied reason="lost">I</supplied>mp</abbr><ex>eratori</ex></expan> <expan><abbr>Caes</abbr><ex>ari</ex></expan> divi Traiani Par<lb break="no" n="2"/>thici <expan><abbr>fil</abbr><ex>io</ex></expan> divi Nervae nepo<lb break="no" n="3"/>ti Traiano Hadriano <expan><abbr>Aug</abbr><ex>usto</ex></expan> <lb n="4"/><supplied reason="lost"><expan><abbr>p</abbr><ex>ontifici</ex></expan></supplied> <expan><abbr>m</abbr><ex>aximo</ex></expan> <expan><abbr>tr</abbr><ex>ibunicia</ex></expan> <expan><abbr>pot</abbr><ex>estate</ex></expan> XVI co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> III <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <lb n="5"/>Olympio <lb n="6"/>colonia Iulia Augusta <lb n="7"/>Diensium per legatum <lb n="8"/><expan><abbr>G</abbr><ex>aium</ex></expan> Memmium Lycum <lb n="9"/>Διεστῶν
