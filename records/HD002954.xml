                <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar divi Traiani Par<lb break="no" n="2"/>thici <expan><abbr>fil</abbr><ex>ius</ex></expan> divi Nervae nepos <lb n="3"/>Traianus Hadrianus Au<supplied reason="lost"><expan><abbr>g</abbr><ex>ustus</ex></expan></supplied> <lb n="4"/>pontifex <expan><abbr>max</abbr><ex>imus</ex></expan> <expan><abbr>trib</abbr><ex>unicia</ex></expan> <expan><abbr>pot</abbr><ex>estate</ex></expan> III <supplied reason="lost"><expan><abbr>co</abbr><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan></supplied> <lb n="5"/>III praesidium Sufative per <expan><abbr>coh</abbr><ex>ortem</ex></expan> <lb n="6"/>I <expan><abbr>Flavia</abbr><ex>m</ex></expan> Musulamiorum factum <lb n="7"/>sub cura <expan><abbr>L</abbr><ex>uci</ex></expan> Sei Aviti <expan><abbr>proc</abbr><ex>uratoris</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan>
            </ab></div>
