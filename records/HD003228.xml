                Voto <supplied reason="lost">s</supplied>uscepto <lb n="2"/><supplied reason="lost">p</supplied>ro salute et reditu et <lb n="3"/>victoria Britanni<lb break="no" n="4"/>ca <expan><abbr>Ti</abbr><ex>beri</ex></expan> Claudi Caesa<lb break="no" n="5"/>ris <expan><abbr>Aug</abbr><ex>usti</ex></expan> Germanici <lb n="6"/><expan><abbr>pont</abbr><ex>ificis</ex></expan> <expan><abbr>max</abbr><ex>imi</ex></expan> <expan><abbr>tr</abbr><ex>ibunicia</ex></expan> <expan><abbr>pot</abbr><ex>estate</ex></expan> V <expan><abbr>imp</abbr><ex>eratoris</ex></expan> <lb n="7"/>X <expan><abbr>p</abbr><ex>atris</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> co<expan><ex>n</ex><abbr>s</abbr><ex>ulis</ex></expan> <expan><abbr>des</abbr><ex>ignati</ex></expan> IIII <lb n="8"/><expan><abbr>A</abbr><ex>ulus</ex></expan> Vicirius Proculus <lb n="9"/>flamen <expan><abbr>Aug</abbr><ex>ustalis</ex></expan> <expan><abbr>tr</abbr><ex>ibunus</ex></expan> <expan><abbr>mil</abbr><ex>itum</ex></expan> <lb n="10"/>Victoriae Britanni<lb break="no" n="11"/>cae votum solvit
