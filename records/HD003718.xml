            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Quomodo hoc <expan><abbr>plumbu</abbr><ex>m</ex></expan> non <lb n="2"/>paret et decadet sic deca<lb break="no" n="3"/>dat aetas membra vita <lb n="4"/>bos grano mer <expan><abbr>eoru</abbr><ex>m</ex></expan> qui <lb n="5"/>mihi dolum <expan><abbr>malu</abbr><ex>m</ex></expan> fecerunt <lb n="6"/>idem Asuetemeos <lb n="7"/>Secundina qu<expan><ex>a</ex><abbr>e</abbr></expan> illum tulit <lb n="8"/>et Verres Tearus </ab></div><div n="2" type="textpart"><ab><lb n="1"/> et Amarantis et <lb n="2"/>hoc omnia vobis Dii <lb n="3"/>interdico in omni<lb break="no" n="4"/>bus sortebus <note>sic</note> tam celebrare <lb n="5"/>Masitlatida concinere Necra<lb break="no" n="6"/>cantum Col<gap reason="lost" extent="unknown" unit="character"/>scantum et <lb n="7"/>omnes deos <gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="8"/>ta datus <gap reason="lost" extent="unknown" unit="character"/>
            </ab></div></div>
