                Flacceia <expan><abbr>A</abbr><ex>uli</ex></expan> <expan><abbr>l</abbr><ex>iberta</ex></expan> Lais <lb n="2"/>Orbia |(mulieris) <expan><abbr>l</abbr><ex>iberta</ex></expan> Lais <lb n="3"/>Cominia <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>l</abbr><ex>iberta</ex></expan> Philocaris <lb n="4"/>Venturia <expan><abbr>Q</abbr><ex>uinti</ex></expan> <expan><abbr>l</abbr><ex>iberta</ex></expan> Thais <lb n="5"/>culinam Veneri de suo <lb n="6"/>fecerunt loco <lb n="7"/>precario
