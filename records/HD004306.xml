                <expan><abbr>C</abbr><ex>aius</ex></expan> Valerius <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <expan><abbr>Quir</abbr><ex>ina</ex></expan> Valens <expan><abbr>Cam</abbr><ex>unnus</ex></expan> <lb n="2"/><expan><abbr>mil</abbr><ex>es</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> VIII <expan><abbr>Aug</abbr><ex>ustae</ex></expan> <expan><abbr><am><g type="centuria"/></am></abbr><ex>centuria</ex></expan> <expan><abbr>Senuci</abbr><ex>onis</ex></expan> <expan><abbr>vix</abbr><ex>it</ex></expan> a<supplied reason="lost"><expan><abbr>n</abbr><ex>nos</ex></expan></supplied> <lb n="3"/>XXXV <expan><abbr>mil</abbr><ex>itavit</ex></expan> <expan><abbr>an</abbr><ex>nos</ex></expan> XIIII <expan><abbr>her</abbr><ex>es</ex></expan> ex testamento
