                <supplied reason="lost">Ap</supplied>ollini <expan><abbr>Aug</abbr><ex>usto</ex></expan> <lb n="2"/><expan><abbr>sanct</abbr><ex>o</ex></expan> <expan><abbr>cons</abbr><ex>ervatori</ex></expan> sacrum <lb n="3"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Scandilius <lb n="4"/>Fabatus <expan><abbr>praef</abbr><ex>ectus</ex></expan> <lb n="5"/>equitum alae <lb n="6"/>Aurianae <lb n="7"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
