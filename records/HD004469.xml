                <expan><abbr>C</abbr><ex>aius</ex></expan> <expan><abbr>Semproni</abbr><ex>us</ex></expan> <expan><abbr>Ti</abbr><ex>beri</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <lb n="2"/><expan><abbr>Ap</abbr><ex>pius</ex></expan> <expan><abbr>Claudi</abbr><ex>us</ex></expan> <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <lb n="3"/><expan><abbr>P</abbr><ex>ublius</ex></expan> <expan><abbr>Licini</abbr><ex>us</ex></expan> <expan><abbr>P</abbr><ex>ubli</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>k</abbr><ex>ardo</ex></expan> XII<supplied reason="lost" cert="low">I</supplied> </ab></div><div n="3" type="textpart"><ab><lb n="1"/> <expan><abbr>d</abbr><ex>ecumanus</ex></expan>
