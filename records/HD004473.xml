                <supplied reason="lost"><expan><abbr>Imp</abbr><ex>eratori</ex></expan> <expan><abbr>Caes</abbr><ex>ari</ex></expan></supplied> Divi <expan><abbr>f</abbr><ex>ilio</ex></expan> Augusto <expan><abbr>pont</abbr><ex>ifici</ex></expan> ma<supplied reason="lost"><expan><abbr>x</abbr><ex>imo</ex></expan></supplied> <lb n="2"/><expan><abbr>Q</abbr><ex>uintus</ex></expan> Lucretius Eros <lb n="3"/>Murdianus </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>L</abbr><ex>ucius</ex></expan> Volumnius <lb n="2"/>Eros </ab></div><div n="3" type="textpart"><ab><lb n="1"/> <expan><abbr>mag</abbr><ex>istri</ex></expan> <expan><abbr>Aug</abbr><ex>ustales</ex></expan>
