                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Ulpiae Aureliae Va<lb break="no" n="3"/>leriae virgini dextra<lb break="no" n="4"/>t<expan><ex>a</ex><abbr>e</abbr></expan> annis III mensibus <lb n="5"/>VIIII <expan><abbr>d</abbr><ex>iebus</ex></expan> XVII filiae Aure<lb break="no" n="6"/>li Herculani <expan><abbr>v</abbr><ex>iri</ex></expan> <expan><abbr>e</abbr><ex>gregii</ex></expan> duce<lb break="no" n="7"/>nari qui vixit annis <lb n="8"/>XLII <expan><abbr>mens</abbr><ex>ibus</ex></expan> VIII <expan><abbr>d</abbr><ex>iebus</ex></expan> XVI <lb n="9"/>nepotiae pientissi<lb break="no" n="10"/>m<expan><ex>a</ex><abbr>e</abbr></expan> <expan><abbr>Ulp</abbr><ex>ius</ex></expan> Valerius Au<lb break="no" n="11"/>relianus <expan><abbr>v</abbr><ex>ir</ex></expan> <expan><abbr>e</abbr><ex>gregius</ex></expan> cente<lb break="no" n="12"/>narius et Titinia <lb n="13"/>Mansueta stola<lb break="no" n="14"/>ta femina viator <lb n="15"/>resiste et lege nihil ul<lb break="no" n="16"/>tra crudelius <expan><abbr>h</abbr><ex cert="low">oc</ex></expan> <expan><abbr>m</abbr><ex cert="low">onumento</ex></expan> <expan><abbr>c</abbr><ex cert="low">ernere</ex></expan> <expan><abbr>po</abbr><ex cert="low">tes</ex></expan>
