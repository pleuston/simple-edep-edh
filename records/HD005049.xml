            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Genio <expan><abbr>leg</abbr><ex>ionis</ex></expan> II <expan><abbr>Parth</abbr><ex>icae</ex></expan> Gordianae et Fortunae Reduci <lb n="2"/>Paciferae conservatoribus <expan><abbr>d</abbr><ex>omini</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan> <lb n="3"/><expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> Antoni Gordiani Pii Felicis Invicti <expan><abbr>Aug</abbr><ex>usti</ex></expan> et <lb n="4"/>Sabiniae Tranquillinae <expan><abbr>Aug</abbr><ex>ustae</ex></expan> <expan><abbr>coniugi</abbr><ex>s</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan> <lb n="5"/>milites <expan><abbr>leg</abbr><ex>ionis</ex></expan> II <expan><abbr>Parth</abbr><ex>icae</ex></expan> Gordianae <expan><abbr>p</abbr><ex>iae</ex></expan> <expan><abbr>f</abbr><ex>elicis</ex></expan> <expan><abbr>f</abbr><ex>idelis</ex></expan> aeternae <lb n="6"/>qui militare coeperunt Sabino II et Anullino co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> <lb n="7"/>quorum nomina cum tribus et patrias <note>sic</note> duobus tabulis aereis <lb n="8"/>incisa continentur devoti numini maiestatique eorum <lb n="9"/>sub cura Valeri Valentis <expan><abbr>v</abbr><ex>iri</ex></expan> <expan><abbr>p</abbr><ex>erfectissimi</ex></expan> vice <expan><abbr>praef</abbr><ex>ecti</ex></expan> <expan><abbr>praet</abbr><ex>orio</ex></expan> agentis <lb n="10"/>et Pomponi Iuliani <expan><abbr>p</abbr><ex>rimi</ex></expan> <expan><abbr>p</abbr><ex>ili</ex></expan> <expan><abbr>praep</abbr><ex>ositi</ex></expan> reliquationis <lb n="11"/><expan><abbr>dedic</abbr><ex>averunt</ex></expan> VIIII <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Aug</abbr><ex>ustas</ex></expan> Attico et Praetextato <supplied reason="lost"><expan><abbr>vv</abbr><ex>iris</ex></expan> <expan><abbr>cc</abbr><ex>larissimis</ex></expan> <expan><abbr>co</abbr><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan></supplied>
            </ab></div>
