                <expan><abbr>Victu</abbr><ex>riae</ex></expan> <note>sic</note> <lb n="2"/><expan><abbr>Vatern</abbr><ex>ius</ex></expan> <lb n="3"/>Cas<expan><ex>s</ex><abbr>ian</abbr><ex>us</ex></expan> <lb n="4"/><expan><abbr>eq</abbr><ex>ues</ex></expan> <expan><abbr>t</abbr><ex>urmae</ex></expan> <abbr>E</abbr> <lb n="5"/>&amp;lt;v=N&amp;gt;(otum<certainty match="preceding-sibling::node()" locus="value"/> <expan><abbr>s</abbr><ex cert="low">olvit</ex></expan> 
