                <expan><abbr>L</abbr><ex>ucius</ex></expan> Pituanius Eros <lb n="2"/><expan><abbr>scr</abbr><ex>iba</ex></expan> <expan><abbr>libr</abbr><ex>arius</ex></expan> <expan><abbr>aedil</abbr><ex>ium</ex></expan> et <lb n="3"/>Pituania Helpis <expan><abbr>fecer</abbr><ex>unt</ex></expan> <lb n="4"/>Pituaniae Heuresidi <expan><abbr>f</abbr><ex>iliae</ex></expan> <expan><abbr>v</abbr><ex>ixit</ex></expan> <expan><abbr>a</abbr><ex>nnos</ex></expan> XV <expan><abbr>m</abbr><ex>enses</ex></expan> IX <expan><abbr>d</abbr><ex>ies</ex></expan> III <expan><abbr>h</abbr><ex>oras</ex></expan> VI <lb n="5"/>Pituaniae Isiadi filiae vixit <lb n="6"/><expan><abbr>n<am>n</am></abbr><ex>os</ex></expan> VI <expan><abbr>mens</abbr><ex>es</ex></expan> V dies IV <expan><abbr>hor</abbr><ex>as</ex></expan> IX et sibi et <lb n="7"/>libertis <expan><abbr>libertabusq</abbr><ex>ue</ex></expan> suis posterisque eorum
