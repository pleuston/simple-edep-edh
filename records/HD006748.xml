                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Vettia Prisca po<lb break="no" n="3"/>suit Cassi<expan><ex>a</ex><abbr>e</abbr></expan> Priscil<lb break="no" n="4"/>l<expan><ex>a</ex><abbr>e</abbr></expan> fili<expan><ex>a</ex><abbr>e</abbr></expan> <expan><abbr>dulcissima</abbr><ex>e</ex></expan> <lb n="5"/>et Octavius Iustus <lb n="6"/>pater qu<expan><ex>a</ex><abbr>e</abbr></expan> vixit an<lb break="no" n="7"/>nis XVIIII mensis <note>sic</note> <lb n="8"/>VIIII dies <note>sic</note> II
