                Vibe <note>sic</note> <expan><abbr>s</abbr><ex>acrum</ex></expan> <lb n="2"/>Mos<expan><ex>i</ex><abbr>qu</abbr></expan> <note>sic</note> <lb n="3"/>Qupiti <note>sic</note> <lb n="4"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
