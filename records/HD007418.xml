                In hoc loco positus est <expan><abbr>Fl</abbr><ex>avius</ex></expan> Gaian<supplied reason="lost">us ex</supplied> <lb n="2"/>praesidibus qui vixit annis <expan><abbr>n</abbr><ex>umero</ex></expan> <gap reason="lost" extent="unknown" unit="character"/> defunctus <lb n="3"/>est autem Rufino e<supplied reason="lost">t Eusebio</supplied> <lb n="4"/><expan><abbr>conss</abbr><ex>ulibus</ex></expan> die VIIII <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Mart</abbr><ex>ias</ex></expan> depositus <supplied reason="lost">est</supplied> <lb n="5"/>VIII <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Mart</abbr><ex>ias</ex></expan> in pace
            </ab></div>
