                <supplied reason="lost">Nutricibus</supplied> <expan><abbr>Aug</abbr><ex>ustis</ex></expan> Aelia Vera <lb n="2"/><supplied reason="lost">pro<certainty locus="name" match="preceding-sibling::text()" cert="low"/> salute<certainty locus="name" match="preceding-sibling::text()" cert="low"/> <gap reason="lost" extent="unknown" unit="character"/></supplied><abbr>iar</abbr> Antoniae <expan><abbr>f</abbr><ex>iliae</ex></expan><certainty match="preceding-sibling::node()" locus="value"/> <lb n="3"/><gap reason="lost" extent="unknown" unit="character"/>ni fili <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
