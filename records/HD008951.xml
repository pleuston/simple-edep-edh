            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Biccus dat M<lb break="no" n="2"/>ercurio quidquid <lb n="3"/>pe<expan><ex>r</ex><abbr>d</abbr><ex>id</ex><abbr>it</abbr></expan> si vir si m<lb break="no" n="4"/>ascet ne meiat <note>sic</note> <lb n="5"/>ne cacet ne loqua<lb break="no" n="6"/>tur ne dormiat <lb n="7"/>n<supplied reason="lost">e</supplied> vigilet nec s<supplied reason="lost">a</supplied><lb break="no" n="8"/><supplied reason="lost">l</supplied>utem nec sa<lb break="no" n="9"/>nitatem ne<lb break="no" n="10"/>ss<supplied reason="lost">i</supplied> <note>sic</note> in templo <lb n="11"/>Mercurii per<lb break="no" n="12"/>tulerit ne <expan><abbr>co</abbr><ex>n</ex></expan><lb break="no" n="13"/>scientiam de <lb n="14"/>perferat <note>sic</note> ness<supplied reason="lost">i</supplied> <note>sic</note> <lb n="15"/>me interceden<lb break="no" n="16"/>te
            </ab></div>
