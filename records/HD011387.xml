            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost">Deo So</supplied>li Elagab<lb break="no" n="2"/><supplied reason="lost">alo sac</supplied><expan><abbr>r</abbr><ex>um</ex></expan> pro salu<lb break="no" n="3"/><supplied reason="lost">te domin</supplied>orum <expan><abbr>n<am>n</am></abbr><ex>ostrorum</ex></expan> <lb n="4"/><supplied reason="lost"><expan><abbr>L</abbr><ex>uci</ex></expan> Septimi</supplied> Severi Pii <lb n="5"/><supplied reason="lost">Pertinaci</supplied>s et <expan><abbr>Mar</abbr><ex>ci</ex></expan> <expan><abbr>Aur</abbr><ex>eli</ex></expan> Anto<lb break="no" n="6"/><supplied reason="lost">nini <expan><abbr>Augg</abbr><ex>ustorum</ex></expan> [et <expan><abbr>Sept</abbr><ex>imi</ex></expan> Getae</supplied>] <lb n="7"/><supplied reason="lost">[<expan><abbr>Caes</abbr><ex>aris</ex></expan></supplied> mil]ites <expan><abbr>cohort</abbr><ex>is</ex></expan> I <lb n="8"/><supplied reason="lost">|(miliariae) <expan><abbr>Antonin</abbr><ex>ae</ex></expan></supplied> Hemesenorum <lb n="9"/><supplied reason="lost">adiectis oper</supplied>ibus ut Clau<lb break="no" n="10"/><supplied reason="lost">di Claudian</supplied>i pr<expan><ex>a</ex><abbr>esidis</abbr></expan> <lb n="11"/><supplied reason="lost">cura voverant i</supplied>ussu eius tem<lb break="no" n="12"/><supplied reason="lost">plum a funda</supplied>mentis inpe<lb break="no" n="13"/><supplied reason="lost">nsa sua extruxs</supplied>erunt
            </ab></div>
            <div type="commentary">
