                In <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> <lb n="2"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Martian<lb break="no" n="3"/>nius Pulch<lb break="no" n="4"/>er <expan><abbr>v</abbr><ex>ir</ex></expan> <expan><abbr>c</abbr><ex>larissimus</ex></expan><certainty match="preceding-sibling::node()" locus="value"/> <expan><abbr>leg</abbr><ex>atus</ex></expan> <lb n="5"/><expan><abbr>Aug<am>g</am></abbr><ex>ustorum</ex></expan> pro <lb n="6"/><expan><abbr>praet</abbr><ex>ore</ex></expan> templ<expan><ex>u</ex><abbr>m</abbr></expan> <lb n="7"/>Isidis c<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="8"/>tis vetustate <lb n="9"/>collabsum <note>sic</note> <lb n="10"/>restitui prae<lb break="no" n="11"/>cepit
