            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Ti</abbr><ex>berius</ex></expan> Claudius <lb n="2"/>Maximus <expan><abbr>vet</abbr><ex>eranus</ex></expan> <lb n="3"/><supplied reason="lost"><expan><abbr>s</abbr><ex>e</ex></expan></supplied> <expan><abbr>v</abbr><ex>ivo</ex></expan> <expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uravit</ex></expan> militavit <lb n="4"/><expan><abbr>eque</abbr><ex>s</ex></expan> in <expan><abbr>leg</abbr><ex>ione</ex></expan> VII <expan><abbr>C</abbr><ex>laudia</ex></expan> <expan><abbr>p</abbr><ex>ia</ex></expan> <expan><abbr>f</abbr><ex>ideli</ex></expan> fac<lb break="no" n="5"/>tus qu<expan><ex>a</ex><abbr>estor</abbr></expan> <expan><abbr>equit</abbr><ex>um</ex></expan> <lb n="6"/>singularis legati le<lb break="no" n="7"/>gionis eiusdem vexil<lb break="no" n="8"/>larius equitum item <lb n="9"/>bello Dacico ob virtu<lb break="no" n="10"/><expan><abbr>te</abbr><ex>m</ex></expan> donis donatus ab Im<lb break="no" n="11"/><expan><abbr>p</abbr><ex>eratore</ex></expan> Domitiano factus <expan><abbr>dupli</abbr><ex>carius</ex></expan> <lb n="12"/>a divo Troiano <note>sic</note> in ala <expan><abbr>secu</abbr><ex>nda</ex></expan> <lb n="13"/>Pannoniorum a quo et <expan><abbr>fa</abbr><ex>c</ex></expan><lb break="no" n="14"/>tus explorator in bello Da<lb break="no" n="15"/>cico et ob <expan><abbr>virtute</abbr><ex>m</ex></expan> bis donis <lb n="16"/>donatus bello Dacico et <lb n="17"/>Parthico et ab <expan><abbr>eode</abbr><ex>m</ex></expan> factus <lb n="18"/>decurio in ala <expan><abbr>eade</abbr><ex>m</ex></expan> quod <lb n="19"/>cepisset <expan><abbr>Decebalu</abbr><ex>m</ex></expan> et caput <lb n="20"/>eius pertulisset ei Ranissto<lb break="no" n="21"/>ro missus voluntarius ho<lb break="no" n="22"/>nesta missione a Terent<supplied reason="lost">io Scau</supplied><lb break="no" n="23"/>riano consulare <note>sic</note> <supplied reason="lost">exerci</supplied><lb break="no" n="24"/>tus provinciae nov<supplied reason="lost" cert="low">ae Daciae</supplied> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/><certainty match="preceding-sibling::node()" locus="value"/>
