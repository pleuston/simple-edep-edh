                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>I</abbr><ex>nferis</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Biracillo <lb n="3"/>Veri <expan><abbr>fil</abbr><ex>io</ex></expan>
