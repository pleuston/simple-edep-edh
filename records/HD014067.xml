            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <expan><abbr>s</abbr><ex>acrum</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Terentius Dionysius <lb n="2"/>sibi vibus et suis posuit </ab></div><div n="3" type="textpart"><ab><lb n="1"/> <expan><abbr>P</abbr><ex>ublio</ex></expan> Terentio <lb n="2"/>Apro <expan><abbr>q</abbr><ex>ui</ex></expan> <expan><abbr>vix</abbr><ex>it</ex></expan> <lb n="3"/><expan><abbr>n<am>n</am></abbr><ex>os</ex></expan> XXXV <lb n="4"/>Terentia Chry<lb break="no" n="5"/>sopolis mater <lb n="6"/>inf<supplied reason="lost">e</supplied>licissima <lb n="7"/>et <expan><abbr>P</abbr><ex>ublio</ex></expan> Ce<surplus>te</surplus>tranio <supplied reason="lost">Eu</supplied><lb break="no" n="8"/>tycho <expan><abbr>marit</abbr><ex>o</ex></expan> <expan><abbr>viv</abbr><ex>o</ex></expan> <expan><abbr>v</abbr><ex>iva</ex></expan> <expan><abbr>p</abbr><ex>osuit</ex></expan> <lb n="9"/>in <expan><abbr>front</abbr><ex>e</ex></expan> <expan><abbr>p</abbr><ex>edes</ex></expan> XV in <expan><abbr>agr</abbr><ex>o</ex></expan> <expan><abbr>p</abbr><ex>edes</ex></expan> XV
