                <expan><abbr>M</abbr><ex>atronis</ex></expan> Vacalline<lb break="no" n="2"/>his Leubasn<lb break="no" n="3"/>ius Exomni <lb n="4"/>pro se et sui<lb break="no" n="5"/>s <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
