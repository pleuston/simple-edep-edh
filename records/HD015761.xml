            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                En perfecta cito <expan><abbr>baiaru</abbr><ex>m</ex></expan> grata voluptas <lb n="2"/>undantesque fluunt <expan><abbr>aq</abbr><ex>uae</ex></expan> saxi de rupe sub ima <lb n="3"/>nisibus hic nostris prostratus libor <note>sic</note> anhelat <lb n="4"/>quisquis amat fratrum veniat <expan><abbr>mecumq</abbr><ex>ue</ex></expan> laetetur
            </ab></div>
