            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Termini positi inter <lb n="2"/>Igilgilitanos in <lb n="3"/>quorum finibus kas<lb break="no" n="4"/>tellum Victoriae <lb n="5"/>positum est et <expan><abbr>Zimiz</abbr><ex>es</ex></expan> <lb n="6"/>ut sciant Zimizes <lb n="7"/>non plus in usum <lb n="8"/>se <expan><abbr>haber</abbr><ex>e</ex></expan> ex aucto<lb break="no" n="9"/>ritate <expan><abbr>M</abbr><ex>arci</ex></expan> Vetti La<lb break="no" n="10"/>tronis <expan><abbr>proc</abbr><ex>uratoris</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <lb n="11"/>qua in circuitu <lb n="12"/>a muro <expan><abbr>kast</abbr><ex>elli</ex></expan> <expan><abbr>p</abbr><ex>assus</ex></expan> <lb n="13"/>D <expan><abbr>pr</abbr><ex>ovinciae</ex></expan> LXXXIX Tor<lb break="no" n="14"/>quato et Libone co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan>
            </ab></div>
