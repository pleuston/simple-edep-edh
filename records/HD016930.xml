            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Sex</abbr><ex>tus</ex></expan> Curvius Silvinus <expan><abbr>q</abbr><ex>uaestor</ex></expan> pro <lb n="2"/><expan><abbr>pr</abbr><ex>aetore</ex></expan> hospitium fecit cum senatu <lb n="3"/>populoque Muniguensi Hispaniae <lb n="4"/>ulterioris eosque liberos posteros<lb break="no" n="5"/>que eorum in fidem clientelamque <lb n="6"/>suam liberorum posterorumque <lb n="7"/>suorum recepit <lb n="8"/>egerunt <lb n="9"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Lucceius <expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <expan><abbr>mag</abbr><ex>istratus</ex></expan> <lb n="10"/><expan><abbr>leg</abbr><ex>atus</ex></expan> <lb n="11"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Octavius <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> Silvanus
            </ab></div>
