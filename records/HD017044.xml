                <supplied reason="lost"><expan><abbr>C</abbr><ex>aio</ex></expan></supplied> <expan><ex>H</ex><abbr>erennio</abbr></expan> Maxim<supplied reason="lost">o</supplied> <lb n="2"/>veterano <expan><abbr>leg</abbr><ex>ionis</ex></expan> V <lb n="3"/>Macedonicae <lb n="4"/><supplied reason="lost">s</supplied>acerdoti Ca<supplied reason="lost">e</supplied><lb break="no" n="5"/><supplied reason="lost">s</supplied>aris civitas <supplied reason="lost">Sy</supplied><lb break="no" n="6"/>ed<supplied reason="lost">r</supplied>en<supplied reason="lost">s</supplied>ium <expan><abbr>h</abbr><ex>onoris</ex></expan> <expan><abbr>c</abbr><ex>ausa</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Γ(αΐῳ) Ἑρεννίῳ Μαξίμ<supplied reason="lost">ῳ</supplied> <lb n="2"/>ἐντείμως ἀ<supplied reason="lost">πολε</supplied><lb break="no" n="3"/>λυμένῳ λεγι<supplied reason="lost">ῶνος</supplied> <lb n="4"/>εʹ Μακεδονικῆς <supplied reason="lost">ἀρ</supplied><lb break="no" n="5"/>χιερ<supplied reason="lost">ε</supplied>ῖ Καίσαρ<supplied reason="lost">ος Συε</supplied><lb break="no" n="6"/>δ<supplied reason="lost">ρέων ἡ πόλις τειμῆς</supplied> <lb n="7"/>ἕν<supplied reason="lost">εκεν</supplied>
            </ab></div></div>
