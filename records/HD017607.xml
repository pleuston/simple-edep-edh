        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Chrauttius Veldeio suo fratri <lb n="2"/>contubernali antiquo pluri<lb break="no" n="3"/>mam salutem <lb n="4"/>et rogo te Veldei frater miror <lb n="5"/>quod mihi tot tempus nihil <lb n="6"/>rescripsti a parentibus nos<lb break="no" n="7"/>tris si quid audieris aut <lb n="8"/>QVOT M in quo numero <lb n="9"/>sit et illum a me salutabis<lb break="no" n="10"/>s <note>sic</note> verbis meis et Virilem <lb n="11"/>veterinarium rogabis <lb n="12"/>illum ut forficem <lb n="13"/> <lb n="14"/>quam mihi promisit pretio <lb n="15"/>mittas per aliquem de nostris <lb n="16"/>et rogo te frater Virilis <lb n="17"/>salutes a me Thuttenam <lb n="18"/>sororem Velbuteium <lb n="19"/>rescribas nobis cum <gap reason="lost" extent="unknown" unit="character"/> <lb n="20"/>se habeat <lb n="21"/>opto sis felicissimus <lb n="22"/>vale </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Londini <lb n="2"/>Veldedeio <lb n="3"/>equisioni co<expan><ex>n</ex><abbr>s</abbr><ex>ularis</ex></expan> <lb n="4"/>a Chrauttio <lb n="5"/>fratre
            </ab></div></div>
