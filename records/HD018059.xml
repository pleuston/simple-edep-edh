            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Iuliae <expan><abbr>Aug</abbr><ex>ustae</ex></expan> matri <lb n="2"/><supplied reason="lost">ca</supplied>strorum <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <lb n="3"/><supplied reason="lost"><expan><abbr>L</abbr><ex>uci</ex></expan> Sept</supplied>imi Severi Pii Perti<lb break="no" n="4"/><supplied reason="lost">naci</supplied>s <expan><abbr>Aug</abbr><ex>usti</ex></expan> Arabici Adiabe<lb break="no" n="5"/><supplied reason="lost">nici</supplied> Parthici maximi <lb n="6"/><supplied reason="lost">fort</supplied>issimi felicissimi <expan><abbr>p</abbr><ex>atris</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> et <lb n="7"/><expan><abbr><supplied reason="lost">Im</supplied>p</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> Aureli Antonini <lb n="8"/><expan><abbr>Aug</abbr><ex>usti</ex></expan> <del rend="erasure">Parthici Bri</del><lb break="no" n="9"/><del rend="erasure"><expan><abbr>tan</abbr><ex>n</ex>ici</expan> <expan><abbr>max</abbr><ex>imi</ex></expan></del> matri <lb n="10"/>Capenates foederati <lb n="11"/><supplied reason="lost" cert="low">c(ura)</supplied> Manili Crescentis <expan><abbr>praet</abbr><ex>oris</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>Dedic</abbr><ex>ata</ex></expan> XIIII <expan><abbr>K</abbr><ex>alendas</ex></expan> <expan><abbr>Oct</abbr><ex>obres</ex></expan> <lb n="2"/>Saturnino et Gallo co<expan><ex>n</ex><abbr>ss</abbr><ex>ulibus</ex></expan>
            </ab></div></div>
            <div type="commentary">
                <p>Z. 8/9: Unter der Eradierung stand ursprünglich: et P(ubli) Septimi Getae / nobilissimi Caes(aris).</p>
