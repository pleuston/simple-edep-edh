            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <expan><abbr>M</abbr><ex>arco</ex></expan> Gellio Servando <lb n="2"/>Seniori seviro <expan><abbr>August</abbr><ex>ali</ex></expan> <lb n="3"/>municipio <expan><abbr>Capene</abbr><ex>atium</ex></expan> <note>sic</note> <expan><abbr>foederato</abbr><ex>rum</ex></expan> <lb n="4"/>ludos edenti ob merita <lb n="5"/>eius collatione facta decurionum <lb n="6"/>et Augustalium item vicanorum <lb n="7"/>hoc <note>sic</note> honorem sibi oblatum HS V <expan><abbr>m</abbr><ex>ilia</ex></expan> <expan><abbr>n</abbr><ex>ummum</ex></expan> <lb n="8"/>in aerarium <expan><abbr>r</abbr><ex>ei</ex></expan> <expan><abbr>p</abbr><ex>ublicae</ex></expan> <expan><abbr>C</abbr><ex>apenatium</ex></expan> <expan><abbr>f</abbr><ex>oederatorum</ex></expan> contulit ut ex eo die na<lb break="no" n="9"/>tali sui V <expan><abbr>K</abbr><ex>alendas</ex></expan> <expan><abbr>Apr</abbr><ex>iles</ex></expan> de |(denariis) LXXV usur<expan><ex>a</ex><abbr>e</abbr></expan> decurio<lb break="no" n="10"/>nibus et <expan><abbr>August</abbr><ex>alibus</ex></expan> et vicanis dividatur prae<lb break="no" n="11"/>sentibus et ex ea divisione iubeo statuae <lb n="12"/>meae coronas emi |(denariis) III <expan><abbr>l</abbr><ex>oco</ex></expan> <expan><abbr>d</abbr><ex>ato</ex></expan> ex <expan><abbr>d</abbr><ex>ecreto</ex></expan> <expan><abbr>d</abbr><ex>ecurionum</ex></expan> <lb n="13"/>curantibus <expan><abbr>C</abbr><ex>aio</ex></expan> Naevio Proculo et <expan><abbr>M</abbr><ex>arco</ex></expan> Gellio <lb n="14"/>Servando <expan><abbr>Iun</abbr><ex>iore</ex></expan> et Vatinio Prisco scriba <expan><abbr>p</abbr><ex>ublico</ex></expan> <expan><abbr>r</abbr><ex>ei</ex></expan> <expan><abbr>p</abbr><ex>ublicae</ex></expan> <expan><abbr>C</abbr><ex>apenatium</ex></expan> <expan><abbr>f</abbr><ex>oederatorum</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>Dedic</abbr><ex>ata</ex></expan> est III <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Decembr</abbr><ex>es</ex></expan> <lb n="2"/>Maximo et Orfito co<expan><ex>n</ex><abbr>ss</abbr><ex>ulibus</ex></expan>
            </ab></div></div>
