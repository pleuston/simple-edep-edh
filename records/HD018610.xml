                Dian<expan><ex>a</ex><abbr>e</abbr></expan> <lb n="2"/>Dometi<lb break="no" n="3"/>us <note>sic</note> <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
