            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Imperato<supplied reason="lost">ribus Caesaribus</supplied> <lb n="2"/><expan><abbr>M</abbr><ex>arco</ex></expan> Aurelio An<supplied reason="lost">tonino <expan><abbr>Aug</abbr><ex>usto</ex></expan> tribuniciae</supplied> <lb n="3"/>potestati<supplied reason="lost">s XVII</supplied> co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> <supplied reason="lost">III et <expan><abbr>L</abbr><ex>ucio</ex></expan> Aur</supplied><lb break="no" n="4"/><supplied reason="lost">elio Vero <expan><abbr>Aug</abbr><ex>usto</ex></expan></supplied> A<supplied reason="lost">rmeniaco trib</supplied><lb break="no" n="5"/><supplied reason="lost">uniciae potestati</supplied>s I<supplied reason="lost">II</supplied> <expan><abbr>co</abbr><ex>n</ex></expan><supplied reason="lost"><expan><abbr>s</abbr><ex>uli</ex></expan></supplied> II <lb n="6"/><supplied reason="lost">vexillatio <expan><abbr>leg</abbr><ex>ionis</ex></expan> XX</supplied> <expan><abbr>V</abbr><ex>aleriae</ex></expan> <expan><abbr>v</abbr><ex>ictricis</ex></expan> fecit su<supplied reason="lost">b c</supplied>ura <lb n="7"/><supplied reason="lost">Sexti Calpurni</supplied> Agrico<supplied reason="lost">l</supplied>ae <lb n="8"/><supplied reason="lost">legati Augustoru</supplied>m <expan><abbr>pr</abbr><ex>o</ex></expan> <expan><abbr>pr</abbr><ex>aetore</ex></expan>
            </ab></div>
            <div type="commentary">
                <p>Die Inschrift besteht aus 6 Fragmenten. (B): CIL 07, 00473 auf Fr. a; EphEp 9, p. 687 n. 1382 und AE 1914, 0002 auf Fr. b u. c.</p>
            </div>
