            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Ex codicillis triplicibus Popili <lb n="2"/>Heraclae <lb n="3"/><expan><abbr>C</abbr><ex>aius</ex></expan> Popilius Heracla <expan><abbr>heredib</abbr><ex>us</ex></expan> <expan><abbr>salut</abbr><ex>em</ex></expan> <lb n="4"/>vos heredes mei rogo iubeoque <lb n="5"/>fideique vestrae committo uti <lb n="6"/>monumentum mihi faciatis in <expan><abbr>Vatic</abbr><ex>ano</ex></expan> <lb n="7"/>ad circum iuxta monumentum Ulpi <lb n="8"/>Narcissi ex HS <expan><abbr>VI</abbr><ex>sex milibus</ex></expan> <expan><abbr>n</abbr><ex>ummum</ex></expan> in quam rem <lb n="9"/>numerabit Novia Trophime HS <expan><abbr>III</abbr><ex>tria milia</ex></expan> <expan><abbr>n</abbr><ex>ummum</ex></expan> <lb n="10"/>et coheredes eius HS <expan><abbr>III</abbr><ex>tria milia</ex></expan> <expan><abbr>n</abbr><ex>ummum</ex></expan> ibique reliquias meas et Fadiae Maximae uxoris meae <lb n="11"/>si quid ei humanitus acciderit poni volo <lb n="12"/>cuius monumenti ius lego libertis liberta<lb break="no" n="13"/><expan><abbr>busq</abbr><ex>ue</ex></expan> meis et quos testamento manumisero <lb n="14"/>sive quem in statu libertatis reliqui et hoc amplius <lb n="15"/>Noviae Trophime libertis <expan><abbr>libertabusq</abbr><ex>ue</ex></expan> eius <lb n="16"/>posterisque supra scriptorum et itum aditum am<lb break="no" n="17"/>bitum sacrificique faciendi causa ad id <expan><abbr>monu</abbr><ex>men</ex></expan><lb break="no" n="18"/>tum uti ei liceat
            </ab></div>
