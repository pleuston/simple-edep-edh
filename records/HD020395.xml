                <expan><abbr>P</abbr><ex>ublio</ex></expan> Aelio <lb n="2"/>Clementi <lb n="3"/><expan><abbr>veter</abbr><ex>ano</ex></expan> ex |(centurione) <lb n="4"/>et <expan><abbr>Cl</abbr><ex>audiae</ex></expan> Carae <lb n="5"/>uxori <lb n="6"/><expan><abbr>f</abbr><ex>ilii</ex></expan> <expan><abbr>f</abbr><ex>ecerunt</ex></expan>
