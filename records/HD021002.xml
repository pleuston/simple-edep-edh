            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Deo Aeterno et Iuno<lb break="no" n="2"/>ni et Angelis <lb n="3"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Procilius Aphrodi<lb break="no" n="4"/>sius <expan><abbr>Aug</abbr><ex>ustalis</ex></expan> <expan><abbr>col</abbr><ex>oniae</ex></expan> <expan><abbr>metropol</abbr><ex>is</ex></expan> <lb n="5"/>et Seximia Hermione <lb n="6"/>et Procilia filia <lb n="7"/>colitoribus <expan><abbr>d</abbr><ex>ono</ex></expan> <expan><abbr>d</abbr><ex>ederunt</ex></expan> <expan><abbr>p</abbr><ex>osuerunt</ex></expan>
            </ab></div>
            <div type="commentary">
                <p>Oberhalb des Inschriftfeldes giebelförmiger Abschluß mit Adler.</p>
            </div>
