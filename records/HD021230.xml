                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/><expan><abbr>Au</abbr><ex>relia</ex></expan> Pa<supplied reason="lost">t</supplied>erna <lb n="3"/><expan><abbr>v</abbr><ex>iva</ex></expan> <expan><abbr>f</abbr><ex>ecit</ex></expan> s<supplied reason="lost">i</supplied>b<supplied reason="lost">i</supplied> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/>
