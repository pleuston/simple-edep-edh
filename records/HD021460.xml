                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="2"/>Dolicheno <lb n="3"/>pro salute et victoria domi<lb break="no" n="4"/>norum nostrorum Augg<del rend="erasure"><expan><abbr>g</abbr><ex>ustorum</ex></expan></del> et <lb n="5"/><del rend="erasure">[<expan><abbr>C</abbr><ex>ai</ex></expan> Fulvi Plautiani <expan><abbr>pr</abbr><ex>aefecti</ex></expan> <expan><abbr>pr</abbr><ex>aetorio</ex></expan> <expan><abbr>c</abbr><ex>larissimi</ex></expan> <expan><abbr>v</abbr><ex>iri</ex></expan></del>] <lb n="6"/><del rend="erasure">[et<certainty locus="name" match="preceding-sibling::text()" cert="low"/> necessari<certainty locus="name" match="preceding-sibling::text()" cert="low"/> <expan><abbr>Auggg</abbr><ex>ustorum</ex></expan>? e</del>]t redi<lb break="no" n="7"/>tu <expan><abbr><supplied reason="lost">I</supplied>mppp</abbr><ex>eratorum</ex></expan> in urbem <supplied reason="lost">s</supplied>uam <lb n="8"/><expan><abbr>T</abbr><ex>itus</ex></expan> Flavius Marinus |(centurio) <expan><abbr>leg</abbr><ex>ionis</ex></expan> <lb n="9"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>p</abbr><ex>osuit</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> d<expan><ex>e</ex><abbr>d</abbr><ex>icata</ex></expan> III Idus Apriles
