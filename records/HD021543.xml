            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Romulii </ab></div><div n="2" type="textpart"><ab><lb n="1"/> ob tantam <lb n="2"/>moderatio<lb break="no" n="3"/>nem iudici<lb break="no" n="4"/>orum provi<lb break="no" n="5"/>sionesque sa<lb break="no" n="6"/>luberrimas <lb n="7"/>adque felici<lb break="no" n="8"/>tatem adven<lb break="no" n="9"/>tus eius Laena<lb break="no" n="10"/>tio Romulo <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <lb n="11"/><expan><abbr>p</abbr><ex>raesidi</ex></expan> <expan><abbr>p</abbr><ex>rovinciae</ex></expan> <expan><abbr>Tripol</abbr><ex>itanae</ex></expan> su<lb break="no" n="12"/>fragio quietis<lb break="no" n="13"/>simi populi et </ab></div><div n="3" type="textpart"><ab><lb n="1"/> decreto <expan><abbr>s</abbr><ex>plendidissimi</ex></expan> <expan><abbr>o</abbr><ex>rdinis</ex></expan> sum<expan><ex>p</ex><abbr>tib</abbr><ex>us</ex></expan> suis <expan><abbr>pos</abbr><ex>uit</ex></expan>
            </ab></div></div>
            <div type="commentary">
                <p>The inscription is carved over an erased earlier text.</p>
            </div>
