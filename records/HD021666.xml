            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Si quis honos vitae <lb n="2"/>est testis post mune<lb break="no" n="3"/>ra fati mortis sorte <lb n="4"/>cluet cum iam sub fine <lb n="5"/>supremo aspicit infe<lb break="no" n="6"/>rnorum Acherusia te<lb break="no" n="7"/>mpla deorum secure <lb n="8"/>qu<expan><ex>a</ex><abbr>e</abbr></expan> videt strepitum <lb n="9"/>Acherontis avari na<lb break="no" n="10"/>mque <expan><ex>e</ex><abbr>gomet</abbr></expan> quod pio se<lb break="no" n="11"/>mper in corpore vixi Ely<lb break="no" n="12"/>sios teneo mites Proserpin<lb break="no" n="13"/>ae campos lege deum <expan><abbr>solemq</abbr><ex>ue</ex></expan> <lb n="14"/>super ac sidera novi Iulia <lb n="15"/><expan><abbr>Mo</abbr><ex>desta</ex></expan> Benenata <expan><abbr>h</abbr><ex>onesta</ex></expan> <expan><abbr>f</abbr><ex>emina</ex></expan> <expan><abbr>vix</abbr><ex>it</ex></expan> annis </ab></div><div n="2" type="textpart"><ab><lb n="1"/> in pace LXXXIII menses <note>sic</note> X </ab></div><div n="3" type="textpart"><ab><lb n="1"/> <expan><abbr>h</abbr><ex>ic</ex></expan> <expan><abbr>s</abbr><ex>ita</ex></expan> <expan><abbr>e</abbr><ex>st</ex></expan>
            </ab></div></div>
