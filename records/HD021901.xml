            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <supplied reason="lost">Heraclii</supplied><certainty match="preceding-sibling::node()" locus="value"/> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Uno eodemque anno <lb n="2"/>du<expan><ex>u</ex><abbr>mviro</abbr></expan> <expan><abbr>Lepcimagn</abbr><ex>ensium</ex></expan> <lb n="3"/>et sacerdoti <expan><abbr>prov</abbr><ex>inciae</ex></expan> Trip<expan><ex>o</ex><abbr>l</abbr><ex>itanae</ex></expan> <lb n="4"/>innocentissimo viro <lb n="5"/>principali integerrimo <lb n="6"/>amatori patriae ac ci<lb break="no" n="7"/>vium suorum <expan><abbr>T</abbr><ex>ito</ex></expan> Flavio <lb n="8"/>Vibiano <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <expan><abbr>fl</abbr><ex>amini</ex></expan> p<expan><ex>er</ex><abbr>p</abbr><ex>etuo</ex></expan> et <expan><abbr>pont</abbr><ex>ifici</ex></expan> <lb n="9"/><expan><abbr>cur</abbr><ex>atori</ex></expan> rei <expan><abbr>pub</abbr><ex>licae</ex></expan> <expan><abbr>Lepcimagn</abbr><ex>ensium</ex></expan> <lb n="10"/><expan><abbr>sac</abbr><ex>erdoti</ex></expan> <expan><abbr>Laur</abbr><ex>entium</ex></expan> <expan><abbr>Lab</abbr><ex>inatium</ex></expan> <note>sic</note> et <expan><abbr>sac</abbr><ex>erdoti</ex></expan> <expan><abbr>M</abbr><ex>atris</ex></expan> <expan><abbr>D</abbr><ex>eum</ex></expan> <lb n="11"/><expan><abbr>praef</abbr><ex>ecto</ex></expan> omnium <expan><abbr>sacr</abbr><ex>orum</ex></expan> ob diversarum volup<lb break="no" n="12"/>tatum exhibitionem <lb n="13"/>et Libycarum ferarum X </ab></div><div n="3" type="textpart"><ab><lb n="1"/> ex populi <expan><abbr>sufrag</abbr><ex>io</ex></expan> et ordin<supplied reason="lost">(is) <expan><abbr>d</abbr><ex>ecreto</ex></expan></supplied>
            </ab></div></div>
            <div type="commentary">
                <p>(B): AE 1929: without a line for the signum above the text; Z. 15: suffrag(io). Datierung: spätkonstantinische Zeit. Base used two times: on the right side original erased text.</p>
