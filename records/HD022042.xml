            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Hic locus est felix sanctus piusque benignus <lb n="2"/>quem monuit Mithras mentemque dedit <lb n="3"/>Proficentio patri sacrorum <lb n="4"/>utque sibi spelaeum faceret dedicaretque <lb n="5"/>et celeri instansque operi reddit munera grata <lb n="6"/>quem bono auspicio suscepit anxia mente <lb n="7"/>ut possint syndexi hilares celebrare vota per aevom <lb n="8"/>hos versiculos generavit Proficentius <lb n="9"/>pater dignissimus Mithrae </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>L</abbr><ex>ucius</ex></expan> Castricius Probus <expan><abbr>d</abbr><ex>onum</ex></expan> <expan><abbr>d</abbr><ex>edit</ex></expan>
            </ab></div></div>
