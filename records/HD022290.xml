                <expan><abbr>P</abbr><ex>ublius</ex></expan> Maximius <lb n="2"/>Maternus <lb n="3"/>mensor <expan><abbr>leg</abbr><ex>ionis</ex></expan> <lb n="4"/>X <expan><abbr>g</abbr><ex>eminae</ex></expan> <expan><abbr>ar</abbr><ex>am</ex></expan> <expan><abbr>d</abbr><ex>edicavit</ex></expan> civibus <lb n="5"/>suis Sabino et <lb n="6"/>Venusto co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
