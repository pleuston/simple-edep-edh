                In <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> Genio <lb n="2"/>Veredariorum <expan><abbr>n</abbr><ex>umeri</ex></expan> <expan><abbr>N</abbr><ex cert="low">idensium</ex></expan> <lb n="3"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>tionius Remu<supplied reason="lost">s <gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>
