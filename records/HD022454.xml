            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Tabularium legionis cum imaginibus <lb n="2"/>domus divinae ex largissimis stipen<lb break="no" n="3"/>dis et liberalitatibus quae in eos <lb n="4"/>conferunt fecerunt <lb n="5"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Aemilius Cattianus <expan><abbr>cornicular</abbr><ex>ius</ex></expan> et <lb n="6"/><expan><abbr>T</abbr><ex>itus</ex></expan> Flavius Surus act<expan><ex>u</ex><abbr>arius</abbr></expan> item librari <lb n="7"/>et exacti <expan><abbr>leg</abbr><ex>ionis</ex></expan> III <expan><abbr>Aug</abbr><ex>ustae</ex></expan> <expan><abbr>p</abbr><ex>iae</ex></expan> <expan><abbr>v</abbr><ex>indicis</ex></expan> <expan><abbr>q</abbr><ex>uorum</ex></expan> <expan><abbr>n</abbr><ex>omina</ex></expan> subiecta sunt <lb n="8"/>ob quam sollemnitatem decretum est ut si <expan><abbr>qui</abbr><ex>s</ex></expan> in locum corniculari legionis vel act<expan><ex>u</ex><abbr>ari</abbr></expan> missi emeriti substitutus <lb n="9"/>fuerit det ei in cuius locum substitutus est anulari nomine |(denarios) <expan><abbr>M</abbr><ex>mille</ex></expan> item si <expan><abbr>qui</abbr><ex>s</ex></expan> in locum cuiusque <lb n="10"/>librari substitutus fuerit vel scamnari nomine collegis |(denarios) <expan><abbr>M</abbr><ex>mille</ex></expan> et si <expan><abbr>qui</abbr><ex>s</ex></expan> ex eodem <lb n="11"/>collegio honestam missionem missus fuerit accipiat a collegis anulari <lb n="12"/>nomine |(denarios) DCCC item si <expan><abbr>qui</abbr><ex>s</ex></expan> ex collegis profecerit accipiat |(denarios) D </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Exacti <lb n="2"/><expan><abbr>C</abbr><ex>aius</ex></expan> Aponius Vitalis <lb n="3"/>Domitius Paulinus <lb n="4"/>Abinneus Victorinus <lb n="5"/>Aurelius Optatus <lb n="6"/><expan><abbr>C</abbr><ex>aius</ex></expan> Iulius Aurelianus <lb n="7"/>Florius Celsus <lb n="8"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Plotius Vitalis <lb n="9"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Aemilius Quadratus <lb n="10"/><expan><abbr>C</abbr><ex>aius</ex></expan> Iulius Crescentianus <lb n="11"/><expan><abbr>D</abbr><ex>ecimus</ex></expan> Valerius <expan><abbr>Quintian</abbr><ex>us</ex></expan> <lb n="12"/><expan><abbr>Q</abbr><ex>uintus</ex></expan> Vereius Vereianus <lb n="13"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Valerius Proculus <lb n="14"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Strobilius <expan><abbr>Marcian</abbr><ex>us</ex></expan> <lb n="15"/><expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Cornel</abbr><ex>ius</ex></expan> <expan><abbr>Augurian</abbr><ex>us</ex></expan> <lb n="16"/>Aemilius Clarus <lb n="17"/>Clodius Victor <lb n="18"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Castricius Frugi <lb n="19"/>Aelius Nummenius <lb n="20"/>Iunius <expan><abbr>Saturnin</abbr><ex>us</ex></expan> <lb n="21"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Munatius Felix <lb n="22"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Tonneius Martialis <expan><abbr>c</abbr><ex>erarius</ex></expan>
