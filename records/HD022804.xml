            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> Caesari <lb n="2"/>divi Marci <supplied reason="lost">An</supplied>tonini Pii Germ<supplied reason="lost">anici</supplied> <lb n="3"/>Sarma<supplied reason="lost">ti</supplied>ci f<supplied reason="lost">ilio divi Antonini Pii</supplied> <lb n="4"/>nepoti divi Hadriani pronepoti divi <lb n="5"/>Traiani Parthici abnepoti divi Ner<lb break="no" n="6"/>vae adnepoti <lb n="7"/><expan><abbr>L</abbr><ex>ucio</ex></expan> Septimio Seve<lb break="no" n="8"/>ro Pertinaci <lb n="9"/><expan><abbr>Aug</abbr><ex>usto</ex></expan> <lb n="10"/>Arabico Adiabenico patri patriae <lb n="11"/>pontifici maximo <expan><abbr>trib</abbr><ex>unicia</ex></expan> <expan><abbr>pot</abbr><ex>estate</ex></expan> <expan><abbr>imp</abbr><ex>eratori</ex></expan> VII <lb n="12"/>co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> II proco<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> fortissimo <expan><abbr>max</abbr><ex>imoque</ex></expan> <lb n="13"/>omnium principum <lb n="14"/>ordo <expan><abbr>c</abbr><ex>olonorum</ex></expan> <expan><abbr>c</abbr><ex>oloniae</ex></expan> <expan><abbr>C</abbr><ex>laritatis</ex></expan> <expan><abbr>I</abbr><ex>uliae</ex></expan> <lb n="15"/><expan><abbr>ded</abbr><ex>icavit</ex></expan> <del rend="erasure"><expan><abbr>Val</abbr><ex>erius</ex></expan> Chalcidicus</del> <lb n="16"/><expan><abbr>proc</abbr><ex>urator</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>cur</abbr><ex>ator</ex></expan> <expan><abbr>r</abbr><ex>ei</ex></expan> <expan><abbr>p</abbr><ex>ublicae</ex></expan> <expan><abbr>c</abbr><ex>olonorum</ex></expan> <expan><abbr>c</abbr><ex>oloniae</ex></expan> <expan><abbr>C</abbr><ex>laritatis</ex></expan> <expan><abbr>I</abbr><ex>uliae</ex></expan>
