            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Pro salute domus <expan><abbr>divin</abbr><ex>ae</ex></expan> <lb n="2"/><expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <expan><abbr>Iunon</abbr><ex>i</ex></expan> <expan><abbr>Regin</abbr><ex>ae</ex></expan> <lb n="3"/>aram <expan><abbr>Q</abbr><ex>uintus</ex></expan> <expan><abbr>Ael</abbr><ex>ius</ex></expan> Aunus IIIIIIvir <expan><abbr>Aug</abbr><ex>ustalis</ex></expan> <lb n="4"/>de suo item donavit <expan><abbr>vican</abbr><ex>is</ex></expan> <lb n="5"/><expan><abbr>n<am>n</am></abbr><ex>ibus</ex></expan> |(denarios) DCCL ex <lb n="6"/>quorum <expan><abbr>ussur</abbr><ex>is</ex></expan> <note>sic</note> gymna<lb break="no" n="7"/>sium in <expan><abbr>derect</abbr><ex>o</ex></expan> <expan><abbr>tempor</abbr><ex>e</ex></expan> <lb n="8"/>per tridu<expan><ex>u</ex><abbr>m</abbr></expan> eisdem <lb n="9"/><expan><abbr>vican</abbr><ex>is</ex></expan> dedit in aev<expan><ex>u</ex><abbr>m</abbr></expan> <lb n="10"/>quod si in alios ussus <note>sic</note> <lb n="11"/><expan><abbr>transferr</abbr><ex>e</ex></expan> voluerint <note>sic</note> <lb n="12"/>hanc <expan><abbr>pecun</abbr><ex>iam</ex></expan> <expan><abbr>incol</abbr><ex>is</ex></expan> <expan><abbr>col</abbr><ex>oniae</ex></expan> Aven<lb break="no" n="13"/>ticensium dari volo <lb n="14"/><expan><abbr>l</abbr><ex>ocus</ex></expan> <expan><abbr>d</abbr><ex>atus</ex></expan> <expan><abbr>d</abbr><ex>ecreto</ex></expan> <expan><abbr>v</abbr><ex>icanorum</ex></expan> <expan><abbr>M</abbr><ex>innodunensium</ex></expan>
            </ab></div>
