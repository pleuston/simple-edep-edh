                <expan><abbr>Fl</abbr><ex>avius</ex></expan> Concordius protector divinorum <lb n="2"/>laterum et pr<expan><ex>a</ex><abbr>epositus</abbr></expan> iuniorum cenation<lb break="no" n="3"/>em ad Guntham ex voto aedificabit <note>sic</note> <lb n="4"/>ita ut nulli liceat in aeodem <note>sic</note> aedi<lb break="no" n="5"/>ficio corpus sepultur<expan><ex>a</ex><abbr>e</abbr></expan> mand<lb break="no" n="6"/>are set <note>sic</note> tantummodo con<lb break="no" n="7"/>vivi<expan><ex>u</ex><abbr>m</abbr></expan> copulantibus vel re<lb break="no" n="8"/>frigerantibus pateat
            </ab></div>
