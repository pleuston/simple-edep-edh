                Primio <lb n="2"/>Cellissi <expan><abbr>fil</abbr><ex>ius</ex></expan> <lb n="3"/><expan><abbr>curia</abbr><ex>lis</ex></expan> gru<expan><ex>e</ex><abbr>s</abbr></expan> duas <lb n="4"/>Mercurio <lb n="5"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
