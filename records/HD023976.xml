                <expan><abbr>Matrib</abbr><ex>us</ex></expan> <lb n="2"/><expan><abbr>templ</abbr><ex>um</ex></expan> <lb n="3"/>cum ara <lb n="4"/><expan><abbr>vex</abbr><ex>illatio</ex></expan> <expan><abbr>coh</abbr><ex>ortis</ex></expan> <lb n="5"/>I <expan><abbr>Vard</abbr><ex>ullorum</ex></expan> <lb n="6"/>instante <lb n="7"/><expan><abbr>P</abbr><ex>ublio</ex></expan> <abbr>D</abbr> <abbr>V</abbr> <lb n="8"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
