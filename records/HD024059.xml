            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost">Pie</supplied>tate iustitia fo<supplied reason="lost">rt</supplied>i<supplied reason="lost">tu</supplied>dine <lb n="2"/>et pleno omnium v<supplied reason="lost">ir</supplied>tutu<supplied reason="lost">m</supplied> <lb n="3"/>principi vero <supplied reason="lost">Got</supplied>h<supplied reason="lost">i</supplied>c<supplied reason="lost">o</supplied> vero<supplied reason="lost">que</supplied> <lb n="4"/>Germanic<supplied reason="lost">o ac</supplied> victoriaru<supplied reason="lost">m</supplied> <lb n="5"/>omnium no<supplied reason="lost">mi</supplied>nibus inlu<supplied reason="lost">stri</supplied> <lb n="6"/><expan><abbr>M</abbr><ex>arco</ex></expan> <expan><abbr>Aur</abbr><ex>elio</ex></expan> Pr<supplied reason="lost">obo</supplied> <expan><abbr>P</abbr><ex>io</ex></expan> <expan><abbr>F</abbr><ex>elici</ex></expan> <expan><abbr>Invict</abbr><ex>o</ex></expan> A<supplied reason="lost"><expan><abbr>ug</abbr><ex>usto</ex></expan></supplied> <lb n="7"/><expan><abbr>pont</abbr><ex>ifici</ex></expan> <expan><abbr>max</abbr><ex>imo</ex></expan> <expan><abbr>t<supplied reason="lost">r</supplied>ib</abbr><ex>unicia</ex></expan> <expan><abbr>p</abbr><ex>otestate</ex></expan> V <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> IIII pro<supplied reason="lost"><expan><abbr>c</abbr><ex>onsuli</ex></expan></supplied> <lb n="8"/>Allius Maximus <expan><abbr>v</abbr><ex>ir</ex></expan> <expan><abbr>c</abbr><ex>larissimus</ex></expan> <expan><abbr>leg</abbr><ex>atus</ex></expan> <expan><abbr>iur</abbr><ex>idicus</ex></expan> <lb n="9"/><expan><abbr>prov</abbr><ex>inciae</ex></expan> <expan><abbr>Hisp</abbr><ex>aniae</ex></expan> <expan><abbr>Tarraconens</abbr><ex>is</ex></expan> <lb n="10"/>maiest<supplied reason="lost">ati</supplied> eius ac numini <lb n="11"/>dicatissimus
