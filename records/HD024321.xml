    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>eratore</ex></expan> Nerva <expan><abbr>Caesar</abbr><ex>e</ex></expan> Traiano <lb n="2"/><expan><abbr>Aug</abbr><ex>usto</ex></expan> <expan><abbr>Germ</abbr><ex>anico</ex></expan> II <lb n="3"/><expan><abbr>C</abbr><ex>aio</ex></expan> Pomponio Pio co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> <lb n="4"/>VI Idus Iunias <lb n="5"/>Baetulonenses ex Hispania citerio<lb break="no" n="6"/>re hospitium fecerunt <lb n="7"/>cum <expan><abbr>Q</abbr><ex>uinto</ex></expan> Licinio Silvano Graniano <lb n="8"/>eumque liberos posterosque <lb n="9"/>eius sibi liberis posterisque <lb n="10"/>suis patronum cooptaverunt <lb n="11"/><expan><abbr>Q</abbr><ex>uintus</ex></expan> Licinius Silvanus Grania<lb break="no" n="12"/>nus Baetulonenses ex His<lb break="no" n="13"/>pania citeriore ipsos libe<lb break="no" n="14"/>ros posterosque eorum in <lb n="15"/>fidem clientelamque suam <lb n="16"/>liberorum posterorum<lb break="no" n="17"/>que suorum recepit <lb n="18"/>egit legatus <lb n="19"/><expan><abbr>Q</abbr><ex>uintus</ex></expan> Caecilius Tertullus
            </ab></div>
            <div type="commentary">
                <p>Hospitiumsvertrag.</p>
            </div>
