            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost"><expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar Divi <expan><abbr>f</abbr><ex>ilius</ex></expan> Augustus pontifex maximus <expan><abbr>imp</abbr><ex>erator</ex></expan> XIII</supplied>I c<supplied reason="lost"><expan><abbr>o</abbr><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> XIII tribunicia potestate XXI pater patriae</supplied> <lb n="2"/><supplied reason="lost">ex manibiis</supplied> <supplied reason="lost">dono dedit</supplied> <lb n="3"/><supplied reason="lost">idemque cum <expan><abbr>C</abbr><ex>aio</ex></expan> et <expan><abbr>L</abbr><ex>ucio</ex></expan> Caesaribus filiis <expan><abbr>co</abbr><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> designatis principibus iuventutis dedicavit</supplied>
            </ab></div>
            <div type="commentary">
                <p>Epistyl. Autopsie Alföldy.</p>
            </div>
