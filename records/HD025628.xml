                <supplied reason="lost"><expan><abbr>Imp</abbr><ex>eratori</ex></expan> Caesari divi Nervae <expan><abbr>f</abbr><ex>ilio</ex></expan> Nervae Traiano <expan><abbr>Aug</abbr><ex>usto</ex></expan> <expan><abbr>Germ</abbr><ex>anico</ex></expan> Dacico <expan><abbr>pontif</abbr><ex>ici</ex></expan> <expan><abbr>max</abbr><ex>imo</ex></expan> <expan><abbr>trib</abbr><ex>unicia</ex></expan> <expan><abbr>pot</abbr><ex>estate</ex></expan> XII</supplied> <expan><abbr>imp</abbr><ex>eratori</ex></expan> VI co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> V <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <supplied reason="lost">propagatori</supplied> <lb n="2"/><supplied reason="lost">orbis terrarum locupletatori civium cultores Larum et imaginum domus Augustae solo pr</supplied>ivato sua pecun<supplied reason="lost">ia fecerunt</supplied>
