x>um</ex></expan> et <expan><abbr>Aug</abbr><ex>usta</ex></expan> <expan><abbr>Vocontior</abbr><ex>um</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I <lb n="10"/>Nervia <expan><abbr>German</abbr><ex>orum</ex></expan> |(miliaria) et I <expan><abbr>Celtiberor</abbr><ex>um</ex></expan> et I <expan><abbr>Thrac</abbr><ex>um</ex></expan> et I <expan><abbr>Afror</abbr><ex>um</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I <lb n="11"/><expan><abbr>Lingon</abbr><ex>um</ex></expan> et I fida <expan><abbr>Vardullor</abbr><ex>um</ex></expan> |(miliaria) <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I <expan><abbr>Frisiavon</abbr><ex>um</ex></expan> et I <expan><abbr>Vangion</abbr><ex>um</ex></expan> <lb n="12"/>|(miliaria) et I <expan><abbr>Hamior</abbr><ex>um</ex></expan> <expan><abbr>sagitt</abbr><ex>aria</ex></expan> et I <expan><abbr>Delmat</abbr><ex>arum</ex></expan> et I <expan><abbr>Aquitan</abbr><ex>orum</ex></expan> et I Ulpia Traia<lb break="no" n="13"/>na <expan><abbr>Cugern</abbr><ex>orum</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I <expan><abbr>Morin</abbr><ex>orum</ex></expan> et I <expan><abbr>Menapior</abbr><ex>um</ex></expan> et I <expan><abbr>Sunucor</abbr><ex>um</ex></expan> et I B<expan><ex>a</ex><abbr>eta</abbr></expan><lb break="no" n="14"/><expan><abbr>sior</abbr><ex>um</ex></expan> et I <expan><abbr>Batavor</abbr><ex>um</ex></expan> et I <expan><abbr>Tungror</abbr><ex>um</ex></expan> et I <expan><abbr>Hispan</abbr><ex>orum</ex></expan> et II <expan><abbr>Gallor</abbr><ex>um</ex></expan> et II <lb n="15"/><expan><abbr>Vascon</abbr><ex>um</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et II <expan><abbr>Thrac</abbr><ex>um</ex></expan> et II <expan><abbr>Lingon</abbr><ex>