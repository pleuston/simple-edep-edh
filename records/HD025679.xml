            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Im<supplied reason="lost"><expan><abbr>p</abbr><ex>erator</ex></expan></supplied> Caesar d<supplied reason="lost">ivi Traiani Parthici <expan><abbr>fil</abbr><ex>ius</ex></expan></supplied> <lb n="2"/>d<supplied reason="lost">ivi Ne</supplied>rvae nepo<supplied reason="lost">s Traianus Hadrianus <expan><abbr>Aug</abbr><ex>ustus</ex></expan></supplied> <lb n="3"/><supplied reason="lost">pontife</supplied>x maximus <supplied reason="lost" cert="low">trib(unicia) potest(ate) --- co(n)s(ul) III imp(erator) II? p(ater) p(atriae)</supplied> <lb n="4"/>has aedes incendio <supplied reason="lost">consumptas restituit quarum</supplied> <lb n="5"/>Gaius Marcus Publiu<supplied reason="lost">s Corneli Cethegi duas veteres affectas</supplied> <lb n="6"/>et i<supplied reason="lost">n</supplied>cendio vexat<supplied reason="lost">as refecerant tertiam exstruxserant</supplied>
            </ab></div>
