                <expan><abbr>Coh</abbr><ex>ors</ex></expan> III <expan><abbr>Thr</abbr><ex>acum</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan>
