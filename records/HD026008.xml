                In <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> <lb n="2"/>pro salute <lb n="3"/><expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="4"/>Materni <lb n="5"/>Marciani <lb n="6"/>Valeriana <lb n="7"/>soror <lb n="8"/>ex voto <lb n="9"/>posuit <lb n="10"/><expan><abbr>l</abbr><ex>aeta</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
