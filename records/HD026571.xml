                <expan><abbr>B</abbr><ex>onae</ex></expan> <expan><abbr>m</abbr><ex>emoriae</ex></expan> <lb n="2"/>hic requiis<lb break="no" n="3"/>cet <note>sic</note> in pace vir <lb n="4"/>venerabilis pr<lb break="no" n="5"/>esbyter Berev<lb break="no" n="6"/>ulfus qui <expan><abbr>vix</abbr><ex>it</ex></expan> <lb n="7"/>et in hunc s<expan><ex>a</ex><abbr>ecu</abbr></expan><lb break="no" n="8"/>lum annus <note>sic</note> plu<lb break="no" n="9"/>s minus LXX req<lb break="no" n="10"/>uuiebet <note>sic</note> sub die <lb n="11"/>III Kalendarum <lb n="12"/>Ianuariarum
            </ab></div>
