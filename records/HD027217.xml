                <expan><abbr>C</abbr><ex>aius</ex></expan> Maximius <lb n="2"/>Bilenius <expan><abbr>mili</abbr><ex>s</ex></expan> <note>sic</note> <lb n="3"/><expan><abbr>leg</abbr><ex>ionis</ex></expan> XV Apol<expan><ex>l</ex><abbr>inaris</abbr></expan> <lb n="4"/>posierunt <note>sic</note> mater <lb n="5"/>et &amp;lt;f=P&amp;gt;rater &amp;lt;P=R&amp;gt;(ublius) Vale<lb break="no" n="6"/>rius <expan><abbr>Proclu</abbr><ex>s</ex></expan> <lb n="7"/><expan><abbr>stip</abbr><ex>endiorum</ex></expan> XIIII 
