                <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">volu</supplied>ntas mea et rata post <gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="2"/><gap reason="lost" extent="unknown" unit="character"/>m meam in qua puteus e<gap reason="lost" extent="unknown" unit="character"/> <lb n="3"/><gap reason="lost" extent="unknown" unit="character"/>tis viri mei volo ita u<supplied reason="lost">t</supplied><gap reason="lost" extent="unknown" unit="character"/> <lb n="4"/><supplied reason="lost">violam</supplied> et rosam ad monim<supplied reason="lost">entum</supplied> <lb n="5"/><gap reason="lost" extent="unknown" unit="character"/>nt inpensam consu<supplied reason="lost">mma</supplied><gap reason="lost" extent="unknown" unit="character"/> <lb n="6"/><gap reason="lost" extent="unknown" unit="character"/> neve ea taberna aut <gap reason="lost" extent="unknown" unit="character"/> <lb n="7"/><gap reason="lost" extent="unknown" unit="character"/> serviant <gap reason="lost" extent="unknown" unit="character"/>
            </ab></div>
