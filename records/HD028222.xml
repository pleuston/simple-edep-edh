                <listBibl><bibl>AE 1900, 0066.</bibl><bibl>CIL 03, 14359, 23. (B)</bibl><bibl>W. Kubitschek, JŒAI (Beibl.) 3, 1900, col. 16; Zeichnung.</bibl><bibl/></listBibl>
            </div>
        </body>
