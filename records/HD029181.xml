                In <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> Genio capsari<lb break="no" n="2"/>orum <expan><abbr>n</abbr><ex>umeri</ex></expan> Divitiensium <lb n="3"/>Gordianorum <expan><abbr>T</abbr><ex>itus</ex></expan> <expan><abbr>F</abbr><ex>lavius</ex></expan> Proces<lb break="no" n="4"/>sus medicus hordina<lb break="no" n="5"/>rius <note>sic</note> sub <expan><abbr>C</abbr><ex>aio</ex></expan> Vibio Vita<lb break="no" n="6"/>le pr<expan><ex>a</ex><abbr>ef</abbr><ex>ecto</ex></expan> <expan><abbr>n</abbr><ex>umeri</ex></expan> <expan><abbr>s</abbr><ex>upra</ex></expan> <expan><abbr>s</abbr><ex>cripti</ex></expan> <expan><abbr>d</abbr><ex>onum</ex></expan> <expan><abbr>p</abbr><ex>osuit</ex></expan>
