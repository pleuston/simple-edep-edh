            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>L</abbr><ex>ucius</ex></expan> Porcius <expan><abbr>Quir</abbr><ex>ina</ex></expan> Quietus <lb n="2"/>IIvir pontifex solo suo <lb n="3"/>templum et signum et <lb n="4"/>forum suo et <expan><abbr>T</abbr><ex>iti</ex></expan> Porci <lb n="5"/><expan><abbr>Quir</abbr><ex>ina</ex></expan> Quieti <expan><abbr>f</abbr><ex>ili</ex></expan> sui nomi<lb break="no" n="6"/>ne de sua pecunia <expan><abbr>f</abbr><ex>acienda</ex></expan> <expan><abbr>c</abbr><ex>uravit</ex></expan>
            </ab></div>
            <div type="commentary">
                <p>Das Stück ist heute verschollen.</p>
            </div>
