                <gap reason="lost" extent="unknown" unit="character"/>o <expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> Rufo pro<supplied reason="lost"><expan><abbr>co</abbr><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan></supplied> </ab></div><div n="2" type="textpart"><ab><lb n="0"/> <gap reason="lost" quantity="1" unit="line"/> <lb n="1"/><supplied reason="lost">patrono</supplied> </ab></div><div n="3" type="textpart"><ab><lb n="0"/> <gap reason="lost" quantity="1" unit="line"/> <lb n="1"/><supplied reason="lost">patrono</supplied> </ab></div><div n="4" type="textpart"><ab><lb n="1"/> <supplied reason="lost">Tia</supplied>ni patrono </ab></div><div n="5" type="textpart"><ab><lb n="1"/> Prusienses ab Hypio <lb n="2"/>patrono </ab></div><div n="6" type="textpart"><ab><lb n="1"/> Prusais ab Olympo <lb n="2"/>patrono </ab></div><div n="7" type="textpart"><ab><lb n="1"/> Prusienses ab mare <lb n="2"/>patrono </ab></div><div n="8" type="textpart"><ab><lb n="1"/> Apameni <lb n="2"/>patrono </ab></div><div n="9" type="textpart"><ab><lb n="1"/> N<supplied reason="lost">icomedenses</supplied> <lb n="2"/><supplied reason="lost">patrono</supplied> </ab></div><div n="10" type="textpart"><ab><lb n="1"/> <gap reason="lost" extent="unknown" unit="character"/>ωι Λευκίου υἱῶ<supplied reason="lost">ι</supplied> Ῥούφωι ἀνθυ̣<supplied reason="lost">πάτωι <gap reason="lost" extent="unknown" unit="character"/></supplied> </ab></div><div n="11" type="textpart"><ab><lb n="1"/> <gap reason="lost" extent="unknown" unit="character"/>νοὶ πάτρωνι καὶ <lb n="2"/><supplied reason="lost">εὐερ</supplied>γέτηι διὰ πρεσβευ<lb break="no" n="3"/><supplied reason="lost">τοῦ Ἀ</supplied>ρτεμιδώρου τοῦ <lb n="4"/><supplied reason="lost">Ἀ</supplied>ρτεμιδώρου </ab></div><div n="12" type="textpart"><ab><lb n="1"/> Προυσιεῖς ἀπὸ Ὑπίου πάτρωνι <lb n="2"/>καὶ εὐεργέτηι πρεσβευόντων <lb n="3"/>Μενεμάχου τοῦ Κασσάνδρου <lb n="4"/>Ἀριστονίκου Τιμοκράτους </ab></div><div n="13" type="textpart"><ab><lb n="1"/> Προυσαεῖς ἀπὸ Ὀλύμπ<supplied reason="lost">ου πάτρωνι</supplied> <lb n="2"/>καὶ εὐεργέτηι πρεσβεύον<supplied reason="lost">τος</supplied> <lb n="3"/>Δημοφίλου Ἀσκληπιάδο<supplied reason="lost">υ</supplied> </ab></div><div n="14" type="textpart"><ab><lb n="1"/> Προυσιεῖς ἀπὸ θαλάσσης πά<lb break="no" n="2"/>τρωνι καὶ εὐεργέτηι πρεσ<lb break="no" n="3"/>βεύοντος Ἀγρία τοῦ Ζωΐλου </ab></div><div n="15" type="textpart"><ab><lb n="1"/> Ἀπαμεῖς πάτρωνι καὶ εὐεργέτηι <lb n="2"/>πρεσβεύοντος Μάρκου Αὐρηλίου <lb n="3"/>Νικομήδους &amp;lt;τ&amp;gt;οῦ <surplus>⁴ΥΙΟΥ</surplus>⁴ Κλεοχάρους </ab></div><div n="16" type="textpart"><ab><lb n="1"/> Νικομηδεῖς π<supplied reason="lost">άτρωνι καὶ</supplied> <lb n="2"/>εὐεργέτηι πρε<supplied reason="lost">σβευοντ <gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied> <lb n="3"/>Γ&amp;lt;λ&amp;gt;υ<supplied reason="lost">κ<certainty locus="name" match="preceding-sibling::text()" cert="low"/> <gap reason="lost" extent="unknown" unit="character"/></supplied>
            </ab></div></div>
