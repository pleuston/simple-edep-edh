                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> <lb n="2"/>Caesari divi <lb n="3"/>Traiani Parthici <expan><abbr>f</abbr><ex>ilio</ex></expan> <lb n="4"/>divi Nervae nepoti <lb n="5"/>Traiano Hadriano <lb n="6"/><expan><abbr>Aug</abbr><ex>usto</ex></expan> pontifici <expan><abbr>max</abbr><ex>imo</ex></expan> <lb n="7"/><expan><abbr>trib</abbr><ex>unicia</ex></expan> <expan><abbr>potest</abbr><ex>ate</ex></expan> XVI co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> III <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <lb n="8"/>res <expan><abbr>p</abbr><ex>ublica</ex></expan> Aratispitana <lb n="9"/><expan><abbr>d</abbr><ex>ecrevit</ex></expan> <expan><abbr>d</abbr><ex>edicavit</ex></expan>
