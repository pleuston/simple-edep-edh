            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>M</abbr><ex>arco</ex></expan> Fulvio Senecioni <lb n="2"/>Aratispitano optum<supplied reason="lost">o et praes</supplied><lb break="no" n="3"/>tantissumo civi ob m<supplied reason="lost">erita eius</supplied> <lb n="4"/>amici posuerun<supplied reason="lost">t</supplied> <lb n="5"/><expan><abbr>P</abbr><ex>ublius</ex></expan> Licinius Aemilianus <expan><abbr>P</abbr><ex>ublius</ex></expan> <expan><abbr>Licin</abbr><ex>ius</ex></expan> R<gap reason="lost" extent="unknown" unit="character"/> <lb n="6"/><expan><abbr>L</abbr><ex>ucius</ex></expan> <expan><abbr>Licin</abbr><ex>ius</ex></expan> <expan><abbr>Vibian</abbr><ex>us</ex></expan> <expan><abbr>L</abbr><ex>ucius</ex></expan> <expan><abbr>Licin</abbr><ex>ius</ex></expan> Licinian<supplied reason="lost">us</supplied> <lb n="7"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Fabius <expan><abbr>Silvin</abbr><ex>us</ex></expan> <expan><abbr>C</abbr><ex>aius</ex></expan> Fabius Fabianus <lb n="8"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Fabius Optatus <expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Iun</abbr><ex>ius</ex></expan> <expan><abbr>Montan</abbr><ex>us</ex></expan> <lb n="9"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Iunius <expan><abbr>Martial</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Iun</abbr><ex>ius</ex></expan> Maternus <lb n="10"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Flavius <expan><abbr>Maxumin</abbr><ex>us</ex></expan> <expan><abbr>L</abbr><ex>ucius</ex></expan> <expan><abbr>Flavi</abbr><ex>us</ex></expan> Severus <lb n="11"/><expan><abbr>C</abbr><ex>aius</ex></expan> Calpurnius Celer <expan><abbr>C</abbr><ex>aius</ex></expan> <expan><abbr>Calpurn</abbr><ex>ius</ex></expan> Perpetuus <lb n="12"/><expan><abbr>C</abbr><ex>aius</ex></expan> <expan><abbr>Aemil</abbr><ex>ius</ex></expan> Anthus <expan><abbr>T</abbr><ex>itus</ex></expan> <expan><abbr>n<am>n</am></abbr><ex>ius</ex></expan> Dionysius <lb n="13"/><expan><abb