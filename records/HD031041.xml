            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Magia <expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilia</ex></expan> Se<supplied reason="lost">c</supplied>u<lb break="no" n="2"/>nda sibi et Ca<supplied reason="lost">e</supplied><lb break="no" n="3"/>lio <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>l</abbr><ex>iberto</ex></expan> Philarg<supplied reason="lost">yro</supplied> <lb n="4"/>viro suo et <expan><abbr>L</abbr><ex>ucio</ex></expan> Magi<supplied reason="lost">o</supplied> <lb n="5"/><expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> <expan><abbr>vet</abbr><ex>erano</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> XIII patri <lb n="6"/>suo et <expan><abbr>M</abbr><ex>arco</ex></expan> Vesonio <lb n="7"/><expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> Repentino fra<lb break="no" n="8"/>tri suo et Aniniae Elpidi viva sibi et <lb n="9"/><supplied reason="lost">suis fecit</supplied>
            </ab></div>
            <div type="commentary">
                <p>(B): Leicht divergierende Lesungen der Zeilenenden von Z. 3 u. 4.</p>
            </div>
