                <expan><abbr>C</abbr><ex>aio</ex></expan> Semproni<supplied reason="lost">o</supplied> <lb n="2"/>Nigellioni <lb n="3"/><expan><abbr>VIvir</abbr><ex>o</ex></expan> <expan><abbr>Aug</abbr><ex>ustali</ex></expan> in <expan><abbr>col</abbr><ex>onia</ex></expan> Patric<supplied reason="lost">ia et</supplied> <lb n="4"/>in municipio <expan><abbr>Singil</abbr><ex>iensi</ex></expan> <expan><abbr>VIvir</abbr><ex>o</ex></expan> <supplied reason="lost"><expan><abbr>Aug</abbr><ex>ustali</ex></expan></supplied> <lb n="5"/>perpetu<surplus>u</surplus>o <expan><abbr>d</abbr><ex>ecreto</ex></expan> <expan><abbr>d</abbr><ex>ecurionum</ex></expan> municipi <supplied reason="lost">mu</supplied><lb break="no" n="6"/>nicipum <expan><abbr>Singil</abbr><ex>iensium</ex></expan> honor<supplied reason="lost">em</supplied> <lb n="7"/>accepit impensam remisi<supplied reason="lost">t</supplied> <lb n="8"/>huic ordo Singiliensis recepto <lb n="9"/>in civium numerum quantum <lb n="10"/>cui&amp;lt;que&amp;gt; plurimum libertino decrevit <lb n="11"/>item huic ordo <expan><abbr>Singiliens</abbr><ex>is</ex></expan> vetus <lb n="12"/>eadem quae supra in univer<lb break="no" n="13"/>sum decreverat suo quoque <lb n="14"/>nomine decrevit
            </ab></div>
