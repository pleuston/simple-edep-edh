                <expan><abbr>T</abbr><ex>ito</ex></expan> Vario <expan><abbr>T</abbr><ex>iti</ex></expan> <expan><abbr>fil</abbr><ex>io</ex></expan> <lb n="2"/>Clementi <expan><abbr>Cl</abbr><ex>audia</ex></expan> <expan><abbr>Cel</abbr><ex>eia</ex></expan> <lb n="3"/><expan><abbr>proc</abbr><ex>uratori</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>provinciar</abbr><ex>um</ex></expan> <lb n="4"/>Raetiae <expan><abbr>Mauretan</abbr><ex>iae</ex></expan> <lb n="5"/>Caesar<expan><ex>i</ex><abbr>ensis</abbr></expan> <lb n="6"/>Lusitaniae Ciliciae <lb n="7"/><expan><abbr>praef</abbr><ex>ecto</ex></expan> <expan><abbr>al</abbr><ex>ae</ex></expan> Britannicae <expan><abbr>miliar</abbr><ex>iae</ex></expan> <lb n="8"/><expan><abbr>praef</abbr><ex>ecto</ex></expan> auxiliariorum tempore <lb n="9"/>expeditionis in Tingitaniam <lb n="10"/>missorum <lb n="11"/><expan><abbr>praef</abbr><ex>ecto</ex></expan> <expan><abbr>eq</abbr><ex>uitum</ex></expan> <expan><abbr>al</abbr><ex>ae</ex></expan> II Pannoniorum <lb n="12"/><expan><abbr>trib</abbr><ex>uno</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> XXX <expan><abbr>Ulp</abbr><ex>iae</ex></expan> <expan><abbr>praef</abbr><ex>ecto</ex></expan> <expan><abbr>coh</abbr><ex>ortis</ex></expan> II <lb n="13"/>Gallorum <expan><abbr>Macedon</abbr><ex>icae</ex></expan> <lb n="14"/><expan><abbr>Valer</abbr><ex>ius</ex></expan> Urbanus <lb n="15"/><expan><abbr>Licin</abbr><ex>ius</ex></expan> Secundinus <lb n="16"/>decuriones <lb n="17"/><expan><abbr>alar</abbr><ex>es</ex></expan> <expan><abbr>provinc</abbr><ex>iae</ex></expan> <expan><abbr>Mauretan</abbr><ex>iae</ex></expan> <lb n="18"/>Caesar<expan><ex>i</ex><abbr>ensis</abbr></expan>
