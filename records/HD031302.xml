            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Vexillatio <lb n="2"/><expan><abbr>leg</abbr><ex>ionis</ex></expan> XIIII <expan><abbr>g</abbr><ex>eminae</ex></expan> <expan><abbr>M</abbr><ex>artiae</ex></expan> <expan><abbr>v</abbr><ex>ictricis</ex></expan>
