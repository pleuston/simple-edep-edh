                <supplied reason="lost">Aquis Sin</supplied>uessanis ob <gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/>i <expan><abbr>T</abbr><ex>itus</ex></expan> Caunius Pris<supplied reason="lost">cus</supplied> <lb n="3"/><supplied reason="lost"><expan><abbr>leg</abbr><ex>atus</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>pr</abbr><ex>o</ex></expan></supplied> <expan><abbr>pr</abbr><ex>aetore</ex></expan> co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> <expan><abbr>des</abbr><ex>ignatus</ex></expan> cum V<supplied reason="lost">era</supplied> <lb n="4"/><supplied reason="lost">uxore et Fir</supplied>mino et Prisca filiis
