            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Pro salute et victoria domini <expan><abbr>n</abbr><ex>ostri</ex></expan> <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>L</abbr><ex>uci</ex></expan> Septimi Severi Pertenacis <note>sic</note> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <del rend="erasure">e[t</del>] <lb n="2"/><del rend="erasure">Clod<supplied reason="lost">i</supplied> Albini <expan><abbr>Caes</abbr><ex>aris</ex></expan></del> Aesculapem <note>sic</note> et Hygiam <note>sic</note> dedicante Lepido Tertullo <expan><abbr>leg</abbr><ex>ato</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <lb n="3"/><expan><abbr>pr</abbr><ex>o</ex></expan> <expan><abbr>pr</abbr><ex>aetore</ex></expan> <expan><abbr>c</abbr><ex>larissimo</ex></expan> <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>M</abbr><ex>arcus</ex></expan> Oppius Antiochianus <del rend="erasure">|(centurio) <expan><abbr>leg</abbr><ex>ionis</ex></expan> III <expan><abbr>Aug</abbr><ex>ustae</ex></expan> piae v[indicis</del>] posuit et <lb n="4"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan>
            </ab></div>
            <div type="commentary">
                <p>C. Iulius Lepidus Tertullus war 194 n. Chr. kaiserlicher Legat in Numidien.</p>
            </div>
