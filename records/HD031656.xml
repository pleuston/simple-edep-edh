                <gap reason="lost" quantity="1" unit="line"/>ELA<gap reason="lost" quantity="1" unit="line"/> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> ------ <expan><abbr>pleroma</abbr><ex>te</ex></expan> --- et] <lb n="2"/>milites ple<supplied reason="lost"><expan><abbr>roma</abbr><ex>tis</ex></expan> eius</supplied><lb break="no" n="3"/>dem aedem <gap reason="lost" extent="unknown" unit="character"/> <lb n="4"/>aere collat<supplied reason="lost" cert="low">o fecerunt</supplied> <lb n="5"/><del rend="erasure">I<supplied reason="lost">m</supplied><expan><abbr>p</abbr><ex>eratore</ex></expan> [Commodo V</del>]I et Septim<supplied reason="lost">iano</supplied> <lb n="6"/>co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan>
