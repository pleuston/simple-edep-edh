            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Pro <expan><abbr>sal</abbr><ex>ute</ex></expan> <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> Caesaris <expan><abbr>L</abbr><ex>uci</ex></expan> <lb n="2"/><surplus>P(ubli)</surplus> Septimi Severi Pertina<lb break="no" n="3"/>cis <expan><abbr>Aug</abbr><ex>usti</ex></expan> Pii co<expan><ex>n</ex><abbr>s</abbr><ex>ulis</ex></expan> II <expan><abbr>p</abbr><ex>atris</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> et <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>Aur</abbr><ex>eli</ex></expan> <lb n="4"/>Antonini <expan><abbr>Caesa</abbr><ex>ris</ex></expan> <expan><abbr>Tib</abbr><ex>erius</ex></expan> <expan><abbr>Cl</abbr><ex>audius</ex></expan> <lb n="5"/>Claudianus <expan><abbr>leg</abbr><ex>atus</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>pr</abbr><ex>o</ex></expan> <expan><abbr>pr</abbr><ex>aetore</ex></expan> <lb n="6"/>praesidium vetustate <lb n="7"/><expan><abbr>coll</abbr><ex>apsum</ex></expan> mutato loco manu <lb n="8"/><expan><abbr>milit</abbr><ex>um</ex></expan> restitui iussit
            </ab></div>
