                <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/> Domitio Antigono</supplied> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">VIIviro</supplied> <lb n="3"/>ep<supplied reason="lost">ulonum<certainty locus="name" match="preceding-sibling::text()" cert="low"/> viro</supplied> <lb n="4"/>consulari <supplied reason="lost">patri</supplied> <lb n="5"/>indulgentiss<supplied reason="lost">imo <expan><abbr>b</abbr><ex>ene</ex></expan> <expan><abbr>m</abbr><ex>erenti</ex></expan></supplied> <lb n="6"/><expan><abbr>Domit</abbr><ex>ius</ex></expan> Ant<supplied reason="lost" cert="low">igonus</supplied> <lb n="7"/><supplied reason="lost"><expan><abbr>v</abbr><ex>ir</ex></expan> <expan><abbr>c</abbr><ex>larissimus</ex></expan> <expan><abbr>co</abbr><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan></supplied> <lb n="8"/><supplied reason="lost">filius <expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uravit</ex></expan></supplied>
