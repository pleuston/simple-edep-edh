                <del rend="erasure">Corn<supplied reason="lost">eli</supplied>ae Salon[i</del>]<lb break="no" n="2"/><del rend="erasure">nae sanctissimae</del> <lb n="3"/><del rend="erasure"><expan><abbr>Aug</abbr><ex>ustae</ex></expan> coniugi <expan><abbr>d</abbr><ex>omini</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan> Gal</del><lb break="no" n="4"/><del rend="erasure">lieni Invicti <expan><abbr>Aug</abbr><ex>usti</ex></expan></del> or<lb break="no" n="5"/>do et populus coloni<lb break="no" n="6"/>ae Faliscorum cu<lb break="no" n="7"/>rante Tyrio Septimi<lb break="no" n="8"/>o Azizo <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <expan><abbr>cur</abbr><ex>atore</ex></expan> <expan><abbr>r</abbr><ex>ei</ex></expan> <expan><abbr>p</abbr><ex>ublicae</ex></expan> devo<lb break="no" n="9"/>ti numini maiestati<lb break="no" n="10"/>que eius
