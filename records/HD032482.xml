                <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar <lb n="2"/>Divi <expan><abbr>f</abbr><ex>ilius</ex></expan> <lb n="3"/>Augustus co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> XI <lb n="4"/><expan><abbr>tribun</abbr><ex>icia</ex></expan> <expan><abbr>potest</abbr><ex>ate</ex></expan> XII <lb n="5"/><expan><abbr>imp</abbr><ex>erator</ex></expan> XII<surplus>I</surplus>
