                <expan><abbr>M</abbr><ex>artia</ex></expan> <expan><abbr>I</abbr><ex>ulia</ex></expan> <expan><abbr>V</abbr><ex>aleria</ex></expan> <expan><abbr>S</abbr><ex>alona</ex></expan> <lb n="2"/><expan><abbr>F</abbr><ex>elix</ex></expan>
