            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> <expan><abbr>Caes</abbr><ex>ari</ex></expan> <lb n="2"/>divi <expan><abbr>Hadr</abbr><ex>iani</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> <lb n="3"/>divi <expan><abbr>Traian</abbr><ex>i</ex></expan> Par<lb break="no" n="4"/>thici <expan><abbr>n</abbr><ex>epoti</ex></expan> divi Nervae <lb n="5"/><expan><abbr>pron</abbr><ex>epoti</ex></expan> <expan><abbr>T</abbr><ex>ito</ex></expan> <expan><abbr>Ael</abbr><ex>io</ex></expan> <expan><abbr>Hadrian</abbr><ex>o</ex></expan> <lb n="6"/>Antonino <expan><abbr>Aug</abbr><ex>usto</ex></expan> Pio <lb n="7"/><expan><abbr>pont</abbr><ex>ifici</ex></expan> <expan><abbr>max</abbr><ex>imo</ex></expan> <expan><abbr>trib</abbr><ex>unicia</ex></expan> <expan><abbr>potes</abbr><ex>tate</ex></expan> <lb n="8"/>XXIII <expan><abbr>imp</abbr><ex>eratori</ex></expan> II co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> IIII <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <lb n="9"/><expan><abbr>d</abbr><ex>ecreto</ex></expan> <expan><abbr>d</abbr><ex>ecurionum</ex></expan>
