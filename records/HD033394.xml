            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Felicissimis temporibus <expan><abbr>d<am>d</am></abbr><ex>ominis</ex></expan> <expan><abbr>n<am>n</am></abbr><ex>ostris</ex></expan> <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <del rend="erasure"><expan><abbr>M</abbr><ex>arci</ex></expan> Iuli Philippi</del> Invicti Pii Felicis <del rend="erasure">et <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> Iuli Philippi Invicti Pii</del> <lb n="2"/>Felicis <expan><abbr>Aug<am>g</am></abbr><ex>ustorum</ex></expan> <del rend="erasure">et Marciae Otaciliae Severae <expan><abbr>Aug</abbr><ex>ustae</ex></expan></del> aqua fontis quae multo tempore deperierat et cives inopia <lb n="3"/>aquae laborabant instantia <expan><abbr>M</abbr><ex>arci</ex></expan> Aurelii Athonis Marcelli <expan><abbr>v</abbr><ex>iri</ex></expan> <expan><abbr>e</abbr><ex>gregii</ex></expan> <expan><abbr>proc</abbr><ex>uratoris</ex></expan> <expan><abbr>Aug<am>g</am></abbr><ex>ustorum</ex></expan> rarissimi praesidis <expan><abbr>n</abbr><ex>ostri</ex></expan> patroni muni<lb break="no" n="4"/>cipii innovato opere aquae ductus abundans in fonte est perducta
            </ab></div>
            <div type="commentary">
                <p>Datierung: Juli/August 247 n. Chr. (Erhebung des jüngeren Philippus zum Augustus) bis September/Oktober 249 n. Chr. (Tod der beiden Philippi).</p>
            </div>
