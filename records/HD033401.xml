                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> Caesari <expan><abbr>d</abbr><ex>omino</ex></expan> <expan><abbr>n</abbr><ex>ostro</ex></expan> <lb n="2"/><expan><abbr>Fl</abbr><ex>avio</ex></expan> Valenti Pio <lb n="3"/>Felici semper <lb n="4"/>Augusto ci<lb break="no" n="5"/>vitas Vicetina
