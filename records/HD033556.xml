            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Nundinae <supplied reason="lost">habe</supplied>ntur hic in <lb n="2"/>castello Mastarensi die <lb n="3"/>III <expan><abbr>Kal</abbr><ex>endarum</ex></expan> <expan><abbr>Septemb</abbr><ex>rium</ex></expan> primarum <lb n="4"/>et die III Idu<expan><ex>u</ex><abbr>m</abbr></expan> Septembrium <lb n="5"/><supplied reason="lost">s</supplied>ubsequentium et deinceps <lb n="6"/>suo quoque mense ex per<lb break="no" n="7"/>missu <lb n="8"/><expan><abbr>M</abbr><ex>arci</ex></expan> Aureli Comini Cas<lb break="no" n="9"/>siani <expan><abbr>leg</abbr><ex>ati</ex></expan> Aug<del rend="erasure"><expan><abbr>g</abbr><ex>ustorum</ex></expan></del> <expan><abbr>pr</abbr><ex>o</ex></expan> <expan><abbr>pr</abbr><ex>aetore</ex></expan> <lb n="10"/><expan><abbr>c</abbr><ex>larissimi</ex></expan> <expan><abbr>v</abbr><ex>iri</ex></expan>
            </ab></div>
            <div type="commentary">
                <p>Datierung: M. Aurelius Cominius Cassianus war 247/248 n. Chr. Statthalter von Numidien.</p>
            </div>
