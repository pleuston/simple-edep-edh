                <supplied reason="lost">Pro salute</supplied> <expan><abbr>Impp</abbr><ex>eratorum</ex></expan> <expan><abbr>ff</abbr><ex>elicium</ex></expan> <expan><abbr>d<am>d</am></abbr><ex>ominorum</ex></expan> <expan><abbr>n<am>n</am></abbr><ex>ostrorum</ex></expan> Carini e<supplied reason="lost">t Numeriani</supplied> <lb n="2"/><supplied reason="lost">divi Cari</supplied> genitoris eorum tem<supplied reason="lost">plum a funda</supplied><lb break="no" n="3"/>mentis <expan><abbr>r</abbr><ex>es</ex></expan> <expan><abbr>p</abbr><ex>ublica</ex></expan> <expan><abbr>mun</abbr><ex>icipum</ex></expan> Verecundensium consti<supplied reason="lost">tuit dedicante</supplied> <lb n="4"/><supplied reason="lost"><expan><abbr>M</abbr><ex>arco</ex></expan> Aurelio</supplied> Decimo <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <expan><abbr>p</abbr><ex>raeside</ex></expan> <expan><abbr>p</abbr><ex>rovinciae</ex></expan> <expan><abbr>N</abbr><ex>umidiae</ex></expan>
