                Magniae Ur<lb break="no" n="2"/>bicae <expan><abbr>Aug</abbr><ex>ustae</ex></expan> con<lb break="no" n="3"/>iugi <expan><abbr>d</abbr><ex>omini</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>Aure</abbr><ex>li</ex></expan> <lb n="4"/>Carini <expan><abbr>Aug</abbr><ex>usti</ex></expan> ma<lb break="no" n="5"/>tri castrorum <lb n="6"/>ordo splen<lb break="no" n="7"/>didissimus <lb n="8"/><expan><abbr>col</abbr><ex>oniae</ex></expan> Lambae<lb break="no" n="9"/>sitanorum <lb n="10"/><expan><abbr>devot</abbr><ex>us</ex></expan> <expan><abbr>numm</abbr><ex>inibus</ex></expan> <lb n="11"/><expan><abbr>eor</abbr><ex>um</ex></expan> <expan><abbr>dedic</abbr><ex>ante</ex></expan> <lb n="12"/><expan><abbr>M</abbr><ex>arco</ex></expan> Aurel<supplied reason="lost">i</supplied>o Deci<lb break="no" n="13"/>mo <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <expan><abbr>p</abbr><ex>raeside</ex></expan> <expan><abbr>p</abbr><ex>rovinciae</ex></expan> <expan><abbr>Numid</abbr><ex>iae</ex></expan>
            </ab></div>
