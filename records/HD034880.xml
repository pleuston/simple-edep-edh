                <expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Ulp</abbr><ex>ius</ex></expan> Romulus <expan><abbr>CO</abbr><ex cert="low"/></expan><gap reason="lost" extent="unknown" unit="character"/>
