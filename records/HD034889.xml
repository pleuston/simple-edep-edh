            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Aur</abbr><ex>elius</ex></expan> Fortuni<lb break="no" n="2"/>us pet<expan><ex>i</ex><abbr>tu</abbr><ex>s</ex></expan> a con<lb break="no" n="3"/>iuge sua <expan><abbr>Aur</abbr><ex>elia</ex></expan> <lb n="4"/>Vernantilla <lb n="5"/>sorori su<expan><ex>a</ex><abbr>e</abbr></expan> Urs<expan><ex>a</ex><abbr>e</abbr></expan> <lb n="6"/>qu<expan><ex>a</ex><abbr>e</abbr></expan> vixit ex cari<lb break="no" n="7"/>tate eorum sene <note>sic</note> ullo <lb n="8"/>devitum <note>sic</note> <expan><abbr>Aur</abbr><ex>elius</ex></expan> Fortuni<lb break="no" n="9"/>us concessit <expan><abbr>locu</abbr><ex>m</ex></expan> <lb n="10"/>si quis autem filio me<lb break="no" n="11"/>o Ver&amp;lt;n=M&amp;gt;a<expan><ex>n</ex><abbr>tiano</abbr></expan> post o<lb break="no" n="12"/>vitum <note>sic</note> eorum Ursa Ver<lb break="no" n="13"/>nantilla Fortunium quin<lb break="no" n="14"/>tum ponere voluerit da<lb break="no" n="15"/>vit <note>sic</note> ec<expan><ex>c</ex><abbr>lesi</abbr><ex>a</ex><abbr>e</abbr></expan> <expan><abbr>argen</abbr><ex>ti</ex></expan> <expan><abbr>po</abbr><ex>ndo</ex></expan> V 
