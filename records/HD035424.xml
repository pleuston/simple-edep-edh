                <gap reason="lost" extent="unknown" unit="character"/> <expan><abbr>dec</abbr><ex>urio</ex></expan> augur porticum <expan><abbr>t</abbr><ex>estamento</ex></expan> <expan><abbr>f</abbr><ex>ieri</ex></expan> <expan><abbr>i</abbr><ex>ussit</ex></expan> ex HS <expan><abbr>LXXX</abbr><ex>octoginta milibus</ex></expan>
