                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="2"/>Iunoni Reginae <lb n="3"/><expan><abbr>G</abbr><ex>aius</ex></expan> Vitalinius <lb n="4"/>Floren<supplied reason="lost">t</supplied>inus <lb n="5"/>et Luciliania <lb n="6"/>Honorata <lb n="7"/>coniux <lb n="8"/><expan><abbr>f</abbr><ex>ecerunt</ex></expan>
