                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="2"/><expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Val</abbr><ex>erius</ex></expan> Florus <lb n="3"/>et Ursa Spera<lb break="no" n="4"/>ti ex voto <lb n="5"/><expan><abbr>p</abbr><ex>osuerunt</ex></expan>
