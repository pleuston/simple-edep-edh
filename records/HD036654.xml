            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="0"/>
                <gap reason="lost" quantity="1" unit="line"/>ΤΑI <lb n="1"/><gap reason="lost" extent="unknown" unit="character"/>εῖον παρὰ τῷ <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> τε καὶ τοῖς τὰ σώ<lb break="no" n="3"/><supplied reason="lost">ματα καὶ τὰ θρέ</supplied>μματα πωλοῦσι<supplied reason="lost">ν</supplied> <lb n="4"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> ἀγορά</supplied>ζουσιν· ἄλλως μή<lb break="no" n="5"/><supplied reason="lost">τε πωλεῖν<certainty locus="name" match="preceding-sibling::text()" cert="low"/> μή</supplied>τε ἀγοράζειν Ε<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied> <lb n="6"/><gap reason="lost" extent="unknown" unit="character"/>Ν ἀπογράψωντα<supplied reason="lost">ι</supplied> <lb n="7"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> ἐὰν δέ</supplied> τις πωλῇ σώματα, <lb n="8"/><gap reason="lost" extent="unknown" unit="character"/> τὴν ὠνὴν καταγρα<lb break="no" n="9"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> τὴν δὲ<certainty locus="name" match="preceding-sibling::text()" cert="low"/> ἀ</supplied>νάκρισιν αὐτῶ<supplied reason="lost">ν</supplied> <lb n="10"/><supplied reason="lost">γίνεσθαι διὰ<certainty locus="name" match="preceding-sibling::text()" cert="low"/> τῶ</supplied>ν ἀρχόντων· ὃ<supplied reason="lost">ς</supplied> <lb n="11"/><supplied reason="lost">δὲ μὴ κατὰ τα</supplied>ῦτα ποιήσῃ ἢ μὴ <lb n="12"/><gap reason="lost" extent="unknown" unit="character"/>ται ἢ μὴ ἀνα<supplied reason="lost">κρ</supplied>είνη<lb break="no" n="13"/><supplied reason="lost">ται<certainty locus="name" match="preceding-sibling::text()" cert="low"/> κατὰ τὰ ν</supplied>ενομοθ<supplied reason="lost">ε</supplied>τημένα, <lb n="14"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> τῷ</supplied> τελώνῃ τὸ τέλος <lb n="15"/><gap reason="lost" extent="unknown" unit="character"/>Ν, καθὼς Καυά<lb break="no" n="16"/><supplied reason="lost">ριος <gap reason="lost" extent="unknown" unit="character"/></supplied>ων ὑπατικὸς <lb n="17"/><supplied reason="lost">ἐπέκ</supplied>ρεινεν. <lb n="18"/><supplied reason="lost">Εὐτυ</supplied>χεῖται.
