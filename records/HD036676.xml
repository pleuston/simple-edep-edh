                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Meddillio <lb n="3"/>Caranto patri <lb n="4"/>et Victorinae <lb n="5"/>matri Carantia <lb n="6"/>Aelia filia dulc<lb break="no" n="7"/>issima heres <lb n="8"/>ex testamento <lb n="9"/>pos<expan><ex>u</ex><abbr>it</abbr></expan>
