    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <supplied reason="lost">Ὁ</supplied> δῆμο<supplied reason="lost">ς ὁ τῶν Κνι</supplied><lb break="no" n="2"/><supplied reason="lost">δίων τ</supplied>ὴ<supplied reason="lost">ν ἐπικράτειαν καὶ τὴν ἀρ</supplied>χὴν τοῦ <supplied reason="lost">δήμου το</supplied>ῦ <supplied reason="lost">Ῥωμαίων</supplied> <lb n="3"/><supplied reason="lost">οὕτω διαφυλασσέτω ἀδόλως<certainty locus="name" match="preceding-sibling::text()" cert="low"/> ὡς ἀ</supplied>ντι<supplied reason="lost">κρατεῖν ὁ δῆμος ὁ τῶν Ῥωμαίων. Ὁ δῆμος ὁ τῶν Κνιδίων τοὺ</supplied>ς ὑ<supplied reason="lost">πεναντίους τοῦ δήμου τοῦ</supplied> <lb n="4"/><supplied reason="lost">Ῥωμαίων διὰ <gap reason="lost" extent="unknown" unit="character"/></supplied>. </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <gap reason="lost" extent="unknown" unit="character"/>ΑΙ<gap reason="lost" extent="unknown" unit="character"/>Σ<supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> Ῥω</supplied><lb break="no" n="2"/>μαίων ἄ<supplied reason="lost">ρχοντές</supplied> τε <supplied reason="lost">ἀντάρχο</supplied>ντες <supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/>, μήτε μὴν ἄρχον</supplied><lb break="no" n="3"/>τές τε ἀντάρ<supplied reason="lost">χοντ</supplied>ές τ<supplied reason="lost">ε Ῥωμα</supplied>ίων τοῦ<supplied reason="lost">το ποιεῖσθαι κελευέτωσαν μηδὲ</supplied> <lb n="4"/>ποιείτωσαν δόλωι <supplied reason="lost">πο</supplied>νη<supplied reason="lost">ρῶ</supplied>ι τοῦτο, <supplied reason="lost">ἀλλὰ κοινῆι βουλῆι δη</supplied><lb break="no" n="5"/><supplied reason="lost">μοσ</supplied>ίᾳ τηρείτωσαν, ὅπως ἑκατέρου τοῦ δ<supplied reason="lost">ήμου παρόντος τὸ δί</supplied><lb break="no" n="6"/><supplied reason="lost">κ</supplied>αιον τηρῆται· πρὸς τοῦτο το ὅρκιο<supplied reason="lost">ν ἐάν τι βούλωνται κοινῆι</supplied> <lb n="7"/>γνώμηι προσθεῖναι, ἐκ τούτου τε το<supplied reason="lost">ῦ ὁρκίου ἐάν τι ἐξελέσθαι</supplied>, <lb n="8"/>ἐξέστω· ὃ δὲ ἂν κατὰ ταῦτα προσθῶσι<supplied reason="lost">ν ἐν τούτωι τῶι ὁρκίωι</supplied>, <lb n="9"/>ἐνέστω, ὅ τε ἂν κατὰ ταῦτα ἐξέλω<supplied reason="lost">νται, τοῦτο ἐκτὸς τούτου τε</supplied> <lb n="10"/>τοῦ ὁρκίου ἔστω<surplus>ι</surplus>· τούτῳ τ<supplied reason="lost">ῷ ὁ</supplied>ρκίῳ <gap reason="lost" extent="unknown" unit="character"/>.
            </ab></div></div>
