                <expan><abbr>Ael</abbr><ex>ius</ex></expan> Cesumari<lb break="no" n="2"/>us Libbonis <supplied reason="lost"><expan><abbr>f</abbr><ex>ilius</ex></expan></supplied> <lb n="3"/>sibi et co<expan><ex>n</ex><abbr>iug</abbr></expan><supplied reason="lost">i</supplied> <lb n="4"/>et filio vivo <lb n="5"/>posuit
