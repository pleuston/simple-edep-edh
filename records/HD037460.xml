                <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar di<supplied reason="lost">vi Tra</supplied><lb break="no" n="2"/>iani Parthici <expan><abbr>fil</abbr><ex>ius</ex></expan> div<supplied reason="lost">i Nervae</supplied> <lb n="3"/>nepos Traianus H<supplied reason="lost">adrianus</supplied> <lb n="4"/><expan><abbr>Aug</abbr><ex>ustus</ex></expan> pontifex ma<supplied reason="lost">ximus</supplied> <lb n="5"/>tribunicia potes<supplied reason="lost">tate</supplied> <lb n="6"/>XVII co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> III <supplied reason="lost"><expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> per</supplied> <lb n="7"/><expan><abbr>leg</abbr><ex>ionem</ex></expan> II <supplied reason="lost"><expan><abbr>ad</abbr><ex>iutricem</ex></expan> <expan><abbr>p</abbr><ex>iam</ex></expan> <expan><abbr>f</abbr><ex>idelem</ex></expan></supplied> <lb n="8"/><supplied reason="lost" cert="low">col(oniam) Aeliam Mursam fec(it)</supplied>
            </ab></div>
