            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Iovi Sarso <expan><abbr>Sex</abbr><ex>tus</ex></expan> Vibi<lb break="no" n="2"/>us Gallus tr&amp;lt;i=E&amp;gt;c&amp;lt;e=I&amp;gt;nari<lb break="no" n="3"/>us primipilaris <expan><abbr>preaf</abbr><ex>ectus</ex></expan> kas<lb break="no" n="4"/><expan><abbr>tror</abbr><ex>um</ex></expan> <lb n="5"/><expan><abbr>leg</abbr><ex>ionis</ex></expan> XIII <expan><abbr>g</abbr><ex>eminae</ex></expan> <surplus>g</surplus> donis do<lb break="no" n="6"/>natus ab <expan><abbr>Imperatorib</abbr><ex>us</ex></expan> ho<lb break="no" n="7"/>noris <expan><abbr>virtutisq</abbr><ex>ue</ex></expan> causa <lb n="8"/><expan><abbr>torquib</abbr><ex>us</ex></expan> armillis phale<lb break="no" n="9"/>ris coronis <expan><abbr>muralib</abbr><ex>us</ex></expan> III <expan><abbr>vallarib</abbr><ex>us</ex></expan> II aurea I has<lb break="no" n="10"/>tis puris V vexillis II <expan><abbr>d</abbr><ex>e</ex></expan> <expan><abbr>s</abbr><ex>ua</ex></expan> <expan><abbr>p</abbr><ex>ecunia</ex></expan> <expan><abbr>f</abbr><ex>ecit</ex></expan> 
            </ab></div>
