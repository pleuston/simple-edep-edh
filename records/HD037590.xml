                <expan><abbr>L</abbr><ex>ucius</ex></expan> Aemilius <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>nep</abbr><ex>os</ex></expan> <expan><abbr>Quir</abbr><ex>ina</ex></expan> Rectus domo Roma <lb n="2"/>qui et Carthaginensis et <expan><abbr>Sicellitan</abbr><ex>us</ex></expan> et <expan><abbr>Assotan</abbr><ex>us</ex></expan> et <expan><abbr>Lacedaemon</abbr><ex>ius</ex></expan> <lb n="3"/>et Argivus et Bastetanus <expan><abbr>scrib</abbr><ex>a</ex></expan> quaestorius <expan><abbr>scrib</abbr><ex>a</ex></expan> aedilicius civis <lb n="4"/>adlectus ob honorem aedilitatis hoc opus testamento suo fieri iussit
            </ab></div>
