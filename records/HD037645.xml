                Argentaria <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>f</abbr><ex>ilia</ex></expan> <expan><abbr>Faustil</abbr><ex>la</ex></expan> <lb n="2"/>octavos cum iterum aetatis <lb n="3"/>mihi curreret annus rapta <lb n="4"/>conplexu <note>sic</note> coniugis hic iaceo <lb n="5"/>cura quibus ius fasque fuit sola<lb break="no" n="6"/>cia mortis haec habeo vitae <lb n="7"/>praemia quae tuleram hunc <lb n="8"/>mihi defunctae monimenti in<lb break="no" n="9"/>pendit honorem mater et incu<lb break="no" n="10"/>ras ipsa Nigella suas
            </ab></div>
