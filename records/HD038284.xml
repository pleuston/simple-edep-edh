            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> et Iunoni <expan><abbr>Regin</abbr><ex>ae</ex></expan> <lb n="2"/>pro <expan><abbr>sal</abbr><ex>ute</ex></expan> <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>Aur</abbr><ex>eli</ex></expan> An<lb break="no" n="3"/>tonini Pii <expan><abbr>Aug</abbr><ex>usti</ex></expan> et <lb n="4"/>Iuliae <expan><abbr>Aug</abbr><ex>ustae</ex></expan> matris <expan><abbr>Aug</abbr><ex>usti</ex></expan> <lb n="5"/><expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Ulp</abbr><ex>ius</ex></expan> Mucianus <expan><abbr>mil</abbr><ex>es</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> XIII <expan><abbr>gem</abbr><ex>inae</ex></expan> <lb n="6"/><expan><abbr>horologiar</abbr><ex cert="low">ium</ex></expan> templum a solo ex voto <lb n="7"/>fecit Falcone et Claro <expan><abbr>cons</abbr><ex>ulibus</ex></expan>
            </ab></div>
