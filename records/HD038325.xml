                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> Doliche<lb break="no" n="2"/>no pro salute <lb n="3"/><expan><abbr>Imperator</abbr><ex cert="low">um</ex></expan> <lb n="4"/><expan><abbr>Ael</abbr><ex>ius</ex></expan> Valentinus <expan><abbr>vet</abbr><ex>eranus</ex></expan> <lb n="5"/>sacerdos <lb n="6"/><expan><abbr>templ</abbr><ex>um</ex></expan> impendio suo <lb n="7"/>restituit
