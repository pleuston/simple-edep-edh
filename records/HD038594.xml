                <expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Mog</abbr><ex cert="low">ius</ex></expan> Valentinus Vibi <expan><abbr>f</abbr><ex>ilius</ex></expan> et <expan><abbr>Mog</abbr><ex cert="low">ia</ex></expan> <lb n="2"/>Iustina <expan><abbr>con</abbr><ex>iux</ex></expan> <expan><abbr>v</abbr><ex>ivi</ex></expan> <expan><abbr>f</abbr><ex>ecerunt</ex></expan> <expan><abbr>sib</abbr><ex>i</ex></expan> et <expan><abbr>Mog</abbr><ex cert="low">io</ex></expan> Urso <expan><abbr>f</abbr><ex>ilio</ex></expan> <expan><abbr>mil</abbr><ex>iti</ex></expan> <lb n="3"/>c<expan><ex>o</ex><abbr>hor</abbr></expan><supplied reason="lost">ti</supplied>s I <expan><abbr>Brit</abbr><ex>tonum</ex></expan> <expan><abbr>an</abbr><ex>norum</ex></expan> XXX
