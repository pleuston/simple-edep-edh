                <expan><abbr>Q</abbr><ex>uintus</ex></expan> Veratius Honoratus <expan><abbr>dec</abbr><ex>urio</ex></expan> <expan><abbr>Iul</abbr><ex>i</ex></expan> <lb n="2"/><expan><abbr>Carn</abbr><ex>ici</ex></expan> sibi et Paganiae <supplied reason="lost">P</supplied>iae <expan><abbr>ux</abbr><ex>ori</ex></expan> <expan><abbr>opt</abbr><ex>imae</ex></expan> et <lb n="3"/><expan><abbr>Q</abbr><ex>uintus</ex></expan> Veratius Iuventianus sibi et Cae<lb break="no" n="4"/>liae <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>f</abbr><ex>iliae</ex></expan> Ritullae <expan><abbr>uxor</abbr><ex>i</ex></expan> pud<supplied reason="lost">e</supplied>ntis<lb break="no" n="5"/>simae
