                Autoscutto <lb n="2"/>Montissi <expan><abbr>f</abbr><ex>ilio</ex></expan> et <lb n="3"/>Septimae Ressimari <expan><abbr>f</abbr><ex>iliae</ex></expan> <lb n="4"/>uxori <expan><abbr>f</abbr><ex>ilii</ex></expan> <expan><abbr>f</abbr><ex>ecerunt</ex></expan>
