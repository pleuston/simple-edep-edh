                <expan><abbr>L</abbr><ex>ucio</ex></expan> Valerio <expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> Ga<supplied reason="lost"><expan><abbr>l</abbr><ex>eria</ex></expan></supplied> <lb n="2"/>Propinquo <lb n="3"/>omnibus ho<lb break="no" n="4"/>noribus in <expan><abbr>r</abbr><ex>e</ex></expan> <lb n="5"/><expan><abbr>p</abbr><ex>ublica</ex></expan> sua functo <lb n="6"/>adlecto in V <lb n="7"/>decurias fla<lb break="no" n="8"/>mini <expan><abbr>p</abbr><ex>rovinciae</ex></expan> <expan><abbr>H</abbr><ex>ispaniae</ex></expan> <expan><abbr>c</abbr><ex>iterioris</ex></expan> <lb n="9"/>Gamus et <lb n="10"/>Trophime <expan><abbr>lib</abbr><ex>erti</ex></expan> <lb n="11"/>patrono optimo <lb n="12"/>et indulgentissimo
