                <gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost">Silva</supplied>no <expan><abbr>Aug</abbr><ex>usto</ex></expan> <expan><abbr>sac</abbr><ex>rum</ex></expan> <lb n="2"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan></supplied> <expan><abbr>m</abbr><ex>erito</ex></expan>
