                <expan><abbr>L</abbr><ex>ucius</ex></expan> Semproni<lb break="no" n="2"/>us Catuma<lb break="no" n="3"/>rus <expan><abbr>an</abbr><ex>norum</ex></expan> L Sem<lb break="no" n="4"/>pronius Iustus <lb n="5"/><expan><abbr>an</abbr><ex>norum</ex></expan> XX <expan><abbr>h</abbr><ex>ic</ex></expan> <expan><abbr>s</abbr><ex>iti</ex></expan> <expan><abbr>s</abbr><ex>unt</ex></expan> Sem<lb break="no" n="6"/>pronia Catta <expan><abbr>v</abbr><ex cert="low">iva</ex></expan> <lb n="7"/>sibi et coniugi <lb n="8"/>filio pos<expan><ex>u</ex><abbr>it</abbr></expan> his opto <lb n="9"/>terram levem
