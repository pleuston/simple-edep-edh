            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Mem</abbr><ex>oriae</ex></expan> <lb n="2"/><expan><abbr>G</abbr><ex>aius</ex></expan> <expan><abbr>Iul</abbr><ex>ius</ex></expan> Sergi<expan><ex>u</ex><abbr>s</abbr></expan> <lb n="3"/>vivo suo po<lb break="no" n="4"/>suit sibi et <lb n="5"/>coni<expan><ex>u</ex><abbr>gi</abbr></expan> suae The<lb break="no" n="6"/><expan><abbr>agenia</abbr><ex>e</ex></expan> qui vi<lb break="no" n="7"/>xit annis XXXXV <lb n="8"/>et filio suo Theo<lb break="no" n="9"/>doriano qui vixit <lb n="10"/>an<expan><ex>n</ex><abbr>is</abbr></expan> XXVI et fili<expan><ex>a</ex><abbr>e</abbr></expan> <note>sic</note> su<lb break="no" n="11"/>ae <note>sic</note> Cocceiani <note>sic</note> qui vi<supplied reason="lost">xit</supplied> <lb n="12"/>annis XXII et fili<expan><ex>a</ex><abbr>e</abbr></expan> <note>sic</note> <expan><abbr>su</abbr><ex>a</ex></expan><lb break="no" n="13"/>e <note>sic</note> Sergiani <note>sic</note> qui vi<lb break="no" n="14"/>xit annis IIII b<supplied reason="lost">e</supplied>n<supplied reason="lost">e</supplied> <lb n="15"/>merentibus <supplied reason="lost">posu</supplied><lb break="no" n="16"/>it ave viator et <lb n="17"/>vale
            </ab></div>
