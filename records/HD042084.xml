            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <gap reason="lost" extent="unknown" unit="character"/>ΛΩΙΙ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="2"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> κίου Ταρσέ</supplied>ως κωμῳδοῦ π<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="3"/><gap reason="lost" extent="unknown" unit="character"/>ου χοραύλου παρ<supplied reason="lost">αδόξου <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="4"/><gap reason="lost" extent="unknown" unit="character"/>ος Καισαρέως Τραλλ<supplied reason="lost">ιανοῦ χοραύλου <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="5"/><gap reason="lost" extent="unknown" unit="character"/>κιος Ταρσεὺς κωμ<supplied reason="lost">ῳδὸς <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="6"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> πρωτάρχων τῆς</supplied> ἐν Ῥώμῃ ἱερᾶς συν<supplied reason="lost">όδου <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="7"/><gap reason="lost" extent="unknown" unit="character"/> χοραύλης, γʹ καπετ<supplied reason="lost">ωλιονείκης <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="8"/><gap reason="lost" extent="unknown" unit="character"/> υἱός, ἄρχων συνό<supplied reason="lost">δου <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="9"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> Καισαρεὺς</supplied> Τραλλιανὸς χορ<supplied reason="lost">αύλης <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="10"/><gap reason="lost" extent="unknown" unit="character"/> σεβαστονείκη<supplied reason="lost">ς <gap reason="lost" extent="unknown" unit="character"/></supplied>.
