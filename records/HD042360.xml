                <expan><abbr>L</abbr><ex>ucius</ex></expan><certainty match="preceding-sibling::node()" locus="value"/> <expan><abbr>Vir</abbr><ex>ius</ex></expan> <gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/>@(obit-) et <expan><abbr>L</abbr><ex>ucius</ex></expan> <expan><abbr>Vir</abbr><ex>ius</ex></expan> Maximia<lb break="no" n="3"/>nus <expan><abbr>dec</abbr><ex>urio</ex></expan> et IIvir <expan><abbr>Cl</abbr><ex>audi</ex></expan> <lb n="4"/><expan><abbr>Iuv</abbr><ex>avi</ex></expan> et <expan><abbr>Vir</abbr><ex>ia</ex></expan> Modera<lb break="no" n="5"/>ta et sibi vivi fece<lb break="no" n="6"/>runt
