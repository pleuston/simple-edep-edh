                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <expan><abbr>Dol</abbr><ex>icheno</ex></expan> <supplied reason="lost">pro salute</supplied> <lb n="2"/><expan><abbr>M</abbr><ex>arci</ex></expan> <expan><abbr>Aur</abbr><ex>eli</ex></expan> Anto<lb break="no" n="3"/>nini Pii <expan><abbr>Aug</abbr><ex>usti</ex></expan> et <expan><abbr>Iul</abbr><ex>iae</ex></expan> <lb n="4"/>Domn<expan><ex>a</ex><abbr>e</abbr></expan> <expan><abbr>Aug</abbr><ex>ustae</ex></expan> ma<lb break="no" n="5"/><expan><abbr>tri</abbr><ex>s</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> et castro<lb break="no" n="6"/>rum dedicante <expan><abbr>L</abbr><ex>ucio</ex></expan> <lb n="7"/>Mario Perpetuo <lb n="8"/><expan><abbr>c</abbr><ex>onsulari</ex></expan> per Restutum <lb n="9"/><expan><abbr>m</abbr><ex cert="low">agistrum</ex></expan> <expan><abbr>c</abbr><ex cert="low">ivium</ex></expan> <expan><abbr>R</abbr><ex cert="low">omanorum</ex></expan> <expan><abbr>D</abbr><ex cert="low">ianae</ex></expan> sacerdo<lb break="no" n="10"/>tes eiusdem loci <lb n="11"/><expan><abbr>d</abbr><ex>edicaverunt</ex></expan>
            </ab></div>
