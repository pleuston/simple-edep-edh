            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Ἀ<supplied reason="lost">γ</supplied>α<supplied reason="lost">θῇ Τύχῃ</supplied> <lb n="2"/>ΘΙ<gap reason="lost" extent="unknown" unit="character"/> <lb n="3"/>Ἐπειδὴ Κλαύδιος Σαιθίδα<supplied reason="lost">ς <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="4"/>ἡμῶν ἀρχιερεὺς τῶν Σεβα<supplied reason="lost">στῶν <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="5"/>καὶ Ἑλλαδάρχης, ἀνὴρ <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΙΟ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="6"/>μενος ὢν τὴν ἀληθῆ φύ<supplied reason="lost">σιν <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="7"/>τοῦ βίου πατρός τε πλεισ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="8"/>σαντος καὶ βαλανεῖα δὲ ἀνα<gap reason="lost" extent="unknown" unit="character"/> <lb n="9"/>τῶν ἱερῶν, τὸ δὲ ἐπὶ τῆς πόλ<supplied reason="lost">εως <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="10"/>λαμπροτάτας ἅτινα δῶρα οὐ <gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="11"/>τεύσατο μητρός τε πρωτε<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="12"/>η τὴν ἰδίαν ἀξίαν καὶ μεγαλοφρ<supplied reason="lost">οσύνην <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="13"/>τὸ μὲν ἔμψυχον ἀνάθημα καὶ <gap reason="lost" extent="unknown" unit="character"/> <lb n="14"/>τὸν ἀρχιερέα σὺν δὲ αὐτῷ καὶ Π<gap reason="lost" extent="unknown" unit="character"/> <lb n="15"/>μέγιστον ὁ πᾶς ὁ πρὸ ἡμῶν χρό<supplied reason="lost">νος <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="16"/>σαι κατηρειμμένον τὸ προσκήνιον <gap reason="lost" extent="unknown" unit="character"/> <lb n="17"/>τὴν ἐπανγελίαν ὑπέσχετο ε<gap reason="lost" extent="unknown" unit="character"/> <lb n="18"/>τέκνῳ δὲ τὴν ἐλπίδα τῆς με<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="19"/>αν χάριν ἔτι ζῶσα καὶ ἐπιγραψ<gap reason="lost" extent="unknown" unit="character"/> <lb n="20"/>τις ἡγούμενος βεβαιότερον ει<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="21"/>τα καὶ πράττειν καὶ λέγειν ΟΔΕΗΓΟ<gap reason="lost" extent="unknown" unit="character"/> <lb n="22"/>ἡλικίας γυμνάσια νομίσας γραμμ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="23"/>ας πλήρη διαδεξάμενος ΟΥΧΟΥ<gap reason="lost" extent="unknown" unit="character"/> <lb n="24"/>ἔργον ἐφιλοτιμήθη πρὸς τὰ μεγ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="25"/>μενος, τοῖς δὲ ἐρίσας οὐδεμιᾶς <gap reason="lost" extent="unknown" unit="character"/> <lb n="26"/>δῶρον ὅσην εἶχεν ἰσχὺν ἐπιστι<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="27"/>γον ὡς μηδενὸς ΕΣΤΟΧΑΣΟΑΔΟΚΕ<supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> πε</supplied><lb break="no" n="28"/>ριφανὲς ὡς ἀπαρκεῖν καὶ ΜΙΑΜΕ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>ΑΣΞΕΙ<gap reason="lost" extent="unknown" unit="character"/> <lb n="29"/>τε ποικιλωτάτων ἀπὸ πάσης ὡς εἰπεῖν <gap reason="lost" extent="unknown" unit="character"/> <lb n="30"/>τέχνης ἐντελοῦς αὐτὰ διαθείσης ΩΣΟ<gap reason="lost" extent="unknown" unit="character"/> <lb n="31"/>πλέον ὧν ὁρᾶσθαι καὶ ἀνάλωμα καὶ μέγεθο<supplied reason="lost">ς <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="32"/>ὑπάρχειν οὐδὲ ψηφίσαι τήν χάριτα καὶ ΟΥΚ<gap reason="lost" extent="unknown" unit="character"/> <lb n="33"/>δῶρον, ἀλλὰ αἰδούμενος τοῦ θ<supplied reason="lost">εάτ</supplied>ρου τὴν ὑπὸ τῷ προσκην<supplied reason="lost">ίῳ <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="34"/>εὐτυχῶς ὑμεῖν καὶ κατ' εὐχ<supplied reason="lost">ὴν γε</supplied>γεννηκὼς ἐκ γυναικὸ<supplied reason="lost">ς <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="35"/>Φροντείνης τὸν Τιβέριον <supplied reason="lost">Κλ</supplied>αύδιον <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied> ΑΚΑ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΡΟΝΙ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="36"/>νον ὑπὲρ αὐτὸν ὐπέσ<supplied reason="lost">χε</supplied>το ΤΙ<gap reason="lost" extent="unknown" unit="character"/>ΡΑΝ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="37"/>ην καὶ πεπόηκεν ἀνδρῶν <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΔΗΤΕ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="38"/>σαν ὥσπερ δὲ πρὸς ἄλλο<gap reason="lost" extent="unknown" unit="character"/> <lb n="39"/>καθ' ἕκαστον ἀγωνιζόμεν<supplied reason="lost">ον <gap reason="lost" extent="unknown" unit="character"/></supplied><lb break="no" n="40"/>κὼς οὐ μόνον ἱερωσύνην <gap reason="lost" extent="unknown" unit="character"/> <lb n="41"/>ἀλλὰ καὶ τὴν τῆς Ἑλλάδος ἐπεθυ<gap reason="lost" extent="unknown" unit="character"/>
