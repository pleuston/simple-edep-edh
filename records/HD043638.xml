            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <supplied reason="lost">Ἀγαθῆι</supplied> Τύχηι. <lb n="2"/><supplied reason="lost">Αὐτοκρά</supplied>τορα Καίσαρα <lb n="3"/><supplied reason="lost">Λούκιον Σεπτί</supplied>μιον Σευῆρον <lb n="4"/>Περτίνακα Σεβαστόν, <lb n="5"/>οἱ τοῦ Ϛʹ ἔτους τῶν <supplied reason="lost">φ</supplied>υλῶν ἄρχοντες. </ab></div><div n="2" type="textpart"><ab><lb n="1"/> φυλῆς Τραια<lb break="no" n="2"/><supplied reason="lost">ν</supplied>ῆς φύ(λαρχος) Δομιτια<lb break="no" n="3"/><supplied reason="lost">νὸ</supplied>ς Δομιτίου, <lb n="4"/><supplied reason="lost">στρ(ατηγὸς) Μάρ</supplied>κελλος <lb n="5"/><supplied reason="lost">Μαρκέλ</supplied>λου. <supplied reason="lost">φυλῆς Σεβ</supplied>αστῆς <lb n="6"/><supplied reason="lost" cert="low">φύ(λαρχος) Χρῦσος</supplied> Χρύ<lb break="no" n="7"/><supplied reason="lost">σου, στρ(ατηγὸς) Χρ</supplied>υσιανὸς <lb n="8"/><supplied reason="lost">Χρυσια</supplied>νοῦ. <lb n="9"/><supplied reason="lost">φυλῆς Διο</supplied>νυσι<supplied reason="lost">άδος</supplied> φ(ύλαρχος) Γάιος <lb n="10"/>ΙΟ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>Π<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>, <supplied reason="lost">στρ(ατηγὸς)</supplied> Ἑρμο<lb break="no" n="11"/><supplied reason="lost">γέ</supplied>νη<supplied reason="lost">ς</supplied> Ῥοδω<lb break="no" n="12"/>νιανοῦ. <lb n="13"/><supplied reason="lost">φ</supplied>υλῆς Ἀπολλω<lb break="no" n="14"/><supplied reason="lost">ν</supplied>είδος φύ(λαρχος) Δῆμος <lb n="15"/>Γνησιουλανοῦ, <lb n="16"/><supplied reason="lost">σ</supplied>τρ(ατηγὸς) Ῥουφῖνος <lb n="17"/><supplied reason="lost">Π</supplied>αυλείνου. <lb n="18"/>φυλῆς Ἀντωνί<lb break="no" n="19"/>νης φύ(λαρχος) Χρύσιπο<lb break="no" n="20"/>ς Καικιλιανοῦ, <lb n="21"/><supplied reason="lost">στρ(ατηγὸς)</supplied> Κρισπεῖνος <lb n="22"/><supplied reason="lost">Π</supplied>ερ<supplied reason="lost">δ</supplied>ίκκου. <lb n="23"/>φυλῆς Ἑρμησιάδος <lb n="24"/>φύ(λαρχος) Βασιλείδης <lb n="25"/>Ἀντιπάτρου, στρ(ατηγὸς) <lb n="26"/>Δομίτι(ο)ς Βαριλ<lb break="no" n="27"/>λεῖνος. </ab></div><div n="3" type="textpart"><ab><lb n="1"/> φυλῆς Δίας φύ(λαρχος) <lb n="2"/>Χρυσιανὸς Μεν<lb break="no" n="3"/>άνδρου, στρ(ατηγὸς) Χρυσ<lb break="no" n="4"/><supplied reason="lost">ί</supplied>ων Χρυσίωνος. <lb n="5"/>φυλῆς Δημητριάδος <lb n="6"/>φύ(λαρχος) Ἀκύλας Ἀκύλο<supplied reason="lost">υ</supplied>, <lb n="7"/>στρ(ατηγὸς) Ἀριστείδης <lb n="8"/>Ἀριστοκράτους, <lb n="9"/>γυ(μνασίαρχος) Σεραπίων Δο<lb break="no" n="10"/>μιτίου. <lb n="11"/>φυλῆς Ἀσκληπ<supplied reason="lost">ι</supplied><lb break="no" n="12"/>άδος φύ(λαρχος) Σοῦσος <lb n="13"/>Σούσου, στρ(ατηγὸς) Ἡρα<lb break="no" n="14"/>κλείδης Δειφίλου. <lb n="15"/>φυλῆς Ἁδριανῆς <lb n="16"/>Λόνγος Λόνγου, <lb n="17"/>στρ(ατηγὸς) Φιλιππιανὸ<supplied reason="lost">ς</supplied> <lb n="18"/>Φιλιππιανοῦ. <lb n="19"/>φυλῆς Ἀντινοίδος <lb n="20"/>φύ(λαρχος) Γναῖ(ος) Φλάβιος <lb n="21"/>Εὐσχήμων, σ<supplied reason="lost">τρ(ατηγὸς)</supplied> <lb n="22"/>Ἀρχέλαος Ἀρχέ<lb break="no" n="23"/>λαου. <lb n="24"/>φυλῆς Αὐρηλιαν<supplied reason="lost">ῆς</supplied> <lb n="25"/>φύ(λαρχος) Ἀσκληπιόδοτος <lb n="26"/>Μά<surplus>ν</surplus>γνου, στρ(ατηγὸς) <lb n="27"/>Αἴλιος Μαρκιανός. <lb n="28"/>Κλ(αύδιος) Ἀντωνῖνος <lb n="29"/>στρατηγὸς κατὰ πόλιν.
            </ab></div></div>
