        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost">ὑπὲρ σωτηρίας καὶ ὐγιήας</supplied> <lb n="2"/><supplied reason="lost">Αὐτοκράτορος Καίσαρος Θέω παῖδος</supplied> <lb n="3"/>Θέω <supplied reason="lost">Σεβάστω καὶ Γαίω Λουκίω Καισάρων</supplied>, <lb n="4"/>τῶν <supplied reason="lost">παίδων αὔτω, καὶ Θέας Σεβάστας Προνοίας</supplied> <lb n="5"/>Λειβί<supplied reason="lost">ας, Γάιος Κορνήλιος Γαίω<certainty locus="name" match="preceding-sibling::text()" cert="low"/> Κορνη</supplied><lb break="no" n="6"/>λίω Ζο<supplied reason="lost" cert="low">ίττα ὔιος --- τεμένεά τε καὶ ναύοις</supplied> <lb n="7"/>ἐκ τῶ<supplied reason="lost">ν ἰδίων κατεσκεύασεν καὶ καθιέρω</supplied><lb break="no" n="8"/>σεν καὶ <supplied reason="lost" cert="low">ἀγάλματα καὶ βώμοις ἀνέθηκεν</supplied>.
            </ab></div>
