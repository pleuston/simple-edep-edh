                <supplied reason="lost">Pro salute <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <expan><abbr>M</abbr><ex>arci</ex></expan> Aureli</supplied> <lb n="2"/>[Severi <del rend="erasure">Alexandri</del> Pii <expan><abbr>Fel</abbr><ex>icis</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> et] <lb n="3"/><del rend="erasure"><supplied reason="lost">Iul</supplied>iae M[amaeae</del> san]c<supplied reason="lost">tissi</supplied>mae <expan><abbr>Aug</abbr><ex>ustae</ex></expan> <lb n="4"/><del rend="erasure"><supplied reason="lost">m</supplied>atr[is</del> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan>] et cas<supplied reason="lost">tro</supplied>rum <lb n="5"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Luccei<supplied reason="lost">us</supplied> Fe<supplied reason="lost">li</supplied>x <expan><abbr><supplied reason="lost">pro</supplied>c</abbr><ex>urator</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>n</abbr><ex>ostri</ex></expan> <lb n="6"/><gap reason="lost" extent="unknown" unit="character"/>imu<gap reason="lost" quantity="1" unit="line"/> </ab></div><div n="2" type="textpart"><ab><lb n="0"/> <gap reason="lost" quantity="1" unit="line"/>mus <gap reason="lost" extent="unknown" unit="character"/>
