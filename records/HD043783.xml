            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Nymphi<supplied reason="lost">s</supplied> sanctis <lb n="2"/><expan><abbr>August</abbr><ex>is</ex></expan> simul et <lb n="3"/>tibi sancta Deana <lb n="4"/><expan><abbr>fontiq</abbr><ex>ue</ex></expan> vestro <lb n="5"/>ret<expan><ex>t</ex><abbr>ulit</abbr></expan> sua vo<lb break="no" n="6"/>ta libens salu<lb break="no" n="7"/>ti ter refirmatus <lb n="8"/>aquis <expan><abbr>Germis</abbr><ex cert="low">arae</ex></expan> <lb n="9"/><expan><abbr>M</abbr><ex>arcus</ex></expan> <expan><abbr>Aur</abbr><ex>elius</ex></expan> Theodo<lb break="no" n="10"/>tus <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan> <expan><abbr>Imp</abbr><ex>eratore</ex></expan> <lb n="11"/><expan><abbr>Comm</abbr><ex>odo</ex></expan> <supplied reason="lost">Fe</supplied>lice <expan><abbr>c</abbr><ex>onsule</ex></expan> VI VIII <expan><abbr>Kal</abbr><ex>endas</ex></expan> <expan><abbr>Com</abbr><ex>modas</ex></expan>
            </ab></div>
