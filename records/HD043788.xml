            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Ἡ βουλὴ καὶ ὁ δήμος ὁ Ἀρ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ιτῶν <lb n="2"/>ἐτίμησαν Μηνοδωριανὸν Μηνο<lb break="no" n="3"/>δώρου ἰατροῦ ὑὸν <gap reason="lost" extent="unknown" unit="character"/>ΝΕΝ<lb break="no" n="4"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>Η τὰ παιδία ἐ<supplied reason="lost">πὶ τῇ αὐτοῦ</supplied> ἀρε<lb break="no" n="5"/>τῇ καὶ οἰκοδεσ<supplied reason="lost">π</supplied>οσύνῃ. <lb n="6"/>ψήφισμα. <lb n="7"/>ἐπεὶ Μηνοδώρο<supplied reason="lost">υ Ἀ</supplied>πολλω<lb break="no" n="8"/>νίδου τοῦ καὶ Ὀ<supplied reason="lost">τα</supplied>κι<supplied reason="lost">λίου <gap reason="lost" extent="unknown" unit="character"/></supplied>ι <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied> <lb n="9"/>ὑοῦ ΠΛ<gap reason="lost" extent="unknown" unit="character"/>ΡΕΤ<gap reason="lost" extent="unknown" unit="character"/> προθυμίᾳ εὐ<lb break="no" n="10"/>εργετοῦντος καὶ κοσμοῦντος <lb n="11"/>τὴν πατρίδα ἔν τε ἐπιμελείᾳ <lb n="12"/>τῇ περὶ τὸ ἑκάστου τῶν πολει<lb break="no" n="13"/>τῶν σῶμα ΑΤΟ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>ΙΑΤΟΥ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied> κα<supplied reason="lost" cert="low">ὶ</supplied> <lb n="14"/>τὴν προαίρεσίν τ' ἀνδρὸς ΚΛ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied><lb break="no" n="15"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>στῆναι κατὰ τὴν Σεβαστε<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="16"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>ΑΞΙΑ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΩΤΟΝ εἰς ΑΡΙΘ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="17"/><gap reason="lost" extent="unknown" unit="character"/> ΤΗΣ<gap reason="lost" extent="unknown" unit="character"/><lb break="no" n="18"/><gap reason="lost" extent="unknown" unit="character"/>ΡΟΙ <gap reason="lost" quantity="1" unit="line"/>
