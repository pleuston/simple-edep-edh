    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Ἐπὶ τοῦ αἰδεσιμωτάτου <lb n="2"/>ἐπισκόπου Ὀπτίμο<supplied reason="lost">υ</supplied> <lb n="3"/>Εἰδομενεὺς ἀναγνώστη<supplied reason="lost">ς</supplied> <lb n="4"/>εὐξάμενος τῷ Θεῷ <lb n="5"/>τὴν εὐχὴν ἀπέδωκε. </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Ἐπὶ τοῦ αἰδεσ(ιμωτάτου) ἐπισ(κόπου) <lb n="2"/>Ὀπτίμου Εὐτυχιανὸς <lb n="3"/><supplied reason="lost">ε</supplied>ὐξάμενος ἐπλήρωσε <lb n="4"/><supplied reason="lost">τ</supplied>ὴν εὐχὴν τῷ Θεῷ. </ab></div><div n="3" type="textpart"><ab><lb n="1"/> Ἐπισκόπει δὲ <lb n="2"/>τῶν Ἀριανῶν Δημόφιλος Γρηγόριος, <lb n="3"/>διέλαμπεν δὲ Ὄπτιμος ἐν Πισιδίᾳ <lb n="4"/>καὶ Ἀμφιλόχιος ἐν Ἰκονίῳ. </ab></div><div n="4" type="textpart"><ab><lb n="1"/> Καὶ ε<supplied reason="lost">ἰσελεύ</supplied><lb break="no" n="2"/>σομ<supplied reason="lost">αι πρὸς</supplied> <lb n="3"/>τὸ θ<supplied reason="lost">υσιαστή</supplied><lb break="no" n="4"/>ριον τ<supplied reason="lost">οῦ Θεοῦ</supplied>.
            </ab></div></div>
            <div type="commentary">
                <p/>
            </div>
