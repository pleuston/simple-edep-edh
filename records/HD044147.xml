                Tertullo et Sacerdote co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> <lb n="2"/><expan><abbr>Iul</abbr><ex>ius</ex></expan> <expan><abbr>Alexand</abbr><ex>er</ex></expan> <expan><abbr>fec</abbr><ex>it</ex></expan>
