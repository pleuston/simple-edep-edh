            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost">Ὑπὲρ τῆς τοῦ Αὐτ</supplied>ο<supplied reason="lost">κ</supplied>ράτορο<supplied reason="lost">ς Δομιτιανοῦ</supplied> <lb n="2"/><supplied reason="lost">Καίσαρ</supplied>ος Σεβαστοῦ Γερ<supplied reason="lost">μανικοῦ τύχης</supplied> <lb n="3"/><supplied reason="lost">καὶ δι</supplied>αμονῆς Τίτος Φλ<supplied reason="lost">άουιος <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="4"/>τὸ ἱερὸν τοῦ Ἑρμοῦ κατασ<supplied reason="lost">κευάσας ἐκ τῶν</supplied> <lb n="5"/>ἰδίων ἀφ<surplus>ε</surplus>ιέρωσεν, ὃ ὑπέ<supplied reason="lost">σχετο τῆι <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="6"/>πόλει Γάιος Πομπώνιος <gap reason="lost" extent="unknown" unit="character"/>.
