                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> Cae<supplied reason="lost">sari</supplied> <lb n="2"/>divi Tra<supplied reason="lost">iani Par</supplied><lb break="no" n="3"/>thici <expan><abbr>f</abbr><ex>ilio</ex></expan> <supplied reason="lost">d</supplied>iv<supplied reason="lost">i</supplied> Ner<lb break="no" n="4"/>vae nepoti Trai<lb break="no" n="5"/>ano <supplied reason="lost">H</supplied>adriano <lb n="6"/><expan><abbr>Aug</abbr><ex>usto</ex></expan> pontifici ma<lb break="no" n="7"/>ximo <expan><abbr>trib</abbr><ex>unicia</ex></expan> potesta<lb break="no" n="8"/>te II co<expan><ex>n</ex><abbr>s</abbr><ex>uli</ex></expan> <expan><abbr>p</abbr><ex>atri</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <expan><abbr>colon</abbr><ex>ia</ex></expan> <lb n="9"/>Ulpia Traiana <expan><abbr>Aug</abbr><ex>usta</ex></expan> <lb n="10"/><expan><abbr>Dacic</abbr><ex>a</ex></expan> <expan><abbr>Sarmizege</abbr><ex>tusa</ex></expan> <gap reason="lost" quantity="1" unit="line"/>
