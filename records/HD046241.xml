                <expan><abbr>Herc</abbr><ex>uli</ex></expan> <expan><abbr>v</abbr><ex cert="low">otum</ex></expan> <expan><abbr>s</abbr><ex cert="low">uum</ex></expan> Veros Liaci <expan><abbr>sol</abbr><ex>vit</ex></expan>
