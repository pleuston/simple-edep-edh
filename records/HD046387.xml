            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost">Dis</supplied> Faventibus et Con<lb break="no" n="2"/><supplied reason="lost">c</supplied>ordia <expan><abbr>Imp</abbr><ex>eratorum</ex></expan> evenit qu<lb break="no" n="3"/>od a primo adventu <lb n="4"/>suo <expan><abbr>P</abbr><ex>ublius</ex></expan> <expan><abbr>F</abbr><ex>urius</ex></expan> <expan><abbr>S</abbr><ex>aturninus</ex></expan> <expan><abbr>leg</abbr><ex>atus</ex></expan> Augusto<supplied reason="lost"><expan><abbr>r</abbr><ex>um</ex></expan></supplied> <lb n="5"/>donec provincia de<lb break="no" n="6"/><expan><abbr>ceder</abbr><ex>et</ex></expan> ita singulos uni<lb break="no" n="7"/><expan><abbr>versosq</abbr><ex>ue</ex></expan> benig<expan><ex>ni</ex><abbr>tate</abbr></expan> sua <lb n="8"/>tractarit oneribus etiam <lb n="9"/><expan><abbr>rel<supplied reason="lost">e</supplied>vaver</abbr><ex>it</ex></expan> ut felicissim<supplied reason="lost">a</supplied> <lb n="10"/>et praeci<supplied reason="lost">p</supplied>uis virtuti<supplied reason="lost"><expan><abbr>b</abbr><ex>us</ex></expan></supplied> <lb n="11"/>eiius <note>sic</note> obs<supplied reason="lost">tr</supplied>icta simul <supplied reason="lost">e</supplied>t <lb n="12"/>devota provincia ei <lb n="13"/><supplied reason="lost">grat</supplied>ia<supplied reason="lost">s</supplied> agat <gap reason="lost" extent="unknown" unit="character"/> <lb n="14"/><gap reason="lost" extent="unknown" unit="character"/> GERM<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied><expan><abbr>P</abbr><ex cert="low"/></expan><gap reason="lost" extent="unknown" unit="character"><certainty match=".." locus="name"/></gap>
