            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Domine Megale <lb n="2"/>Invicte tu qui Attidis <lb n="3"/>corpus accepisti accipias cor<lb break="no" n="4"/>pus eius qui meas sarcinas <lb n="5"/>supstulit qui me compilavit <lb n="6"/>de domo Hispani illius corpus <lb n="7"/>tibi et <expan><abbr>anima</abbr><ex>m</ex></expan> do dono ut meas <lb n="8"/>res <expan><abbr>invenia</abbr><ex>m</ex></expan> tunc tibi <expan><abbr>ostia</abbr><ex>m</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>quadripede</abbr><ex>m</ex></expan> dono Attis voveo <lb n="2"/>si eas iure invenero dom<expan><ex>i</ex><abbr>ne</abbr></expan> <lb n="3"/>Attis te rogo per tu<expan><ex>u</ex><abbr>m</abbr></expan> Nocturnum <lb n="4"/>ut me quam <expan><abbr>primu</abbr><ex>m</ex></expan> <expan><abbr>compote</abbr><ex>m</ex></expan> facias
            </ab></div></div>
