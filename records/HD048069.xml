                Iuliae Mam<expan><ex>a</ex><abbr>eae</abbr></expan> Au<lb break="no" n="2"/>gustae matri sanc<lb break="no" n="3"/>tissimi <expan><abbr>Imp</abbr><ex>eratoris</ex></expan> <expan><abbr>Caes</abbr><ex>aris</ex></expan> <lb n="4"/>Severi Alexandri <lb n="5"/><expan><abbr>Aug</abbr><ex>usti</ex></expan> et castrorum <lb n="6"/>senatusque ala <lb n="7"/>Frontoniana Ale<lb break="no" n="8"/>xandriana ex <lb n="9"/>quaestura sua <lb n="10"/>dedicante <lb n="11"/><supplied reason="lost">Ia</supplied>sdio Domitia<lb break="no" n="12"/><supplied reason="lost">no l</supplied><expan><abbr>eg</abbr><ex>ato</ex></expan> <expan><abbr>Aug</abbr><ex>usti</ex></expan> <expan><abbr>pr</abbr><ex>o</ex></expan> <expan><abbr>pr</abbr><ex>aetore</ex></expan>
