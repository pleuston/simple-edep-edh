            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Fortunae <lb n="2"/>Reduci <expan><abbr>Ael</abbr><ex>ius</ex></expan> <lb n="3"/>Celer <expan><abbr>praef</abbr><ex>ectus</ex></expan> <lb n="4"/><expan><abbr>eq</abbr><ex>uitum</ex></expan> alae Fro<lb break="no" n="5"/><expan><abbr>nt</abbr><ex>onianae</ex></expan> ob res<lb break="no" n="6"/>titutio<lb break="no" n="7"/>nem bali<lb break="no" n="8"/>nei posuit
            </ab></div>
            <div type="commentary">
                <p>In den Thermen gefunden.</p>
            </div>
