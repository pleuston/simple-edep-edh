            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Dagus Zi<lb break="no" n="2"/>pyronis fil<lb break="no" n="3"/>ia reliquit <lb n="4"/>vicanis Sceu<lb break="no" n="5"/>euenis |(denarios) CXX ut <lb n="6"/>ex usuris eor<lb break="no" n="7"/>um vescant<lb break="no" n="8"/>ur quotquot <lb n="9"/>annis rosis a<lb break="no" n="10"/><expan><abbr>dalant</abbr><ex>ur</ex></expan> quot <lb n="11"/>si non <expan><abbr>fecer</abbr><ex>int</ex></expan> <lb n="12"/>tum <expan><abbr>dab</abbr><ex>itur</ex></expan> po<lb break="no" n="13"/>ena vicanis <lb n="14"/>Antherita<lb break="no" n="15"/>nis |(denarios) CCXXX
            </ab></div>
            <div type="commentary">
                <p>(B): Abweichende Textgestaltung.</p>
            </div>
