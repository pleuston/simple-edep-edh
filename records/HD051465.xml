            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                ἀγαθῇ τύχῃ <lb n="2"/>τοὺς μεγίστους κὲ θι<lb break="no" n="3"/>οτάτους Αὐτοκρατόρους <lb n="4"/>Φλ(άβιον) Οὐαλ(έριον) Κωνστάντιο<supplied reason="lost">ν</supplied> <lb n="5"/>κὲ Γαλ(έριον) Οὐαλ(έριον) Μαξιμιανὸν <lb n="6"/>Σεβ(αστοὺς) καὶ τοὺς ἐπιφα<lb break="no" n="7"/>νεστάτους Κέσαρας <lb n="8"/>Φλ(άβιον) Οὐαλ(έριον) Σεουῆρον <lb n="9"/>κὲ Γαλ(έριον) Οὐαλ(έριον) <supplied reason="lost">Μα</supplied>ξιμῖν<supplied reason="lost">ον</supplied> <lb n="10"/>ἡ πόλις εὐτυχῶς </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Licinni<lb break="no" n="2"/>ano Licin<lb break="no" n="3"/>nus </ab></div><div n="3" type="textpart"><ab><lb n="1"/> <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar <expan><abbr>F</abbr><ex>lavius</ex></expan> <lb n="2"/>Va<supplied reason="lost"><expan><abbr>l</abbr><ex>erius</ex></expan></supplied> Constanti<lb break="no" n="3"/>nus <expan><abbr>P</abbr><ex>ius</ex></expan> <expan><abbr>F</abbr><ex>elix</ex></expan> Invictu<lb break="no" n="4"/>s <expan><abbr>Aug</abbr><ex>ustus</ex></expan> et <expan><abbr>Imp</abbr><ex>erator</ex></expan> Cae<lb break="no" n="5"/>sar Licinianus <lb n="6"/>Licinnius <expan><abbr>P</abbr><ex>ius</ex></expan> <expan><abbr>F</abbr><ex>elix</ex></expan> Inv<lb break="no" n="7"/>ictus <expan><abbr>Aug</abbr><ex>ustus</ex></expan>
            </ab></div></div>
