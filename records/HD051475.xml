            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Θ(εοῖς) Κ(αταχθονίοις) <lb n="2"/>Ὁσίαι Φ(λαβίου) Ἀβασκάν<lb break="no" n="3"/>του θυγατρὶ ζησά<lb break="no" n="4"/>σᾳ ἔτη κε Φ(λάβιος) Ἀβάσ<lb break="no" n="5"/>καντος καὶ Πριμι<lb break="no" n="6"/>γενία γονεῖς θυγατ<lb break="no" n="7"/>ρὶ εὐσεβεῖ ἀνέθηκαν </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Hosia <expan><abbr>F</abbr><ex>lavi</ex></expan> Abas<lb break="no" n="3"/>canti <expan><abbr>f</abbr><ex>ilia</ex></expan> <expan><abbr>v</abbr><ex>ixit</ex></expan> <expan><abbr>a</abbr><ex>nnos</ex></expan> XXV <lb n="4"/><expan><abbr>F</abbr><ex>lavius</ex></expan> Abascantus <lb n="5"/>et Primigenia <lb n="6"/>parentes filiae <lb n="7"/>bene merenti <lb n="8"/><expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uraverunt</ex></expan>
            </ab></div></div>
            <div type="commentary">
                <p>Reliefdarstellung eines Gladiatoren. (B): Abweichende Textgestaltung in Z. 2-3, 7.</p>
            </div>
