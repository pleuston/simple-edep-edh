                <supplied reason="lost" cert="low">Dis</supplied><supplied reason="lost">Dis</supplied> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>Seve</abbr><ex>rio</ex></expan> Lupulo i<expan><ex>u</ex><abbr>veni</abbr></expan> qui <lb n="2"/>v<expan><ex>ixi</ex><abbr>t</abbr></expan> <expan><abbr>an</abbr><ex>nos</ex></expan> XXXV <expan><abbr>m</abbr><ex>enses</ex></expan> V et Severio <lb n="3"/>Florentino fratere <note>sic</note> <expan><abbr>q</abbr><ex>ui</ex></expan> <expan><abbr>v</abbr><ex>ixit</ex></expan> <expan><abbr>an</abbr><ex>nos</ex></expan> <lb n="4"/>XXII <expan><abbr>m</abbr><ex>enses</ex></expan> X <expan><abbr>negotiat</abbr><ex>ori</ex></expan> et <expan><abbr>caud</abbr><ex>iciario</ex></expan> <lb n="5"/>Licontius mater infelix qu<expan><ex>a</ex><abbr>e</abbr></expan> <lb n="6"/>sibi a fili<expan><ex>i</ex><abbr>s</abbr></expan> <expan><abbr>optave</abbr><ex>rat</ex></expan> fieri cont<lb break="no" n="7"/>ra votum fili<expan><ex>i</ex><abbr>s</abbr></expan> <expan><abbr>mem</abbr><ex>oriam</ex></expan> <lb n="8"/><expan><abbr>p</abbr><ex>osuit</ex></expan>
