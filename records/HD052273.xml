                <expan><abbr>Q</abbr><ex>uinto</ex></expan> <expan><abbr>Iul</abbr><ex>io</ex></expan> Fel<supplied reason="lost">ici</supplied> <lb n="2"/><expan><abbr>dec</abbr><ex>urioni</ex></expan> c<supplied reason="lost"><expan><abbr>ol</abbr><ex>oniae</ex></expan></supplied> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/>
