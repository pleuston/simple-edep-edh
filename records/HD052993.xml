    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Ἔτους δμσ τ<supplied reason="lost">ο</supplied>ῦ κὲ <surplus>γ</surplus> ξτʹ <lb n="2"/>σεβαστοῦ, ἐν Αὐ<supplied reason="lost">τ</supplied>όχθονι ἐπὶ <lb n="3"/>τῇ θεῷ, κατὰ κ<supplied reason="lost">έ</supplied>λευσιν τοῦ <lb n="4"/>κρατίστου ἡγ<supplied reason="lost">εμό</supplied>νος μου Τερ<lb break="no" n="5"/>τυλλιανοῦ Ἀκ<supplied reason="lost">υλάο</supplied>υ Αὐρήλιος Πο<lb break="no" n="6"/>σιδώνιος ὁ <supplied reason="lost">πρὶν</supplied> Μέστυος ὁ κὲ <lb n="7"/>Παντακιαν<supplied reason="lost">ὸς</supplied> χαρίζομε <lb n="8"/>πεδίσκην ὀνόματι Ἀμμίαν <lb n="9"/>κὲ τέκνα αὐτῆς Ποσιδώνι<supplied reason="lost">ν</supplied> <lb n="10"/>κὲ Νείκωνα, ὧν κὲ τὰς ἀσ<lb break="no" n="11"/>φαλείας ἀπεθέμ<supplied reason="lost">η</supplied>ν εἰς τὰς <lb n="12"/>ἀ&amp;lt;γ=Ν&amp;gt;κάλας τῆς θεοῦ 
            </ab></div>
