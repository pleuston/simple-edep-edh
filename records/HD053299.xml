                <expan><abbr>P</abbr><ex>ublio</ex></expan> Aelio <expan><abbr>P</abbr><ex>ubli</ex></expan> <expan><abbr>f</abbr><ex>ilio</ex></expan> <lb n="2"/><expan><abbr>Tro</abbr><ex>mentina</ex></expan> <lb n="3"/>Osilliano <lb n="4"/>Novia Bassilla <lb n="5"/>mater et Novia Ius<lb break="no" n="6"/>tilla avia posuerunt <lb n="7"/>et sportulis <expan><abbr>decurio</abbr><ex>nibus</ex></expan> <lb n="8"/>Augustalibus et sexvi<lb break="no" n="9"/>ris datis item pugilum <lb n="10"/>spectaculo dedicave<lb break="no" n="11"/>runt huic universus <lb n="12"/>ordo decurionatus <lb n="13"/>honorem et locum <lb n="14"/>statuae decrevit
