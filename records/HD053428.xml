    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <supplied reason="lost">τὸν ἀρχιερ</supplied>έα τῶν <lb n="2"/><supplied reason="lost">Σεβαστῶν</supplied> καὶ ἀγωνοθέ<lb break="no" n="3"/><supplied reason="lost">την τοῦ</supplied> κοινοῦ Μακεδόνων <lb n="4"/><supplied reason="lost">Τι(βέριον)? Κλαύ</supplied>διον Αἰλιανὸν Ἀλέ<supplied reason="lost">ξανδ</supplied>ρον Παρμενίωνος <lb n="5"/><supplied reason="lost">Αἰ</supplied>στρεάτην ἡ Αἰστρεατῶν <lb n="6"/><supplied reason="lost">πόλις ἀρ</supplied>ετῆς καὶ εὐνοίας τῆς εἰς <lb n="7"/><supplied reason="lost">ἑα</supplied>υτὴν ἕνεκεν </ab></div><div n="2" type="textpart"><ab><lb n="1"/> τὴν ἱέρειαν τῶν <lb n="2"/>Σεβαστῶν Ἀουιδίαν <lb n="3"/>Ἀμμίαν <lb n="4"/>θυγατέρα Φίλωνος γυναῖ<lb break="no" n="5"/>κα Ἀλεξάνδρου Αἰστρεᾶτιν <lb n="6"/>ἡ Αἰστρεατῶν πόλις <lb n="7"/>ἀρετῆς ἕνεκεν
            </ab></div></div>
