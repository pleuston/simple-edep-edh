                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> C<supplied reason="lost">aesa</supplied><lb break="no" n="2"/>ri <supplied reason="lost"><expan><abbr>T</abbr><ex>ito</ex></expan></supplied> Ael<supplied reason="lost">io</supplied> <lb n="3"/><supplied reason="lost">Ha</supplied>dri<supplied reason="lost">ano</supplied> <lb n="4"/><supplied reason="lost">An</supplied>t<supplied reason="lost">onino</supplied> <lb n="5"/>[<expan><abbr>Aug</abbr><ex>usto</ex></expan> Pio ------
