            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="2"/>Sulpicius Cal<lb break="no" n="3"/>vio <expan><abbr>c</abbr><ex>enturio</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> I <expan><abbr>M</abbr><ex>inerviae</ex></expan> pr<lb break="no" n="4"/>aepositus c<expan><ex>o</ex><abbr>h</abbr></expan><lb break="no" n="5"/><expan><abbr>o</abbr><ex>rtis</ex></expan> I <expan><abbr>Belg</abbr><ex>arum</ex></expan> hoc in <lb n="6"/>loco maiesta<lb break="no" n="7"/>te et <expan><abbr>numin</abbr><ex>e</ex></expan> <lb n="8"/>eius servat<lb break="no" n="9"/>us
            </ab></div>
            <div type="commentary">
                <p>Hederae. Datierung: wohl bevor die coh. I Belg. unter Septimius Severus Dalmatien verließ.</p>
