                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Martino <lb n="3"/>Saturini <lb n="4"/>filio <expan><abbr>an</abbr><ex>norum</ex></expan> XXX <lb n="5"/>et Valentin<expan><ex>a</ex><abbr>e</abbr></expan> <lb n="6"/><expan><abbr>an</abbr><ex>norum</ex></expan> V et Ceri<lb break="no" n="7"/>li<expan><ex>a</ex><abbr>e</abbr></expan> <expan><abbr>co</abbr><ex>niugi</ex></expan>
