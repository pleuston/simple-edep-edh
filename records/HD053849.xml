            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <gap reason="lost" extent="unknown" unit="character"/>ΙΙ<gap reason="lost" extent="unknown" unit="character"/>ΝΟΙΙΟΙΓΑΙΙΛ<gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/>ΕΝΟΙΣ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΠΥΛΩΣΗΜ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>ΤΙΑΝΑ<gap reason="lost" extent="unknown" unit="character"/> <lb n="3"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΟΙ<gap reason="lost" extent="unknown" unit="character"/>ΕΛ<gap reason="lost" extent="unknown" unit="character"/>ΛΕΑΣ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΤΕ<gap reason="lost" extent="unknown" unit="character"/> <lb n="4"/>ΕΙΛΕΝΙΑΣ<gap reason="lost" extent="unknown" unit="character"/>Λ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/><gap reason="lost" quantity="1" unit="character"/></supplied>ΠΛ τὸν πο<lb break="no" n="5"/>λιτάρχην ΠΕΙΔ<gap reason="lost" extent="unknown" unit="character"/>Σ πολι<lb break="no" n="6"/>λιτάρχης ΕΙΣ<gap reason="lost" extent="unknown" unit="character"/>ΕΤΟΣ μά<lb break="no" n="7"/>λιστα <supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>Ε<gap reason="lost" extent="unknown" unit="character"/>ΣΙΝ<supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/></supplied>ΑΙ κατεχο<supplied reason="lost">ύ</supplied><lb break="no" n="8"/>σης τὴν Μακεδονίαν προενοήθη <lb n="9"/>τῶν τε τῆς πόλεως πραγμάτων καὶ <lb n="10"/>τῆς τῶν παροικούντων ξένων ἀσφα<lb break="no" n="11"/>λήας πάντας ἀφελὼν τῆι κακοπαθ<supplied reason="lost">ίαι</supplied> <lb n="12"/>καὶ δαπάνην π<supplied reason="lost">ᾶσαν ἐ</supplied>κ τῶν ἰδίων εἰσενε<supplied reason="lost">γ</supplied><lb break="no" n="13"/>κάμενος ἐπὶ τῶι κοινῶι τῆς πατρίδο<supplied reason="lost">ς</supplied> <lb n="14"/>καὶ τῶι ἡμετέρωι συνφέροντι γενέ<supplied reason="lost">σ</supplied><lb break="no" n="15"/><supplied reason="lost">θ</supplied>αι δὲ αὐτοῦ εἰκόνα ἐν ὅπλωι ἐπίχρυσ<supplied reason="lost">ον</supplied> <lb n="16"/><supplied reason="lost">ἣ</supplied>ν καὶ τεθῆναι ὅπου ἂν αὐτὸς αἱρῆται <lb n="17"/>ἐπεχειροτονήθη ἔτους <lb n="18"/><supplied reason="lost"><gap reason="lost" quantity="1" unit="character"/>ʹ</supplied> καὶ ρʹ Ὑπερβερταίου δεκάτηι
