            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Aram <lb n="2"/><expan><abbr>d</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> et innocen<lb break="no" n="3"/>tiae Hipponici <expan><abbr>ser</abbr><ex>vi</ex></expan> <lb n="4"/>Dignillae <expan><abbr>Iun</abbr><ex>i</ex></expan> Pastoris <lb n="5"/><expan><abbr>leg</abbr><ex>ati</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> XXII <expan><abbr>Pr</abbr><ex>imigeniae</ex></expan> <expan><abbr>p</abbr><ex>iae</ex></expan> <expan><abbr>f</abbr><ex>idelis</ex></expan> <lb n="6"/>Hedyepes et Genesia <lb n="7"/>parentes <lb n="8"/>ut primum adolevit pollens <lb n="9"/>viribus decora facie Cupidinis <lb n="10"/>os habitumque gerens nec metuam <lb n="11"/>dicere Apollineus huic expletis <lb n="12"/>ter centum ter denisque diebus <lb n="13"/>invisae Parcae sollemnem cele<lb break="no" n="14"/>brare diem iamque ut esset gra<lb break="no" n="15"/>tus amicis invidia superum cess<supplied reason="lost">a</supplied><lb break="no" n="16"/>vit amari
            </ab></div>
