            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar divi Nervae <expan><abbr>f</abbr><ex>ilius</ex></expan> Nerva Traia<lb break="no" n="2"/>nus Augustus Germanicus Dacicus <lb n="3"/>pontifex maximus <expan><abbr>tribunic</abbr><ex>ia</ex></expan> potes<lb break="no" n="4"/><expan><abbr>tat</abbr><ex>e</ex></expan> VIIII <expan><abbr>imp</abbr><ex>erator</ex></expan> IIII co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> V <expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <lb n="5"/>equitibus et peditibus qui militant in alis <lb n="6"/>tribus et cohortibus septem quae appel<lb break="no" n="7"/>lantur I Flavia Gaetulorum et I Astu<lb break="no" n="8"/>rum et II Hispanorum et Arvacorum et <lb n="9"/>I Lepidiana <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I Bracaraugustanorum <lb n="10"/>et I Sugambrorum tironum et II Mattia<lb break="no" n="11"/>corum et II Chalcidenorum et II Flavia <lb n="12"/>Brittonum et Ubiorum et sunt in Moe<lb break="no" n="13"/>sia inferiore sub <expan><abbr>A</abbr><ex>ulo</ex></expan> Caecilio Faustino <lb n="14"/>qui quina et vicena plurave stipendia <lb n="15"/>meruerunt item dimissis honesta <lb n="16"/>missione quorum nomina subscripta <lb n="17"/>sunt ipsis liberis posterisque eorum <lb n="18"/>civitatem dedit et conubium cum <lb n="19"/>uxoribus quas tunc habuissent cum <lb n="20"/>civitas iis data aut si qui caelibes es<lb break="no" n="21"/>sent cum iis quas postea duxissent dum<lb break="no" n="22"/>taxat singuli singulas <expan><abbr>a</abbr><ex>nte</ex></expan> <expan><abbr>d</abbr><ex>iem</ex></expan> III Idus <expan><abbr>Mai</abbr><ex>as</ex></expan> <lb n="23"/><expan><abbr>C</abbr><ex>aio</ex></expan> Iulio Basso <expan><abbr>Cn</abbr><ex>aeo</ex></expan> Afranio Dextro co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> <lb n="24"/>alae II Hispanorum et Arvacorum cui <lb n="25"/>prae<expan><ex>e</ex><abbr>st</abbr></expan> <expan><abbr>L</abbr><ex>ucius</ex></expan> Fabius <expan><abbr>L</abbr><ex>uci</ex></expan> <expan><abbr>f</abbr><ex>ilius</ex></expan> <expan><abbr>Pal</abbr><ex>atina</ex></expan> Fabullus <lb n="26"/>gregali <lb n="27"/>Atrecto Capitonis <expan><abbr>f</abbr><ex>ilio</ex></expan> <expan><abbr>Nemet</abbr><ex>i</ex></expan> <lb n="28"/>descriptum et recognitum ex tabula <lb n="29"/>aenea quae fixa est Romae in muro <lb n="30"/>post templum divi <expan><abbr>Aug</abbr><ex>usti</ex></expan> ad <expan><abbr>Minerva</abbr><ex>m</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar divi Nervae <expan><abbr>f</abbr><ex>ilius</ex></expan> Nerva Traianus <expan><abbr>August</abbr><ex>us</ex></expan> <lb n="2"/>Germanicus pontifex maximus <expan><abbr>tribunic</abbr><ex>ia</ex></expan> <lb n="3"/><expan><abbr>potestat</abbr><ex>e</ex></expan> VIIII <expan><abbr>imp</abbr><ex>erator</ex></expan> IIII <lb n="4"/>co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> V <expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> <lb n="5"/>equitibus et peditibus qui militant in alis <lb n="6"/>tribus et cohortibus septem quae ap<expan><ex>p</ex><abbr>ellantur</abbr></expan> <lb n="7"/>I Flavia Gaetulorum et I Asturum et II Hispano<lb break="no" n="8"/>rum et Arvacorum et I Lepidiana <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan> et I Braca<lb break="no" n="9"/>raugustanorum et I Sugambrorum tironum <lb n="10"/>et II Mattiacorum et II Chalcidenorum et <lb n="11"/>II Flavia Brittannorum et Ubiorum et sunt <lb n="12"/>in Moesia inferiore sub <expan><abbr>A</abbr><ex>ulo</ex></expan> Caecilio Faustino <lb n="13"/>qui quina et vicena plurave stipendia <lb n="14"/>meruerunt item dimissis honesta missione
