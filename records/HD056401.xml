                <expan><abbr>P</abbr><ex>ublius</ex></expan> <lb n="2"/>Aelius <lb n="3"/>Tertullus <lb n="4"/><expan><abbr>viv</abbr><ex>us</ex></expan> <expan><abbr>fec</abbr><ex>it</ex></expan> sibi <lb n="5"/>et Maximiae <lb n="6"/>Secundae <lb n="7"/>uxori
