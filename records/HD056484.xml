                <expan><abbr>C</abbr><ex>aius</ex></expan> Seccius <expan><abbr>C</abbr><ex>ai</ex></expan> <expan><abbr>lib</abbr><ex>ertus</ex></expan> <lb n="2"/>Lesbius <expan><abbr>an</abbr><ex>norum</ex></expan> XX <lb n="3"/>hic <expan><abbr>s</abbr><ex>itus</ex></expan> est <lb n="4"/>cum mihi prima no<lb break="no" n="5"/>vos spargebat flore <lb n="6"/>iu<expan><ex>v</ex><abbr>entus</abbr></expan> heu miser ae<lb break="no" n="7"/>tatis praemia nulla &amp;lt;t=I&amp;gt;u<lb break="no" n="8"/>li bis denis mihi mors <lb n="9"/>annis accessit iniqua <lb n="10"/>ingemit et damno Sec<lb break="no" n="11"/>cius ille gravi di meli<lb break="no" n="12"/>ora precor pro nostro <lb n="13"/>munera casu sentiat <lb n="14"/>et plures possit habere <lb n="15"/>suos hic tumulum titu<lb break="no" n="16"/><expan><abbr>lumq</abbr><ex>ue</ex></expan> mihi donavit ho<lb break="no" n="17"/>nori et proprium no<lb break="no" n="18"/>men d&amp;lt;e=I&amp;gt;stinat in lac<lb break="no" n="19"/>r&amp;lt;i=V&amp;gt;mas bene merenti 
