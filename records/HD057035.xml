            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="0"/> <gap reason="lost" quantity="1" unit="line"/> XXXVII Salvio <expan><abbr>n<am>n</am></abbr><ex>orum</ex></expan> XXXIII <expan><abbr>frum</abbr><ex>entario</ex></expan> <expan><abbr>leg</abbr><ex>ionis</ex></expan> II <expan><abbr>adi</abbr><ex>utricis</ex></expan> <lb n="1"/><expan><abbr>Iul</abbr><ex>ius</ex></expan> Asclepiades caris suis hunc <expan><abbr>titul</abbr><ex>um</ex></expan> <lb n="2"/>posui miserabile munus non satis <lb n="3"/>ut meruistis quattuor amissis te quin<lb break="no" n="4"/>tum Salvi flere necesse est adsidu<surplus>a</surplus>e <lb n="5"/>dum mea fata resistent te nunc amis<lb break="no" n="6"/>so domus inclinata recumbit <expan><abbr>depon</abbr><ex>am</ex></expan> <lb n="7"/>luctus cum te sequar care per <expan><abbr>umbr</abbr><ex>as</ex></expan> <lb n="8"/><expan><abbr>dulce</abbr><ex>m</ex></expan> meum Salvium liceat mihi <expan><abbr>dicer</abbr><ex>e</ex></expan> <lb n="9"/>semper <expan><abbr>optaver</abbr><ex>am</ex></expan> <expan><abbr>tumul</abbr><ex>um</ex></expan> tu mihi ut <expan><abbr>facer</abbr><ex>es</ex></expan> <lb n="10"/>tot bona tum carui <expan><abbr>merit</abbr><ex>o</ex></expan> te care requiro
            </ab></div></div>
