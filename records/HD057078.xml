                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Eutychi<expan><ex>a</ex><abbr>e</abbr></expan> con<lb break="no" n="3"/><expan><abbr>se</abbr><ex cert="low">rvae</ex></expan>
