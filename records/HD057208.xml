            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Ἀγαθῇ Τύχῃ <lb n="2"/>ἐπὶ ἱερέος τοῦ <lb n="3"/>Διὸς τοῦ Ἰθωμά<lb break="no" n="4"/>τα Ἀσκληπιάδου <lb n="5"/>τοῦ Γναίου, ἔτους <lb n="6"/>σηʹ· γυμνασίαρχος <lb n="7"/>Σωτηρίδας Ἡλιοδώ<lb break="no" n="8"/>ρου, ὑπογυμνασίαρ<lb break="no" n="9"/>χος Νεικάνωρ |(Νεικάνωρος), ἐφήβ <lb n="10"/>αρχος Νεικάνωρ |(Νεικάνωρος), <lb n="11"/>ἀρχέφηβος Σωτηρίδας |(Σωτηρίδου), <lb n="12"/>ἔφηβοι </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Ὑλλίδος <lb n="2"/>Λύκος Σωτηρίχου, <lb n="3"/>Φλ(άβιος) Θρέπτος, <lb n="4"/>Κλώ(διος) Λεωνᾶς, <lb n="5"/>Φλά(βιος) Φίλων, <lb n="6"/>Μᾶρκος |(Μάρκου), <lb n="7"/>Αἴλιος Ἔφηβος, <lb n="8"/>Κλ(αύδιος) Δαμᾶς, <lb n="9"/>Πρεῖσκος Φιλέου, <lb n="10"/>Λύκισκος ἀπὸ Κλυμένου, <lb n="11"/>Εὐρώτας Διο<lb break="no" n="12"/>νυσίου, Φλ(άβιος) Ἐπαφρ<supplied reason="lost">ᾶς</supplied>, <lb n="13"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> Ζ</supplied>ήνων, <lb n="14"/><gap reason="lost" extent="unknown" unit="character"/>οκράτης ἀπὸ <lb n="15"/>Καλλιμάχου </ab></div><div n="3" type="textpart"><ab><lb n="1"/> Κλεολαίας Λύκος <lb n="2"/>Αἴλιος <lb n="3"/>Φλά(βιος) Ἀγη<gap reason="lost" extent="unknown" unit="character"/> <lb n="4"/>Φιλουμενός <lb n="5"/>Δι<gap reason="lost" extent="unknown" unit="character"/> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/> <lb n="6"/>Φλ(άβιος) Εὐβίοτος <lb n="7"/>Δαιφοντίδος <lb n="0"/>Ἀγα<gap reason="lost" quantity="1" unit="line"/>
