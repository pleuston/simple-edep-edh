                <expan><abbr>Imp</abbr><ex>eratori</ex></expan> <expan><abbr>Cae</abbr><ex>sari</ex></expan> Tito <lb n="2"/><expan><abbr>Ael</abbr><ex>io</ex></expan> <expan><abbr>Hadr</abbr><ex>iano</ex></expan> <lb n="3"/>Antonino <lb n="4"/><expan><abbr>Aug</abbr><ex>usto</ex></expan> Pio <lb n="5"/><expan><abbr>coh</abbr><ex>ors</ex></expan> I <expan><abbr>Br</abbr><ex>eucorum</ex></expan> <expan><abbr>c</abbr><ex>ivium</ex></expan> <expan><abbr>R</abbr><ex>omanorum</ex></expan>
