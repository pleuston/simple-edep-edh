            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Toto orbe <lb n="2"/>pacifico <lb n="3"/>consuli <lb n="4"/><expan><abbr>d</abbr><ex>omino</ex></expan> <expan><abbr>n</abbr><ex>ostro</ex></expan> Flavio <lb n="5"/>Arcadio <lb n="6"/>Pio Felici <lb n="7"/>victori ac <lb n="8"/>triumfato<lb break="no" n="9"/>ri semper <lb n="10"/>Augusto </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Lepcitani devoti <expan><abbr>num</abbr><ex>ini</ex></expan> <lb n="2"/><expan><abbr>maiestatiq</abbr><ex>ue</ex></expan> eius
            </ab></div></div>
            <div type="commentary">
                <p>The inscription is carved over an erased earlier text.</p>
            </div>
