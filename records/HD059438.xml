            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                Inachii </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Omnium <lb n="2"/>virtutum <lb n="3"/>viro Publicio <lb n="4"/>Valeriano <expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>p</abbr><ex>erfectissimo</ex></expan> <lb n="5"/>ex praesidibus <lb n="6"/>singularis inte<lb break="no" n="7"/>gritatis et mode<lb break="no" n="8"/>rationis Lepci<lb break="no" n="9"/>magnenses pa<lb break="no" n="10"/>trono prae<supplied reason="lost">stan</supplied></ab></div><div n="3" type="textpart"><ab><lb n="1"/><expan><abbr>tiss</abbr><ex>imo</ex></expan> posuerunt
            </ab></div></div>
            <div type="commentary">
                <p>The inscription is carved over an erased earlier text.</p>
            </div>
