                <supplied reason="lost"><expan><abbr>I</abbr><ex>n</ex></expan></supplied> <expan><abbr>h</abbr><ex>onorem</ex></expan> <expan><abbr>d</abbr><ex>omus</ex></expan> <expan><abbr>d</abbr><ex>ivinae</ex></expan> <lb n="2"/><supplied reason="lost">D</supplied>eae <expan><abbr>Fort</abbr><ex>unae</ex></expan> <lb n="3"/><expan><abbr><supplied reason="lost">A</supplied>el</abbr><ex>ius</ex></expan> Aelio<lb break="no" n="4"/>dorus <lb n="5"/><supplied reason="lost">et Ae</supplied>lia Maura <lb n="6"/>ex <expan><abbr>v</abbr><ex>oto</ex></expan> <expan><abbr>p</abbr><ex>osuerunt</ex></expan> <expan><abbr>l</abbr><ex>ibentes</ex></expan> <expan><abbr>l</abbr><ex>aeti</ex></expan> <lb n="7"/><expan><abbr>m</abbr><ex>erito</ex></expan>
