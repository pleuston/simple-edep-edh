                <gap reason="lost" extent="unknown" unit="character"/>VN <expan><abbr>d</abbr><ex>omino</ex></expan> <expan><abbr>n</abbr><ex>ostro</ex></expan> Theo<supplied reason="lost">dosio <expan><abbr>Aug</abbr><ex>usto</ex></expan> <gap reason="lost" extent="unknown" unit="character"/></supplied>
