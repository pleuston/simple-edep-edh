    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Q</abbr><ex>uinto</ex></expan> Gellio Sentio Augurino proco<expan><ex>n</ex><abbr>s</abbr><ex>ule</ex></expan> decret<supplied reason="lost">a</supplied> <lb n="2"/>ex tabellis recitata Kalendis Marti<expan><ex>i</ex><abbr>s</abbr></expan> cum optimus maximusque <lb n="3"/>princeps Traianus Hadrianus <expan><abbr>Aug</abbr><ex>ustus</ex></expan> scripserit mihi uti adhibitis mens<supplied reason="lost">o</supplied><lb break="no" n="4"/>ribus de controversi<supplied reason="lost">is</supplied> finium inter Lamienses et Hypataeos cognita causa <lb n="5"/>terminarem egoque in rem praesentem saepius et continuis diebus <lb n="6"/>fuerim cognoverimque praesentibus utriusque civitatis defensoribus <lb n="7"/>adhibito a me Iulio Victore evocato Augusti mensore placet initium <lb n="8"/>finium esse ab eo loco in quo Siden fuisse comperi quae est infra con<lb break="no" n="9"/>saeptum consecratum Neptuno indeque discendentibus rigorem ser<lb break="no" n="10"/>vari usque at fontem Dercynnam qui est trans flumen Sperchion it<supplied reason="lost">a ut per</supplied><lb break="no" n="11"/>amphispora Lamiensium et Hypataeorum rigor at fontem Dercynn<supplied reason="lost">am supra</supplied> <lb n="12"/>scriptum ducat et inde at tumulum Pelion per decursum Sib<gap reason="lost" extent="unknown" unit="character"/> <lb n="13"/>at monumentum Euryti quod est intra finem Lam<supplied reason="lost">iensium</supplied><gap reason="lost" extent="unknown" unit="character"/> <lb n="14"/>Erycaniorum et Proherniorum <gap reason="lost" extent="unknown" unit="character"/> <lb n="15"/><gap reason="lost" extent="unknown" unit="character"/>ithraxum et sido<gap reason="lost" extent="unknown" unit="character"/> <lb n="16"/><gap reason="lost" extent="unknown" unit="character"/> const<gap reason="lost" extent="unknown" unit="character"/>
            </ab></div>
