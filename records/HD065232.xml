            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                ταγευόντουν Κλευμαχίδα <lb n="2"/>Ἀρναιείοι Δαμασίπποι Ἀντιγενεί<lb break="no" n="3"/>οι Ἀθαναγόρα Σταχυείοι Ἁρμο<lb break="no" n="4"/>δίοι Κλεουνείοι Πολυαινε<supplied reason="lost">ίδ</supplied>α <lb n="5"/>Μενανδρείοι ταμιευόντ<supplied reason="lost">ουν</supplied> <lb n="6"/>Δαμέα Νικορραίοι καὶ Καλ<supplied reason="lost">λία</supplied> Λ<supplied reason="lost">ε</supplied><lb break="no" n="7"/>οντείοι γυμνασιαρχέντο<supplied reason="lost">ς Θρά</supplied><lb break="no" n="8"/>σουνος Θρασιππείοι Ὁμ<supplied reason="lost">ολουΐοι</supplied> <lb n="9"/>ἕ<supplied reason="lost">κ</supplied>τᾳ ἀγορᾶς ἐόνσας ἀ<supplied reason="lost">γ</supplied>ορα<supplied reason="lost">νομέντος</supplied> Δαμα<lb break="no" n="10"/>σίπποι Ἀντιγενείοι Δα<supplied reason="lost">μασίπποι Ἀντιγενείοι</supplied> <lb n="11"/>λέξαντος ἔδοξε τοῦ δ<supplied reason="lost">άμου τοῦ Λαρισαίουν το</supplied><lb break="no" n="12"/><supplied reason="lost">ῖς ὑπο</supplied>γεγραμμένο<supplied reason="lost">ις <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="13"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> δε</supplied>δόσθειν π<supplied reason="lost">ολιτείαν <gap reason="lost" extent="unknown" unit="character"/></supplied>
            </ab></div>
