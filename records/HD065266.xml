                Valerius <lb n="2"/>Terentius <lb n="3"/><expan><abbr>t</abbr><ex>estamento</ex></expan> <expan><abbr>f</abbr><ex>ieri</ex></expan> <expan><abbr>i</abbr><ex>ussit</ex></expan> <lb n="4"/><expan><abbr>Adnamu</abbr><ex>s</ex></expan> <lb n="5"/><expan><abbr>Matuio</abbr><ex>s</ex></expan> Te<lb break="no" n="6"/><expan><abbr>ttu</abbr><ex>os</ex></expan> <expan><abbr>Terti</abbr><ex>us</ex></expan> <lb n="7"/><expan><abbr>fil</abbr><ex>ii</ex></expan> <lb n="8"/><expan><abbr>her</abbr><ex>edes</ex></expan> <expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uraverunt</ex></expan>
