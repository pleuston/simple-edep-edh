                <expan><abbr>L</abbr><ex>ucius</ex></expan> Licinius S<supplied reason="lost">eve</supplied><lb break="no" n="2"/>rus eques le<supplied reason="lost"><expan><abbr>g</abbr><ex>ionis</ex></expan></supplied> <lb n="3"/>IIII <expan><abbr>Mac</abbr><ex>edonicae</ex></expan> Phoen<supplied reason="lost">ino</supplied> <note>sic</note> <lb n="4"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
