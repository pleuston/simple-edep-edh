            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>B</abbr><ex>onae</ex></expan> &amp;lt;m=LA&amp;gt;(emoriae) Eniae Frontonillae filiae carissimae pien<lb break="no" n="2"/>tissimae dulcissimaeque <expan><abbr>Aul</abbr><ex>us</ex></expan> <expan><abbr>P</abbr><ex>ublius</ex></expan> Enius Frontonis <expan><abbr>fil</abbr><ex>ius</ex></expan> <lb n="3"/>Papiria Lucilianus <expan><abbr>dec</abbr><ex>urio</ex></expan> Brectenus IIvir flamen <lb n="4"/>et Valeria Materna mater Enius Aulinus frat&amp;lt;e&amp;gt;r <lb n="5"/>sorori <expan><abbr>amantiss</abbr><ex>imae</ex></expan> et sibi pos&amp;lt;t&amp;gt;<expan><abbr>e</abbr><ex>risque</ex></expan> suis vivi <expan><abbr>fecer</abbr><ex>unt</ex></expan> 
            </ab></div>
