                <expan><abbr>M</abbr><ex>arco</ex></expan> Aurelio Masculo <lb n="2"/><expan><abbr>v</abbr><ex>iro</ex></expan> <expan><abbr>e</abbr><ex>gregio</ex></expan> <lb n="3"/>ob eximiam praesidatus <lb n="4"/>eius integritatem et <lb n="5"/>egregiam ad omnes homines <lb n="6"/>mansuetudinem et urgentis <lb n="7"/>annonae sinceram praebitionem <lb n="8"/>ac munificentiam et quod aquae <lb n="9"/>usum vetustate lapsum requi<lb break="no" n="10"/>situm ac repertum saeculi <lb n="11"/>felicitate cursui pristino <lb n="12"/>reddiderit <lb n="13"/><expan><abbr>colleg</abbr><ex>ia</ex></expan> III <lb n="14"/><expan><abbr>quib</abbr><ex>us</ex></expan> ex <expan><abbr>s</abbr><ex>enatus</ex></expan> <expan><abbr>c</abbr><ex>onsulto</ex></expan> <expan><abbr>c</abbr><ex>oire</ex></expan> <expan><abbr>p</abbr><ex>ermissum</ex></expan> est <lb n="15"/>patrono <expan><abbr>digniss</abbr><ex>imo</ex></expan>
