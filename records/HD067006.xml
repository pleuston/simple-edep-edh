                <expan><abbr><supplied reason="lost">N</supplied>utrecib</abbr><ex>us</ex></expan> <note>sic</note> Au<supplied reason="lost"><expan><abbr>g</abbr><ex>ustis</ex></expan> s</supplied><expan><abbr>acr</abbr><ex>um</ex></expan> Sati<gap reason="lost" extent="unknown" unit="character"/>
