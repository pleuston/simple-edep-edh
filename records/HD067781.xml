            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                βασιλίσσης καὶ βασι<lb break="no" n="2"/>λέως προσταξάντων <lb n="3"/>ἀντὶ τῆς προανακει<lb break="no" n="4"/>μένης περὶ τῆς ἀναθέσε<lb break="no" n="5"/>ως τῆς προσευχῆς πλα<lb break="no" n="6"/>κός, ἡ ὑπογεγραμμένη <lb n="7"/>ἐπιγραφήτω <lb n="8"/>βασιλεὺς Πτολεμαῖος Εὐ<lb break="no" n="9"/>εργέτης τὴν προσευχὴν <lb n="10"/>ἄσυλον </ab></div><div n="2" type="textpart"><ab><lb n="1"/> regina et <lb n="2"/>rex iusser<expan><ex>un</ex><abbr>t</abbr></expan>
            </ab></div></div>
