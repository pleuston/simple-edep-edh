                <expan><abbr>Mercur</abbr><ex>io</ex></expan> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/>INCE<supplied reason="lost">N</supplied> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/>
