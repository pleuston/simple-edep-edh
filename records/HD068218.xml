                Numini domus Augustae <lb n="2"/><expan><abbr>Ti</abbr><ex>berius</ex></expan> Claudius Faustus <expan><abbr>Regin</abbr><ex>us</ex></expan> et <lb n="3"/>Claudia Nais Fausti <lb n="4"/>balneum populo et familiai <note>sic</note> <lb n="5"/>Caesaris <expan><abbr>n</abbr><ex>ostri</ex></expan> <expan><abbr>d</abbr><ex>e</ex></expan> <supplied reason="lost"><expan><abbr>s</abbr><ex>ua</ex></expan></supplied> <expan><abbr>p</abbr><ex>ecunia</ex></expan> <expan><abbr>f</abbr><ex>ecerunt</ex></expan> idemque <lb n="6"/>aquam in eius balnei usus <lb n="7"/>perduxerunt et consacrarunt <lb n="8"/><del rend="erasure">[Nerone</del>] Caesare <expan><abbr>Aug</abbr><ex>usto</ex></expan> et Antistio Vetere <lb n="9"/>co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan>
