                Genio loci <lb n="2"/><expan><abbr>Fortun</abbr><ex>ae</ex></expan> Reduci <lb n="3"/>Romae <expan><abbr>Aetern</abbr><ex>ae</ex></expan> <lb n="4"/>et Fato Bono <lb n="5"/><expan><abbr>G</abbr><ex>aius</ex></expan> Cornelius <lb n="6"/>Peregrinus <lb n="7"/><expan><abbr>trib</abbr><ex>unus</ex></expan> <expan><abbr>cohor</abbr><ex>tis</ex></expan> <lb n="8"/>ex provincia <lb n="9"/><expan><abbr>Maur</abbr><ex>etania</ex></expan> <expan><abbr>Caesa</abbr><ex>riensi</ex></expan> <lb n="10"/>domo Sald<supplied reason="lost">i</supplied>s <lb n="11"/><expan><abbr>d<supplied reason="lost">e</supplied>c</abbr><ex>urio</ex></expan> <expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>aetus</ex></expan> <supplied reason="lost"><expan><abbr>l</abbr><ex>ibens</ex></expan></supplied> <expan><abbr>m</abbr><ex>erito</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> Volanti vivas
