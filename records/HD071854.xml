    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <expan><abbr>Imp</abbr><ex>erator</ex></expan> Caesar Vespasianus Augustus <lb n="2"/>pontifex maximus <expan><abbr>tribunic</abbr><ex>ia</ex></expan> <expan><abbr>potestat</abbr><ex>e</ex></expan> <lb n="3"/>VIIII <expan><abbr>imp</abbr><ex>erator</ex></expan> XVIIII <expan><abbr>p</abbr><ex>ater</ex></expan> <expan><abbr>p</abbr><ex>atriae</ex></expan> censor co<expan><ex>n</ex><abbr>s</abbr><ex>ul</ex></expan> VIII <lb n="4"/>peditibus et equitibus qui militant in co<lb break="no" n="5"/>hortibus sex I Cretum I et II Bracarau<lb break="no" n="6"/>gustanorum II Chalcidenorum VII Gallo<lb break="no" n="7"/>rum Ubiorum quae sunt in Moesia sub <expan><abbr>Sex</abbr><ex>to</ex></expan> <lb n="8"/>Vettuleno Ceriale qui quina et vicena sti<lb break="no" n="9"/>pendia aut plura meruerant item remi<lb break="no" n="10"/>gibus qui militant in classe quae est in <lb n="11"/>provincia eadem sub eodem qui sena et vi<lb break="no" n="12"/>cena stipendia aut plura meruerant quo<lb break="no" n="13"/>rum nomina subscripta sunt ipsis libe<lb break="no" n="14"/>ris posterisque eorum civitatem <lb n="15"/>dedit et conubium cum uxoribus quas tunc <lb n="16"/>habuissent cum est civitas iis data aut si qui <lb n="17"/><supplied reason="lost">caelibes essent cum iis quas postea duxissent</supplied> <lb n="18"/><supplied reason="lost">dumtaxat singuli singulas <gap reason="lost" extent="unknown" unit="character"/></supplied>
            </ab></div>
