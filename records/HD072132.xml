                <expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="2"/>Doloc<expan><ex>h</ex><abbr>eno</abbr></expan> <note>sic</note> <lb n="3"/>Secundius <lb n="4"/>Restutus |(centurio) <lb n="5"/><expan><abbr>leg</abbr><ex>ionis</ex></expan> X <expan><abbr>gem</abbr><ex>inae</ex></expan> <lb n="6"/>pro se et <lb n="7"/><supplied reason="lost">su</supplied>is <lb n="8"/><supplied reason="lost">po</supplied>suit
