                <supplied reason="lost">V</supplied>aleriano IIII et <lb n="2"/><supplied reason="lost">Ga</supplied>llieno III <expan><abbr>Aug<am>g</am></abbr><ex>ustis</ex></expan> co<expan><ex>n</ex><abbr>ss</abbr><ex>ulibus</ex></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <expan><abbr>Aur</abbr><ex>elius</ex></expan> Claudi<lb break="no" n="2"/>us Salunas <lb n="3"/>ex <expan><abbr>region</abbr><ex>e</ex></expan> <lb n="4"/><expan><abbr>Dolich</abbr><ex>e</ex></expan> a vico <lb n="5"/>Arpuartura <lb n="6"/>ex re promis<lb break="no" n="7"/>so et fidei <expan><abbr>bon</abbr><ex>ae</ex></expan> <lb n="8"/>votum promissum <expan><abbr>solv</abbr><ex>it</ex></expan>
            </ab></div></div>
            <div type="commentary">
