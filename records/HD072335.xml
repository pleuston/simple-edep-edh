            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                <supplied reason="lost" cert="low">Ἀγαθῆι τύχηι</supplied> <lb n="2"/><supplied reason="lost">ἐπὶ τοῦ δεῖνος ἄρχοντος καὶ ἱερέως Δρούσου ὑπάτου, ἐπὶ τῆς <gap reason="lost" extent="unknown" unit="character"/> ίδος <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="3"/><supplied reason="lost">πρυτανείας ἧς (vel ἧι) ὁ δεῖνα ἐγραμμάτευεν <gap reason="lost" extent="unknown" unit="character"/> Ποσει</supplied>δεῶν̣<supplied reason="lost">ος</supplied> <lb n="4"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> τῆς πρυτανείας· τῶν προέδρων ἐπεψήφιζεν ὁ δεῖνα καὶ συ</supplied>μπρόεδροι <lb n="5"/><supplied reason="lost">ἔδοξε (τῆι ἐξ Ἀρείου πάγου βουλῇ καὶ<certainty locus="name" match="preceding-sibling::text()" cert="low"/>) τῆι βουλῇ τῶν ἑξα</supplied>κοσίων καὶ τῶι Ἀ<lb break="no" n="6"/><supplied reason="lost">θηναίων δήμωι <gap reason="lost" extent="unknown" unit="character"/> ἐπαινέσαι <gap reason="lost" extent="unknown" unit="character"/></supplied>λεα τὸν ἀρχιερέα τε <lb n="7"/><supplied reason="lost">τῶν Σεβαστῶν καὶ ἀγωνοθέτην τῶν τῆς Σεβαστῆς οἰκία</supplied>ς<certainty match="preceding-sibling::node()" locus="value"/> ἀγώνων ἐπὶ πεντε<lb break="no" n="8"/><supplied reason="lost">τηρίδα <gap reason="lost" extent="unknown" unit="character"/> τὸν εὐεργετήσαντα<certainty locus="name" match="preceding-sibling::text()" cert="low"/> τὴν</supplied> πόλιν τὴν Ἀθηναίων <lb n="9"/><gap reason="lost" extent="unknown" unit="character"/> ἔπαρχος Αἰγύπτου <lb n="10"/><supplied reason="lost"><gap reason="lost" extent="unknown" unit="character"/> δί</supplied>πλωμα συνεσφραγεί<lb break="no" n="11"/><supplied reason="lost">σατο <gap reason="lost" extent="unknown" unit="character"/></supplied>ΟΙΣ ἀριθμήσας τῶν <lb n="12"/><gap reason="lost" extent="unknown" unit="character"/><supplied reason="lost" cert="low"> εἰκ</supplied>όσι καὶ καθειερώσα̣ς <lb n="13"/><gap reason="lost" extent="unknown" unit="character"/> Δήμητρος καὶ <supplied reason="lost">Κό</supplied><lb break="no" n="14"/><supplied reason="lost" cert="low">ρης --- διένε</supplied>ιμ(ε)ν αὐτῶι <gap reason="lost" extent="unknown" unit="character"/> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/>
