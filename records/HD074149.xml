                <supplied reason="lost"><expan><abbr>S</abbr><ex>il</ex>va</expan></supplied><expan><abbr>n</abbr><ex>o</ex></expan><certainty match="preceding-sibling::node()" locus="value"/> <expan><abbr>sac</abbr><ex>rum</ex></expan>
