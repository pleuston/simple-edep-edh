                <expan><abbr>D</abbr><ex>eo</ex></expan> <expan><abbr>I</abbr><ex>nvicto</ex></expan> <expan><abbr>M</abbr><ex>ithrae</ex></expan> A<gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/>et <expan><abbr>Aur</abbr><ex>eli--</ex></expan> V<gap reason="lost" quantity="1" unit="line"/>
