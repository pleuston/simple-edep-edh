                Momacus caro <expan><abbr>fra</abbr><ex>tri</ex></expan> <expan><abbr>Rivo</abbr><ex cert="low"/></expan> an<supplied reason="lost">te die</supplied>m XII <expan><abbr>K</abbr><ex>alendas</ex></expan> Se<expan><ex>p</ex><abbr>tem</abbr></expan><supplied reason="lost"><expan><abbr>b</abbr><ex>res</ex></expan></supplied> salve <gap reason="lost" extent="unknown" unit="character"/> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> <gap reason="lost" extent="unknown" unit="character"/> Sesti <expan><abbr>ex</abbr><ex cert="low"/></expan> <gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> ad <expan><abbr>riv</abbr><ex cert="low"/></expan><gap reason="lost" extent="unknown" unit="character"/> </ab></div><div n="3" type="textpart"><ab><lb n="1"/> epistulas <gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/>peto ut mi<supplied reason="lost">tta</supplied><expan><abbr>s</abbr><ex cert="low"/></expan> m<supplied reason="lost">ihi<certainty locus="name" match="preceding-sibling::text()" cert="low"/> <gap reason="lost" extent="unknown" unit="character"/></supplied> <lb n="3"/>si at m<supplied reason="lost">e</supplied> miseris <expan><abbr>eo</abbr><ex cert="low"/></expan> <gap reason="lost" extent="unknown" unit="character"/> <lb n="4"/>quas mihi da TES<gap reason="lost" extent="unknown" unit="character"/> <lb n="5"/>ecce nipoti n<gap reason="lost" extent="unknown" unit="character"/> <lb n="6"/><expan><abbr>INO</abbr><ex cert="low"/></expan><gap reason="lost" extent="unknown" unit="character"/> <lb n="7"/>neq<supplied reason="lost">ui</supplied>t OM<gap reason="lost" extent="unknown" unit="character"/> <lb n="8"/>imi<surplus>u</surplus>tatio<supplied reason="lost">nes</supplied> <lb n="9"/>mi facias <gap reason="lost" extent="unknown" unit="character"/> <lb n="10"/>ut si scutella argenti XI O<gap reason="lost" extent="unknown" unit="character"/> </ab></div><div n="4" type="