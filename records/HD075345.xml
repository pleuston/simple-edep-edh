            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Pro salute <expan><abbr>Imp</abbr><ex>eratorum</ex></expan> <expan><abbr>n</abbr><ex>ostrorum</ex></expan> <lb n="2"/><expan><abbr>I</abbr><ex>ovi</ex></expan> <expan><abbr>O</abbr><ex>ptimo</ex></expan> <expan><abbr>M</abbr><ex>aximo</ex></expan> <lb n="3"/>ceterisque Diis <lb n="4"/>et Genio loci <lb n="5"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Verecundini<lb break="no" n="6"/>us Simplex |(centurio) <expan><abbr>leg</abbr><ex>ionis</ex></expan> XXX <expan><abbr>Ulp</abbr><ex>iae</ex></expan> curam <lb n="7"/>agens strato<lb break="no" n="8"/>rum et peditum <lb n="9"/>singularium co<expan><ex>n</ex><abbr>s</abbr><ex>ularis</ex></expan> <lb n="10"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>l</abbr><ex>aetus</ex></expan> <lb n="11"/>Macrino et Ce&amp;lt;l=I&amp;gt;so co<expan><ex>n</ex><abbr>s</abbr><ex>ulibus</ex></expan> 
            </ab></div>
