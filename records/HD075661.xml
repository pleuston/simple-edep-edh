                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Visionio Ia<lb break="no" n="3"/>so et coniu<lb break="no" n="4"/>gi fili eius fe<lb break="no" n="5"/>cerunt
