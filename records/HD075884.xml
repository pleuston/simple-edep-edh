                <expan><abbr>D</abbr><ex cert="low">eae</ex></expan> <expan><abbr>O</abbr><ex cert="low">ptimae</ex></expan> <expan><abbr>M</abbr><ex cert="low">aximae</ex></expan> <lb n="2"/>Dian<expan><ex>a</ex><abbr>e</abbr></expan> ex pr<expan><ex>a</ex><abbr>ecept</abbr></expan><lb break="no" n="3"/>is posuit Sec<supplied reason="lost">u</supplied>ndio
