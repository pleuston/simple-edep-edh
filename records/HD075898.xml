                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/>Quintio Libe<lb break="no" n="3"/>rali qui vixit <lb n="4"/>annis LI et <lb n="5"/>Proximoniae <lb n="6"/>Sanctae co<expan><ex>n</ex><abbr>iugi</abbr></expan> <lb n="7"/>ei<surplus>i</surplus>us viv<expan><ex>a</ex><abbr>e</abbr></expan> sibi <lb n="8"/>fili eorum Libe<lb break="no" n="9"/>ralini Iuvenis <lb n="10"/>et Iuventina et <lb n="11"/>Maternus et Fau<lb break="no" n="12"/>stus et Tiberna<lb break="no" n="13"/>lis fili eorum <lb n="14"/>patri incomparabili <lb n="15"/><expan><abbr>f</abbr><ex>aciendum</ex></expan> <expan><abbr>c</abbr><ex>uraverunt</ex></expan>
