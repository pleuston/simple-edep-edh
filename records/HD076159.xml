                Quietus <expan><abbr>M</abbr><ex>arci</ex></expan> <lb n="2"/>Viri <expan><abbr>f</abbr><ex>ilius</ex></expan> <lb n="3"/><expan><abbr>an</abbr><ex>norum</ex></expan> IIII <lb n="4"/><expan><abbr>h</abbr><ex>ic</ex></expan> <expan><abbr>s</abbr><ex>itus</ex></expan> <expan><abbr>e</abbr><ex>st</ex></expan>
