                <supplied reason="lost">Hic requies</supplied>cit Macedonia quae vixit ann<supplied reason="lost">o u</supplied>no et me<expan><ex>n</ex><abbr>ses</abbr></expan> q<supplied reason="lost">u</supplied><gap reason="lost" extent="unknown" unit="character"/> <lb n="2"/><gap reason="lost" extent="unknown" unit="character"/> Lea dulcissimae filiae suae ti<supplied reason="lost">t</supplied>ulum <expan><abbr>posu</abbr><ex>it</ex></expan>
