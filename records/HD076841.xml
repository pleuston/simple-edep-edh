                <expan><abbr>C</abbr><ex>aio</ex></expan> Attio Caro <lb n="2"/>et <expan><abbr>Iul</abbr><ex>iae</ex></expan> Suausiae <lb n="3"/>uxori Attio Paterno <lb n="4"/>Attiae Avianae fili<expan><ex>i</ex><abbr>s</abbr></expan> <lb n="0"/><gap reason="lost" quantity="1" unit="line"/>
