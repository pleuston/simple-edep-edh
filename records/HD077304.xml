    <text>
        <body>
            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                ἁγνὴν παρθ<supplied reason="lost">ένον</supplied> <lb n="2"/>Εὐστόργιος θῆκ<supplied reason="lost">εν παρὰ</supplied> <lb n="3"/>σκηναῖς πάν<supplied reason="lost">τ’ ἀρ</supplied>ί̣σ̣τ̣<supplied reason="lost">ην ἐς</supplied> <lb n="4"/>ἀμνόν τ’ ἀβρὰ νε(ύ)ου<supplied reason="lost">σαν</supplied> <lb n="5"/>ὄφρα πανημέριος <supplied reason="lost">ὁρῶν</supplied> <lb n="6"/><supplied reason="lost">ὑ</supplied>μνοῖς πατέρα πά<supplied reason="lost">ντων</supplied> <lb n="7"/><supplied reason="lost">με</supplied>λπομένη μεθ’ ὁ<supplied reason="lost">μιλία</supplied> <lb n="8"/><supplied reason="lost">Χρι</supplied>στῷ πανβασιλε<supplied reason="lost">ῖ τε καὶ</supplied> <lb n="9"/><supplied reason="lost">πνε</supplied>ύματι σὺν ἁγίῳ· <supplied reason="lost">καὶ τόδε</supplied> <lb n="10"/><supplied reason="lost">παρ</supplied>ά μοι φίλον ἄ<supplied reason="lost">γαλμα</supplied> <lb n="11"/><supplied reason="lost">αὐτ</supplied>οθέα προφαν(ε)ῖ ἅ<supplied reason="lost">γιόν τι</supplied> <lb n="12"/><supplied reason="lost">σαφ</supplied>ῶς, σοῖσι πατράσι <supplied reason="lost">γνωτόν</supplied> <lb n="13"/><supplied reason="lost">μὴ ὂ</supplied>ν σφαλλόμενο<supplied reason="lost">ν ἀπὸ</supplied> <lb n="14"/><supplied reason="lost">σωφ</supplied>ροσύνης τ’ ἀρετῆ<supplied reason="lost">ς τε</supplied>
            </ab></div>
            <div type="commentary">
                <p>Metrum: Hexameter.</p>
            </div>
