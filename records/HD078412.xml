                <expan><abbr>Oliva</abbr><ex>e</ex></expan> <expan><abbr>nig</abbr><ex>rae</ex></expan> ex <expan><abbr>defr</abbr><ex>uto</ex></expan> <lb n="2"/><expan><abbr>penuar</abbr><ex>ium</ex></expan> <lb n="3"/><expan><abbr>excell</abbr><ex>ens</ex></expan> <lb n="4"/><expan><abbr>C</abbr><ex>ai</ex></expan> Rutili Felicis </ab></div><div n="2" type="textpart"><ab><lb n="0"/> <gap reason="lost" quantity="1" unit="line"/>
