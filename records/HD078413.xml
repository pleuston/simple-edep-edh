                <expan><abbr>C</abbr><ex>aius</ex></expan> Lucius Vi<supplied reason="lost">c</supplied>tor <lb n="2"/>de<supplied reason="lost"><expan><abbr>c</abbr><ex>urio</ex></expan> ci</supplied>vitatis <expan><abbr>Vang</abbr><ex>ionum</ex></expan> <lb n="3"/>omnibus honeribus <note>sic</note> functus <lb n="4"/>et Victori Florentinus <lb n="5"/>et Victorinus <expan><abbr>fili</abbr><ex>i</ex></expan> <lb n="6"/>ob amorem patri<supplied reason="lost">a</supplied>e et civium <lb n="7"/>portam omni sumptu suo exstructam <lb n="8"/>donaverunt
