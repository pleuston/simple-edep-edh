            <div type="edition" xml:space="preserve"><head>Text</head><ab><lb n="1"/>
                Hic iacet Meteriola mihi dul<lb break="no" n="2"/>cissima coniux qui mecum <lb n="3"/>labora&amp;lt;v=B&amp;gt;it multis et pl<expan><ex>u</ex><abbr>ribus</abbr></expan> a<lb break="no" n="4"/>nnis qu<expan><ex>a</ex><abbr>e</abbr></expan> mihi fuit ann&amp;lt;o=V&amp;gt;s XXIII <lb n="5"/>coniux et ann&amp;lt;o=V&amp;gt;s VIII et me<expan><ex>n</ex><abbr>ses</abbr></expan> <lb n="6"/><expan><abbr>septe</abbr><ex>m</ex></expan> et dies XVIII soror in Domin<lb break="no" n="7"/>o D<expan><ex>e</ex><abbr>o</abbr></expan> nos<expan><ex>t</ex><abbr>ro</abbr></expan> h<expan><ex>ie</ex><abbr>su</abbr></expan> X<expan><ex>Ch</ex><abbr>P</abbr><ex>rist</ex><abbr>o</abbr></expan> qui mihi &amp;lt;t=F&amp;gt;an<lb break="no" n="8"/>ti <expan><ex>h</ex><abbr>abeat</abbr></expan> ostendere vias suas q<expan><ex>u</ex><abbr>as</abbr></expan> <lb n="9"/>ego seq<expan><ex>u</ex><abbr>ere</abbr></expan> poss&amp;lt;i=E&amp;gt;m 
            </ab></div>
