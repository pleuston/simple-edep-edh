            <div type="edition" xml:space="preserve"><head>Text</head><div n="1" type="textpart"><ab><lb n="1"/>
                <expan><abbr>Merc</abbr><ex>urio</ex></expan> <expan><abbr>Aug</abbr><ex>usto</ex></expan> <lb n="2"/><expan><abbr>L</abbr><ex>ucius</ex></expan> Silanius Candidus <lb n="3"/>nomine suo et <lb n="4"/><expan><abbr>M</abbr><ex>arci</ex></expan> Silani Sabini <lb n="5"/>et <expan><abbr>T</abbr><ex>iti</ex></expan> Silvi Similis <lb n="6"/>fratrum suorum <lb n="7"/>ex HS <expan><abbr>n</abbr><ex>ummum</ex></expan> <expan><abbr>IIII</abbr><ex>milibus</ex></expan> <expan><abbr>t</abbr><ex>estamento</ex></expan> <expan><abbr>p</abbr><ex>oni</ex></expan> <expan><abbr>i</abbr><ex>ussit</ex></expan> <lb n="8"/><expan><abbr>M</abbr><ex>arcus</ex></expan> Domitius Magnus <lb n="9"/>heres <expan><abbr>ponend</abbr><ex>um</ex></expan> curavit <lb n="10"/>et eo amplius de suo <lb n="11"/>adiecit HS <expan><abbr>n</abbr><ex>ummum</ex></expan> m<expan><ex>ille</ex><abbr>CCCC</abbr></expan> </ab></div><div n="2" type="textpart"><ab><lb n="1"/> dona venibunt <lb n="2"/>ad ornamenta eius <lb n="3"/>et ex stipibus <lb n="4"/>ponentur
            </ab></div></div>
            <div type="commentary">
                <p>Sockel und Bekrönung fehlen. Text 2 befindet sich auf der Rückseite. Blattförmige hederae als Worttrenner in Z. 1 u. Text 2, Z. 3.</p>
            </div>
