                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/><expan><abbr>Pressus</abbr><ex cert="low"/></expan> <lb n="3"/><supplied reason="lost" cert="low">Pre</supplied>ssi <expan><abbr>fil</abbr><ex>ius</ex></expan>
