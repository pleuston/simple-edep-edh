                <expan><abbr>De</abbr><ex>ae</ex></expan> Minerv<expan><ex>a</ex><abbr>e</abbr></expan> Saxxamus <lb n="2"/>Cintusmi filius posuit <lb n="3"/><expan><abbr>v</abbr><ex>otum</ex></expan> <expan><abbr>s</abbr><ex>olvit</ex></expan> <expan><abbr>l</abbr><ex>ibens</ex></expan> <expan><abbr>m</abbr><ex>erito</ex></expan>
