                <expan><abbr>D</abbr><ex>is</ex></expan> <expan><abbr>M</abbr><ex>anibus</ex></expan> <lb n="2"/><expan><ex>A</ex><abbr>eliae</abbr></expan> li<lb break="no" n="3"/>bertae <expan><abbr>p</abbr><ex>ublicae</ex></expan> <lb n="4"/>Arari<lb break="no" n="5"/>cus <expan><abbr>frat</abbr><ex>er</ex></expan> <lb n="6"/><expan><abbr>p</abbr><ex>onendum</ex></expan> <expan><abbr>c</abbr><ex>uravit</ex></expan>
